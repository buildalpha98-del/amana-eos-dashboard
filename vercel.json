      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/cron/compliance-alerts",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/cron/auto-onboarding",
      "schedule": "30 21 * * *"
    },
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/cron/auto-escalation",
