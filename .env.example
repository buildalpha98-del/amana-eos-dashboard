DATABASE_URL=postgresql://postgres:password@localhost:5432/amana_eos
NEXTAUTH_SECRET=generate-a-strong-secret-here
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@amanaoshc.com.au
ADMIN_PASSWORD=change-this-on-first-login

# WhatsApp Business API (Support Tickets):
WHATSAPP_ACCESS_TOKEN=your-permanent-system-user-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-chosen-webhook-verification-string
WHATSAPP_APP_SECRET=your-app-secret-for-hmac-verification

# Railway deployment:
# - Set DATABASE_URL to your Railway PostgreSQL connection string
# - Set NEXTAUTH_URL to your Railway app URL (e.g. https://your-app.up.railway.app)
# - Generate NEXTAUTH_SECRET with: openssl rand -base64 32
# - Set WHATSAPP_* variables from your Meta Developer Dashboard
# - Configure webhook URL: https://your-app.up.railway.app/api/webhooks/whatsapp
