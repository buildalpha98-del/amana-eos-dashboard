# ── Test Environment Variables ────────────────────────────────
# Copy this file and fill in a test-specific DATABASE_URL.
# NEVER use the production database for tests.

# Test database (use a separate Railway dev branch, Docker container, or local PG)
DATABASE_URL="postgresql://test:test@localhost:5432/amana_eos_test"

# Auth
NEXTAUTH_SECRET="test-secret-do-not-use-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Cron
CRON_SECRET="test-cron-secret"

# Cowork API
COWORK_API_KEY="test-cowork-api-key"

# Stub external services (tests should never call real APIs)
RESEND_API_KEY="re_test_fake"
ANTHROPIC_API_KEY="sk-ant-test-fake"

# Sentry (disabled in test — leave blank)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
