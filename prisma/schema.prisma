// ---------------------------------------------------------------------------
// API Key Management — database-backed API keys for external integrations
// ---------------------------------------------------------------------------

model ApiKey {
  id          String    @id @default(cuid())
  name        String // human label, e.g. "Cowork Production"
  keyPrefix   String // first 8 hex chars for display
  keyHash     String    @unique // SHA-256 hex of the full key
  scopes      String[] // ["programs:write", "menus:write", "announcements:write"]
  allowedIps  String[] // empty = allow all; otherwise restrict to these IPs/CIDRs
  expiresAt   DateTime? // null = never expires
  revokedAt   DateTime? // non-null = revoked
  lastUsedAt  DateTime?
  createdById String
  createdBy   User      @relation("ApiKeyCreator", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([keyHash])
  @@index([createdById])
}

