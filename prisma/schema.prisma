  whatsappPostsRecorded          WhatsAppCoordinatorPost[] @relation("WhatsAppRecorder")
  whatsappNetworkPostsRecorded   WhatsAppNetworkPost[]     @relation("WhatsAppNetworkPostRecordedBy")
  qrCodesCreated                 QrCode[]                  @relation("QrCodeCreatedBy")
  weeklyMarketingReportsDrafted  WeeklyMarketingReport[]   @relation("WeeklyReportDrafter")
  weeklyMarketingReportsReviewed WeeklyMarketingReport[]   @relation("WeeklyReportReviewer")
  weeklyMarketingReportsSent     WeeklyMarketingReport[]   @relation("WeeklyReportSender")
  socialCountersUpdated          SocialCounter[]           @relation("SocialCounterUpdater")
  amanaWayContentEdits           AmanaWayContent[]         @relation("AmanaWayContentUpdater")
  amanaHandbookContentEdits      AmanaHandbookContent[]    @relation("AmanaHandbookContentUpdater")
  emailTemplateOverridesEdited   EmailTemplateOverride[]   @relation("EmailTemplateUpdater")
  orgSettingsEdited              OrgSettings[]             @relation("OrgSettingsUpdater")

  // ── Centre Avatars (Sprint 3) ─────────────────────
  centreAvatarInsightsCreated          CentreAvatarInsight[]            @relation("CentreAvatarInsightCreatedBy")
  centreAvatarCampaignLogsCreated      CentreAvatarCampaignLog[]        @relation("CentreAvatarCampaignLogCreatedBy")
  centreAvatarCheckInsAsCoordinator    CentreAvatarCoordinatorCheckIn[] @relation("CentreAvatarCheckInCoordinator")
  centreAvatarCheckInsCreated          CentreAvatarCoordinatorCheckIn[] @relation("CentreAvatarCheckInCreatedBy")
  centreAvatarSchoolLiaisonLogsCreated CentreAvatarSchoolLiaisonLog[]   @relation("CentreAvatarSchoolLiaisonCreatedBy")
  centreAvatarUpdateLogs               CentreAvatarUpdateLog[]          @relation("CentreAvatarUpdateLogUpdatedBy")
  // 2026-05-04 (timeclock v1): kiosks the user has registered.
  kiosksCreated                        Kiosk[]                          @relation("KioskCreator")
  // 2026-05-04 (shift templates v1): templates the user has authored.
  shiftTemplatesCreated                ShiftTemplate[]                  @relation("ShiftTemplateCreator")
  // 2026-07-05 (AI morning briefing v1): one AI-composed brief per day.
  dailyBriefings                       DailyBriefing[]                  @relation("UserDailyBriefings")

  // 2026-05-14 (service-staff v1): additional service memberships layered on
  // top of User.serviceId (which stays as the primary/home service). Lets a
  // single staff member be at multiple centres with per-service role+access.
  serviceMemberships UserServiceMembership[] @relation("UserMemberships")

  @@index([serviceId])
  @@index([contentTeamRole, contentTeamStatus])
  @@index([name])
}

model PasswordResetToken {
