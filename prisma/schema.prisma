generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  owner
  admin
  member
  staff
}

enum RockStatus {
  on_track
  off_track
  complete
  dropped
}

enum RockPriority {
  critical
  high
  medium
}

enum RockType {
  company
  personal
}

enum TodoStatus {
  pending
  in_progress
  complete
  cancelled
}

enum IssuePriority {
  critical
  high
  medium
  low
}

enum IssueStatus {
  open
  in_discussion
  solved
  closed
}

enum GoalStatus {
  on_track
  at_risk
  off_track
  complete
}

enum GoalDirection {
  above
  below
  exact
}

enum MeasurableFrequency {
  weekly
  monthly
}

enum ServiceStatus {
  active
  onboarding
  pipeline
  closing
  closed
}

enum SessionType {
  bsc
  asc
  vc
}

enum ProjectStatus {
  not_started
  in_progress
  complete
  on_hold
  cancelled
}

enum MeetingStatus {
  scheduled
  in_progress
  completed
  cancelled
}

// ============================================================
// Marketing
// ============================================================

enum MarketingPlatform {
  facebook
  instagram
  linkedin
  email
  newsletter
  website
  flyer
}

enum MarketingPostStatus {
  draft
  in_review
  approved
  scheduled
  published
}

enum MarketingCampaignType {
  campaign
  event
  launch
  promotion
  awareness
  partnership
}

enum MarketingCampaignStatus {
  draft
  scheduled
  active
  completed
  paused
  cancelled
}

enum MarketingRecurrence {
  none
  weekly
  fortnightly
  monthly
}

enum MarketingKPIPeriod {
  monthly
  quarterly
  yearly
}

enum MarketingAssetType {
  image
  video
  document
  template
  graphic
}

enum MarketingHashtagCategory {
  brand
  campaign
  platform
  trending
}

enum MarketingKPICategory {
  engagement
  growth
  content
  conversion
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(member)
  avatar       String?
  active       Boolean  @default(true)
  serviceId    String?
  service      Service? @relation("ServiceStaff", fields: [serviceId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedRocks        Rock[]            @relation("RockOwner")
  assignedTodos     Todo[]            @relation("TodoAssignee")
  createdTodos      Todo[]            @relation("TodoCreator")
  raisedIssues      Issue[]           @relation("IssueRaiser")
  ownedIssues       Issue[]           @relation("IssueOwner")
  ownedMeasurables  Measurable[]      @relation("MeasurableOwner")
  measurableEntries MeasurableEntry[] @relation("EntryCreator")
  activityLogs      ActivityLog[]
  vtoUpdates        VisionTractionOrganiser[] @relation("VTOUpdater")
  managedServices   Service[]         @relation("ServiceManager")
  ownedProjects     Project[]         @relation("ProjectOwner")
  createdMeetings   Meeting[]         @relation("MeetingCreator")
  uploadedDocuments Document[]        @relation("DocumentUploader")
  uploadedAttachments Attachment[]    @relation("AttachmentUploader")
  assignedTickets   SupportTicket[]   @relation("TicketAssignee")
  sentMessages      TicketMessage[]   @relation("MessageSender")
  dismissedNotifications NotificationDismissal[]
  marketingPosts    MarketingPost[]   @relation("MarketingPostAssignee")
  marketingComments MarketingComment[] @relation("MarketingCommentAuthor")
  announcements     Announcement[]    @relation("AnnouncementAuthor")
  announcementReads AnnouncementRead[] @relation("AnnouncementReader")
  cascadeAcks       CascadeAcknowledgment[] @relation("CascadeAcknowledger")
  weeklyPulses      WeeklyPulse[]     @relation("PulseAuthor")
  passwordResetTokens PasswordResetToken[]
  calendarIntegration CalendarIntegration?
  onboardings       StaffOnboarding[] @relation("OnboardingUser")
  lmsEnrollments    LMSEnrollment[]   @relation("LMSStudent")
  certificates      ComplianceCertificate[] @relation("UserCertificates")
  recordedAttendance DailyAttendance[]     @relation("AttendanceRecorder")

  @@index([serviceId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model CalendarIntegration {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String   @default("microsoft") // "microsoft" | "google" (future)
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  scope        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model VisionTractionOrganiser {
  id                String   @id @default(cuid())
  coreValues        String[]
  corePurpose       String?
  coreNiche         String?
  tenYearTarget     String?  @db.Text
  threeYearPicture  String?  @db.Text
  marketingStrategy String?  @db.Text
  sectionLabels     Json?    // Custom section titles e.g. { tenYearTarget: "5-Year Target" }
  updatedAt         DateTime @updatedAt
  updatedById       String?
  updatedBy         User?    @relation("VTOUpdater", fields: [updatedById], references: [id])

  oneYearGoals OneYearGoal[]
}

model OneYearGoal {
  id          String     @id @default(cuid())
  title       String
  description String?    @db.Text
  targetDate  DateTime?
  status      GoalStatus @default(on_track)
  vtoId       String
  vto         VisionTractionOrganiser @relation(fields: [vtoId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  rocks Rock[]
}

model Rock {
  id              String       @id @default(cuid())
  title           String
  description     String?      @db.Text
  ownerId         String
  owner           User         @relation("RockOwner", fields: [ownerId], references: [id])
  quarter         String
  status          RockStatus   @default(on_track)
  percentComplete Int          @default(0)
  priority        RockPriority @default(medium)
  rockType        RockType     @default(personal)
  oneYearGoalId   String?
  oneYearGoal     OneYearGoal? @relation(fields: [oneYearGoalId], references: [id], onDelete: SetNull)
  serviceId       String?
  service         Service?     @relation("ServiceRocks", fields: [serviceId], references: [id], onDelete: SetNull)
  deleted         Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  todos       Todo[]
  issues      Issue[]
  milestones  Milestone[]
  measurables Measurable[]
  attachments Attachment[]

  @@index([quarter])
  @@index([ownerId])
  @@index([status])
  @@index([serviceId])
}

model Milestone {
  id        String   @id @default(cuid())
  title     String
  dueDate   DateTime
  completed Boolean  @default(false)
  rockId    String
  rock      Rock     @relation(fields: [rockId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Todo {
  id          String     @id @default(cuid())
  title       String
  description String?    @db.Text
  assigneeId  String
  assignee    User       @relation("TodoAssignee", fields: [assigneeId], references: [id])
  createdById String?
  createdBy   User?      @relation("TodoCreator", fields: [createdById], references: [id])
  rockId      String?
  rock        Rock?      @relation(fields: [rockId], references: [id], onDelete: SetNull)
  issueId     String?
  issue       Issue?     @relation(fields: [issueId], references: [id], onDelete: SetNull)
  serviceId   String?
  service     Service?   @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  projectId   String?
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  dueDate     DateTime
  status      TodoStatus @default(pending)
  weekOf      DateTime
  isPrivate   Boolean    @default(false)
  deleted     Boolean    @default(false)
  createdAt   DateTime   @default(now())
  completedAt DateTime?
  updatedAt   DateTime   @updatedAt

  @@index([assigneeId])
  @@index([rockId])
  @@index([weekOf])
  @@index([status])
  @@index([serviceId])
  @@index([projectId])
}

model Issue {
  id           String        @id @default(cuid())
  title        String
  description  String?       @db.Text
  raisedById   String
  raisedBy     User          @relation("IssueRaiser", fields: [raisedById], references: [id])
  ownerId      String?
  owner        User?         @relation("IssueOwner", fields: [ownerId], references: [id])
  rockId       String?
  rock         Rock?         @relation(fields: [rockId], references: [id], onDelete: SetNull)
  serviceId    String?
  service      Service?      @relation("ServiceIssues", fields: [serviceId], references: [id], onDelete: SetNull)
  priority     IssuePriority @default(medium)
  status       IssueStatus   @default(open)
  identifiedAt DateTime      @default(now())
  discussedAt  DateTime?
  solvedAt     DateTime?
  resolution   String?       @db.Text
  deleted      Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  spawnedTodos Todo[]
  attachments Attachment[]

  @@index([priority])
  @@index([status])
  @@index([ownerId])
  @@index([serviceId])
}

model Scorecard {
  id        String   @id @default(cuid())
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  measurables Measurable[]
}

model Measurable {
  id            String              @id @default(cuid())
  title         String
  description   String?
  ownerId       String
  owner         User                @relation("MeasurableOwner", fields: [ownerId], references: [id])
  goalValue     Float
  goalDirection GoalDirection       @default(above)
  unit          String?
  frequency     MeasurableFrequency @default(weekly)
  rockId        String?
  rock          Rock?               @relation(fields: [rockId], references: [id], onDelete: SetNull)
  scorecardId   String
  scorecard     Scorecard           @relation(fields: [scorecardId], references: [id], onDelete: Cascade)
  serviceId     String?
  service       Service?            @relation("ServiceMeasurables", fields: [serviceId], references: [id], onDelete: SetNull)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  entries MeasurableEntry[]

  @@index([ownerId])
  @@index([scorecardId])
  @@index([serviceId])
}

model MeasurableEntry {
  id           String     @id @default(cuid())
  measurableId String
  measurable   Measurable @relation(fields: [measurableId], references: [id], onDelete: Cascade)
  weekOf       DateTime
  value        Float
  onTrack      Boolean
  notes        String?
  enteredById  String
  enteredBy    User       @relation("EntryCreator", fields: [enteredById], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([measurableId, weekOf])
  @@index([weekOf])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String
  details    Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================================
// Marketing
// ============================================================

model MarketingCampaign {
  id          String                  @id @default(cuid())
  name        String
  type        MarketingCampaignType   @default(campaign)
  status      MarketingCampaignStatus @default(draft)
  startDate   DateTime?
  endDate     DateTime?
  platforms   MarketingPlatform[]
  goal        String?                 @db.Text
  notes       String?                 @db.Text
  designLink  String?
  deleted     Boolean                 @default(false)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  posts    MarketingPost[]
  comments MarketingComment[]

  @@index([status])
  @@index([startDate])
}

model MarketingPost {
  id               String               @id @default(cuid())
  title            String
  platform         MarketingPlatform
  status           MarketingPostStatus   @default(draft)
  scheduledDate    DateTime?
  content          String?               @db.Text
  notes            String?               @db.Text
  designLink       String?
  pillar           String?
  assigneeId       String?
  assignee         User?                 @relation("MarketingPostAssignee", fields: [assigneeId], references: [id])
  campaignId       String?
  campaign         MarketingCampaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  likes            Int                   @default(0)
  comments         Int                   @default(0)
  shares           Int                   @default(0)
  reach            Int                   @default(0)
  recurring        MarketingRecurrence   @default(none)
  recurringParentId String?
  recurringParent  MarketingPost?        @relation("RecurringPosts", fields: [recurringParentId], references: [id])
  recurringChildren MarketingPost[]      @relation("RecurringPosts")
  deleted          Boolean               @default(false)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([platform])
  @@index([status])
  @@index([assigneeId])
  @@index([campaignId])
  @@index([scheduledDate])
}

model MarketingComment {
  id         String            @id @default(cuid())
  campaignId String
  campaign   MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  authorId   String
  author     User              @relation("MarketingCommentAuthor", fields: [authorId], references: [id])
  text       String            @db.Text
  createdAt  DateTime          @default(now())

  @@index([campaignId])
  @@index([authorId])
}

model MarketingKPI {
  id        String               @id @default(cuid())
  name      String
  target    Float
  current   Float                @default(0)
  unit      String?
  period    MarketingKPIPeriod   @default(monthly)
  category  MarketingKPICategory @default(engagement)
  deleted   Boolean              @default(false)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([category])
  @@index([period])
}

model MarketingAsset {
  id        String             @id @default(cuid())
  name      String
  type      MarketingAssetType @default(image)
  url       String
  tags      String[]
  deleted   Boolean            @default(false)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([type])
}

model MarketingTemplate {
  id        String            @id @default(cuid())
  name      String
  platform  MarketingPlatform
  pillar    String?
  content   String            @db.Text
  notes     String?           @db.Text
  hashtags  String?
  deleted   Boolean           @default(false)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([platform])
}

model MarketingHashtagSet {
  id        String                  @id @default(cuid())
  name      String
  category  MarketingHashtagCategory
  tags      String                  @db.Text
  deleted   Boolean                 @default(false)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  @@index([category])
}

// ============================================================
// Services (OSHC Centres) & Projects
// ============================================================

model Service {
  id          String        @id @default(cuid())
  name        String
  code        String        @unique
  address     String?
  suburb      String?
  state       String?
  postcode    String?
  phone       String?
  email       String?
  status      ServiceStatus @default(active)
  managerId   String?
  manager     User?         @relation("ServiceManager", fields: [managerId], references: [id])
  capacity    Int?
  operatingDays String?
  notes       String?       @db.Text
  bscDailyRate  Float?
  ascDailyRate  Float?
  vcDailyRate   Float?
  bscCasualRate Float     @default(0)
  ascCasualRate Float     @default(0)
  xeroTrackingOptionId String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  todos    Todo[]
  projects Project[]
  issues   Issue[]    @relation("ServiceIssues")
  rocks    Rock[]     @relation("ServiceRocks")
  measurables Measurable[] @relation("ServiceMeasurables")
  financials FinancialPeriod[] @relation("ServiceFinancials")
  metrics    CentreMetrics[]   @relation("ServiceMetrics")
  documents  Document[] @relation("ServiceDocuments")
  tickets    SupportTicket[]  @relation("ServiceTickets")
  whatsappContacts WhatsAppContact[] @relation("ServiceContacts")
  announcements Announcement[] @relation("ServiceAnnouncements")
  healthScores      HealthScore[]      @relation("ServiceHealthScores")
  staffMembers      User[]             @relation("ServiceStaff")
  onboardingPacks   OnboardingPack[]   @relation("ServiceOnboardingPacks")
  lmsCourses        LMSCourse[]        @relation("ServiceCourses")
  certificates      ComplianceCertificate[] @relation("ServiceCertificates")
  attendance        DailyAttendance[]      @relation("ServiceAttendance")

  @@index([status])
  @@index([managerId])
}

model ProjectTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks    ProjectTemplateTask[]
  projects Project[]
}

model ProjectTemplateTask {
  id          String          @id @default(cuid())
  templateId  String
  template    ProjectTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  title       String
  description String?         @db.Text
  category    String?
  sortOrder   Int             @default(0)
  defaultDays Int?

  @@index([templateId])
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?       @db.Text
  serviceId   String?
  service     Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  templateId  String?
  template    ProjectTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  ownerId     String
  owner       User          @relation("ProjectOwner", fields: [ownerId], references: [id])
  status      ProjectStatus @default(not_started)
  startDate   DateTime?
  targetDate  DateTime?
  completedAt DateTime?
  deleted     Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  todos Todo[]
  attachments Attachment[]

  @@index([serviceId])
  @@index([ownerId])
  @@index([status])
}

// ============================================================
// L10 Meetings
// ============================================================

model Meeting {
  id            String        @id @default(cuid())
  title         String
  date          DateTime
  status        MeetingStatus @default(scheduled)
  currentSection Int          @default(0)
  rating        Float?
  notes         String?       @db.Text
  headlines     String?       @db.Text
  segueNotes    String?       @db.Text
  concludeNotes   String?       @db.Text
  cascadeMessages String?       @db.Text
  serviceIds    String[]      // IDs of services scoped to this meeting
  rockIds       String[]      // IDs of rocks linked to this meeting
  startedAt       DateTime?
  completedAt   DateTime?
  createdById   String
  createdBy     User          @relation("MeetingCreator", fields: [createdById], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  cascades CascadeMessage[] @relation("MeetingCascade")

  @@index([date])
  @@index([status])
  @@index([createdById])
}

// ============================================================
// Documents & Attachments
// ============================================================

enum DocumentCategory {
  program
  policy
  procedure
  template
  guide
  compliance
  financial
  marketing
  hr
  other
}

model Document {
  id          String           @id @default(cuid())
  title       String
  description String?          @db.Text
  category    DocumentCategory @default(other)
  fileName    String
  fileUrl     String
  fileSize    Int?
  mimeType    String?
  centreId    String?
  centre      Service?         @relation("ServiceDocuments", fields: [centreId], references: [id], onDelete: SetNull)
  uploadedById String
  uploadedBy  User             @relation("DocumentUploader", fields: [uploadedById], references: [id])
  version     Int              @default(1)
  tags        String[]
  folderId    String?
  folder      DocumentFolder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  deleted     Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([category])
  @@index([centreId])
  @@index([uploadedById])
  @@index([folderId])
}

model DocumentFolder {
  id        String           @id @default(cuid())
  name      String
  parentId  String?
  parent    DocumentFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  children  DocumentFolder[] @relation("FolderHierarchy")
  documents Document[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([parentId])
}

model Attachment {
  id          String   @id @default(cuid())
  fileName    String
  fileUrl     String
  fileSize    Int?
  mimeType    String?
  rockId      String?
  rock        Rock?    @relation(fields: [rockId], references: [id], onDelete: Cascade)
  issueId     String?
  issue       Issue?   @relation(fields: [issueId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy  User     @relation("AttachmentUploader", fields: [uploadedById], references: [id])
  createdAt   DateTime @default(now())

  @@index([rockId])
  @@index([issueId])
  @@index([projectId])
}

// ============================================================
// Financial & Performance Data
// ============================================================

enum FinancialPeriodType {
  weekly
  monthly
  quarterly
}

model FinancialPeriod {
  id            String              @id @default(cuid())
  serviceId     String
  service       Service             @relation("ServiceFinancials", fields: [serviceId], references: [id], onDelete: Cascade)
  periodType    FinancialPeriodType
  periodStart   DateTime
  periodEnd     DateTime
  
  // Revenue
  bscRevenue    Float               @default(0)
  ascRevenue    Float               @default(0)
  vcRevenue     Float               @default(0)
  otherRevenue  Float               @default(0)
  totalRevenue  Float               @default(0)
  
  // Costs
  staffCosts    Float               @default(0)
  foodCosts     Float               @default(0)
  suppliesCosts Float               @default(0)
  rentCosts     Float               @default(0)
  adminCosts    Float               @default(0)
  otherCosts    Float               @default(0)
  totalCosts    Float               @default(0)
  
  // Derived
  grossProfit   Float               @default(0)
  margin        Float               @default(0)

  // Budget
  budgetRevenue Float?
  budgetCosts   Float?

  // Attendance
  bscEnrolments Int                 @default(0)
  ascEnrolments Int                 @default(0)
  bscAttendance Int                 @default(0)
  ascAttendance Int                 @default(0)
  vcAttendance  Int                 @default(0)

  // Data source
  dataSource    String              @default("manual")
  xeroSyncedAt  DateTime?

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  
  @@unique([serviceId, periodType, periodStart])
  @@index([serviceId])
  @@index([periodStart])
  @@index([periodType])
}

model CentreMetrics {
  id              String   @id @default(cuid())
  serviceId       String
  service         Service  @relation("ServiceMetrics", fields: [serviceId], references: [id], onDelete: Cascade)
  recordedAt      DateTime @default(now())
  
  // Occupancy
  bscCapacity     Int      @default(0)
  ascCapacity     Int      @default(0)
  bscOccupancy    Float    @default(0)
  ascOccupancy    Float    @default(0)
  
  // Staff
  totalEducators  Int      @default(0)
  educatorsTurnover Float  @default(0)
  ratioCompliance Float    @default(100)
  
  // Quality
  parentNps       Float?
  incidentCount   Int      @default(0)
  complaintCount  Int      @default(0)
  
  // Compliance
  wwccCompliance  Float    @default(100)
  firstAidCompliance Float @default(100)
  overallCompliance Float  @default(100)
  nqsRating       String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([serviceId])
  @@index([recordedAt])
}

// ============================================================
// Support Ticket System (WhatsApp Integration)
// ============================================================

enum TicketStatus {
  new
  open
  pending_parent
  resolved
  closed
}

enum TicketPriority {
  urgent
  high
  normal
  low
}

enum MessageDirection {
  inbound
  outbound
}

enum MessageDeliveryStatus {
  sent
  delivered
  read
  failed
}

model WhatsAppContact {
  id          String   @id @default(cuid())
  waId        String   @unique
  phoneNumber String
  name        String?
  parentName  String?
  childName   String?
  serviceId   String?
  service     Service? @relation("ServiceContacts", fields: [serviceId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tickets SupportTicket[]

  @@index([waId])
  @@index([serviceId])
}

model SupportTicket {
  id             String         @id @default(cuid())
  ticketNumber   Int            @unique @default(autoincrement())
  contactId      String
  contact        WhatsAppContact @relation(fields: [contactId], references: [id])
  subject        String?
  status         TicketStatus   @default(new)
  priority       TicketPriority @default(normal)
  assignedToId   String?
  assignedTo     User?          @relation("TicketAssignee", fields: [assignedToId], references: [id])
  serviceId      String?
  service        Service?       @relation("ServiceTickets", fields: [serviceId], references: [id], onDelete: SetNull)
  firstResponseAt DateTime?
  resolvedAt     DateTime?
  closedAt       DateTime?
  lastInboundAt  DateTime?
  tags           String[]
  deleted        Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  messages TicketMessage[]

  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([contactId])
  @@index([serviceId])
  @@index([createdAt])
}

model TicketMessage {
  id              String                @id @default(cuid())
  ticketId        String
  ticket          SupportTicket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  waMessageId     String?               @unique
  direction       MessageDirection
  senderName      String?
  agentId         String?
  agent           User?                 @relation("MessageSender", fields: [agentId], references: [id])
  body            String                @db.Text
  mediaUrl        String?
  mediaType       String?
  deliveryStatus  MessageDeliveryStatus @default(sent)
  deliveredAt     DateTime?
  readAt          DateTime?
  createdAt       DateTime              @default(now())

  @@index([ticketId])
  @@index([waMessageId])
}

model ResponseTemplate {
  id        String   @id @default(cuid())
  title     String
  body      String   @db.Text
  category  String?
  shortcut  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// Internal Communication
// ============================================================

enum AnnouncementAudience {
  all
  owners_admins
  managers
  custom
}

enum AnnouncementPriority {
  normal
  important
  urgent
}

model Announcement {
  id          String               @id @default(cuid())
  title       String
  body        String               @db.Text
  authorId    String
  author      User                 @relation("AnnouncementAuthor", fields: [authorId], references: [id])
  audience    AnnouncementAudience @default(all)
  priority    AnnouncementPriority @default(normal)
  pinned      Boolean              @default(false)
  serviceId   String?
  service     Service?             @relation("ServiceAnnouncements", fields: [serviceId], references: [id], onDelete: SetNull)
  publishedAt DateTime?
  expiresAt   DateTime?
  deleted     Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  readReceipts AnnouncementRead[]

  @@index([audience])
  @@index([pinned])
  @@index([publishedAt])
  @@index([serviceId])
}

model AnnouncementRead {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("AnnouncementReader", fields: [userId], references: [id])
  readAt         DateTime     @default(now())

  @@unique([announcementId, userId])
  @@index([announcementId])
  @@index([userId])
}

model CascadeMessage {
  id          String   @id @default(cuid())
  meetingId   String
  meeting     Meeting  @relation("MeetingCascade", fields: [meetingId], references: [id], onDelete: Cascade)
  message     String   @db.Text
  publishedAt DateTime @default(now())
  deleted     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  acknowledgments CascadeAcknowledgment[]

  @@index([meetingId])
  @@index([publishedAt])
}

model CascadeAcknowledgment {
  id               String         @id @default(cuid())
  cascadeMessageId String
  cascadeMessage   CascadeMessage @relation(fields: [cascadeMessageId], references: [id], onDelete: Cascade)
  userId           String
  user             User           @relation("CascadeAcknowledger", fields: [userId], references: [id])
  acknowledgedAt   DateTime       @default(now())

  @@unique([cascadeMessageId, userId])
  @@index([cascadeMessageId])
  @@index([userId])
}

model WeeklyPulse {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation("PulseAuthor", fields: [userId], references: [id])
  weekOf     DateTime
  wins       String?  @db.Text
  priorities String?  @db.Text
  blockers   String?  @db.Text
  mood       Int?     // 1-5 scale
  notes      String?  @db.Text
  submittedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, weekOf])
  @@index([userId])
  @@index([weekOf])
}

model NotificationDismissal {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  notificationId String
  dismissedAt    DateTime @default(now())

  @@unique([userId, notificationId])
  @@index([userId])
}

model OrgSettings {
  id           String   @id @default("singleton")
  name         String   @default("Amana OSHC")
  primaryColor String   @default("#004E64")
  accentColor  String   @default("#FECE00")
  updatedAt    DateTime @updatedAt
}

// ============================================================
// Xero Integration
// ============================================================

enum XeroConnectionStatus {
  connected
  disconnected
  error
}

model XeroConnection {
  id                     String               @id @default("singleton")
  status                 XeroConnectionStatus @default(disconnected)
  tenantId               String?
  tenantName             String?
  accessToken            String?              @db.Text
  refreshToken           String?              @db.Text
  tokenExpiresAt         DateTime?
  scopes                 String?
  trackingCategoryId     String?
  lastSyncAt             DateTime?
  lastSyncStatus         String?
  lastSyncError          String?              @db.Text
  connectedById          String?
  syncedFinancialPeriods Int                  @default(0)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  accountMappings XeroAccountMapping[]
}

// ============================================================
// Health Score (Centre Health Score - Phase 2)
// ============================================================

model HealthScore {
  id              String   @id @default(cuid())
  serviceId       String
  service         Service  @relation("ServiceHealthScores", fields: [serviceId], references: [id], onDelete: Cascade)
  periodStart     DateTime
  periodType      String   @default("monthly")

  overallScore    Float
  trend           String   @default("stable") // improving | declining | stable

  financialScore      Float @default(0)
  operationalScore    Float @default(0)
  complianceScore     Float @default(0)
  satisfactionScore   Float @default(0)
  teamCultureScore    Float @default(0)

  financialBreakdown      Json?
  operationalBreakdown    Json?
  complianceBreakdown     Json?
  satisfactionBreakdown   Json?
  teamCultureBreakdown    Json?

  computedAt      DateTime @default(now())

  @@unique([serviceId, periodType, periodStart])
  @@index([serviceId])
  @@index([periodStart])
}

model XeroAccountMapping {
  id               String         @id @default(cuid())
  xeroConnectionId String
  xeroConnection   XeroConnection @relation(fields: [xeroConnectionId], references: [id], onDelete: Cascade)
  xeroAccountCode  String
  xeroAccountName  String
  xeroAccountType  String
  localCategory    String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([xeroConnectionId, xeroAccountCode])
  @@index([xeroConnectionId])
}

// ============================================================
// Staff Onboarding
// ============================================================

enum OnboardingStatus {
  not_started
  in_progress
  completed
}

model OnboardingPack {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  serviceId   String?
  service     Service? @relation("ServiceOnboardingPacks", fields: [serviceId], references: [id], onDelete: SetNull)
  isDefault   Boolean  @default(false)
  deleted     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks       OnboardingTask[]
  assignments StaffOnboarding[]

  @@index([serviceId])
}

model OnboardingTask {
  id          String          @id @default(cuid())
  packId      String
  pack        OnboardingPack  @relation(fields: [packId], references: [id], onDelete: Cascade)
  title       String
  description String?         @db.Text
  category    String?
  sortOrder   Int             @default(0)
  isRequired  Boolean         @default(true)
  documentId  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  progress StaffOnboardingProgress[]

  @@index([packId])
}

model StaffOnboarding {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation("OnboardingUser", fields: [userId], references: [id], onDelete: Cascade)
  packId       String
  pack         OnboardingPack    @relation(fields: [packId], references: [id], onDelete: Cascade)
  status       OnboardingStatus  @default(not_started)
  startedAt    DateTime?
  completedAt  DateTime?
  dueDate      DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  progress StaffOnboardingProgress[]

  @@unique([userId, packId])
  @@index([userId])
  @@index([packId])
  @@index([status])
}

model StaffOnboardingProgress {
  id             String          @id @default(cuid())
  onboardingId   String
  onboarding     StaffOnboarding @relation(fields: [onboardingId], references: [id], onDelete: Cascade)
  taskId         String
  task           OnboardingTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  completed      Boolean         @default(false)
  completedAt    DateTime?
  notes          String?         @db.Text
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([onboardingId, taskId])
  @@index([onboardingId])
  @@index([taskId])
}

// ============================================================
// LMS (Learning Management System)
// ============================================================

enum LMSCourseStatus {
  draft
  published
  archived
}

enum LMSModuleType {
  document
  video
  quiz
  checklist
  external_link
}

enum LMSEnrollmentStatus {
  enrolled
  in_progress
  completed
  expired
}

model LMSCourse {
  id          String          @id @default(cuid())
  title       String
  description String?         @db.Text
  category    String?
  thumbnail   String?
  status      LMSCourseStatus @default(draft)
  isRequired  Boolean         @default(false)
  serviceId   String?
  service     Service?        @relation("ServiceCourses", fields: [serviceId], references: [id], onDelete: SetNull)
  sortOrder   Int             @default(0)
  deleted     Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  modules     LMSModule[]
  enrollments LMSEnrollment[]

  @@index([status])
  @@index([serviceId])
}

model LMSModule {
  id          String        @id @default(cuid())
  courseId     String
  course      LMSCourse     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  description String?       @db.Text
  type        LMSModuleType @default(document)
  content     String?       @db.Text
  resourceUrl String?
  documentId  String?
  duration    Int?
  sortOrder   Int           @default(0)
  isRequired  Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  progress LMSModuleProgress[]

  @@index([courseId])
}

model LMSEnrollment {
  id           String              @id @default(cuid())
  userId       String
  user         User                @relation("LMSStudent", fields: [userId], references: [id], onDelete: Cascade)
  courseId      String
  course       LMSCourse           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  status       LMSEnrollmentStatus @default(enrolled)
  enrolledAt   DateTime            @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  dueDate      DateTime?
  score        Float?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  moduleProgress LMSModuleProgress[]

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
}

model LMSModuleProgress {
  id            String        @id @default(cuid())
  enrollmentId  String
  enrollment    LMSEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  moduleId      String
  module        LMSModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  completed     Boolean       @default(false)
  completedAt   DateTime?
  score         Float?
  timeSpent     Int?
  notes         String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([enrollmentId, moduleId])
  @@index([enrollmentId])
  @@index([moduleId])
}

// ============================================================
// Compliance Calendar
// ============================================================

enum CertificateType {
  wwcc
  first_aid
  anaphylaxis
  asthma
  cpr
  police_check
  annual_review
  other
}

model ComplianceCertificate {
  id          String          @id @default(cuid())
  serviceId   String
  service     Service         @relation("ServiceCertificates", fields: [serviceId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?           @relation("UserCertificates", fields: [userId], references: [id], onDelete: SetNull)
  type        CertificateType
  label       String?
  issueDate   DateTime
  expiryDate  DateTime
  notes       String?         @db.Text
  fileUrl     String?
  fileName    String?
  alertDays   Int             @default(30)
  acknowledged Boolean        @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([serviceId])
  @@index([userId])
  @@index([expiryDate])
}

// ── Attendance & Enrolment Tracking ─────────────────────────

model DailyAttendance {
  id            String      @id @default(cuid())
  serviceId     String
  service       Service     @relation("ServiceAttendance", fields: [serviceId], references: [id], onDelete: Cascade)
  date          DateTime    @db.Date
  sessionType   SessionType
  enrolled      Int         @default(0)
  attended      Int         @default(0)
  capacity      Int         @default(0)
  casual        Int         @default(0)
  absent        Int         @default(0)
  notes         String?     @db.Text
  recordedById  String?
  recordedBy    User?       @relation("AttendanceRecorder", fields: [recordedById], references: [id], onDelete: SetNull)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([serviceId, date, sessionType])
  @@index([serviceId])
  @@index([date])
}
