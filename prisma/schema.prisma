// ============================================================

enum MarketingPlatform {
  facebook
  instagram
  linkedin
  tiktok
  email
  newsletter
  website
  flyer
}

enum SocialConnectionStatus {
  connected
  disconnected
  expired
  error
}

enum MarketingPostStatus {
  draft
  in_review
  approved
  scheduled
  published
}

enum MarketingCampaignType {
  campaign
  event
  launch
  promotion
  awareness
  partnership
  activation
}

enum MarketingCampaignStatus {
  draft
  scheduled
  active
  completed
  paused
  cancelled
}

enum MarketingRecurrence {
  none
  weekly
  fortnightly
  monthly
}

enum MarketingKPIPeriod {
  weekly
  monthly
  quarterly
  yearly
}

enum MarketingAssetType {
  image
  video
  document
  template
  graphic
}

enum MarketingHashtagCategory {
  brand
  campaign
  platform
  trending
}

enum MarketingKPICategory {
  engagement
  growth
  content
  conversion
  retention
}

enum MarketingTaskStatus {
  todo
  in_progress
  in_review
  done
}

enum MarketingTaskPriority {
  high
  medium
  low
}

// ============================================================
// Employment Hero Replacement — HR Enums
// ============================================================

enum EmploymentType {
  casual
  part_time
  permanent
  fixed_term
}

enum VisaStatus {
  citizen
  permanent_resident
  work_visa
  student_visa
  bridging_visa
  other
}

enum QualificationType {
  cert_iii
  diploma
  bachelor
  masters
  first_aid
  wwcc
  other
}

enum PolicyStatus {
  draft
  published
  archived
}

enum ContractStatus {
  contract_draft
  active
  superseded
  terminated
}

enum ContractType {
  ct_casual
  ct_part_time
  ct_permanent
  ct_fixed_term
}

enum AwardLevel {
  es1
  es2
  es3
  es4
  cs1
  cs2
  cs3
  cs4
  director
  coordinator
  custom
}

enum LeaveType {
  annual
  sick
  personal
  unpaid
  long_service
  parental
  compassionate
}

enum LeaveRequestStatus {
  leave_pending
  leave_approved
  leave_rejected
  leave_cancelled
}

enum TimesheetStatus {
  ts_draft
  submitted
  approved
  exported_to_xero
  rejected
}

enum ShiftType {
  shift_bsc
  shift_asc
  shift_vac
  pd
  shift_admin
  shift_other
}

// ============================================================
// CRM
// ============================================================

enum LeadSource {
  tender
  direct
  build_alpha_kids
  referral
  community_connection
}

enum PipelineStage {
  new_lead
  reviewing
  contact_made
  follow_up_1
  follow_up_2
  meeting_booked
  proposal_sent
  submitted
  negotiating
  won
  lost
  on_hold
}

enum TouchpointType {
  email_sent
  call
  meeting
  note
  stage_change
  auto_email
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(member)
  avatar       String?
  active       Boolean  @default(true)
  serviceId    String?
  service      Service? @relation("ServiceStaff", fields: [serviceId], references: [id], onDelete: SetNull)
  state        String?  // Australian state for State Manager scoping (VIC, NSW, QLD, etc.)
  tokenVersion  Int      @default(0) // Bump to invalidate all existing sessions
  mfaSecret     String?  // Encrypted TOTP secret (null = MFA not enrolled)
  mfaBackupCodes String[] // Hashed one-time recovery codes
  mfaEnabledAt  DateTime? // Non-null = MFA is active
  createdAt     DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedRocks                    Rock[]                         @relation("RockOwner")
  assignedTodos                 Todo[]                         @relation("TodoAssignee")
  createdTodos                  Todo[]                         @relation("TodoCreator")
  raisedIssues                  Issue[]                        @relation("IssueRaiser")
  ownedIssues                   Issue[]                        @relation("IssueOwner")
  ownedMeasurables              Measurable[]                   @relation("MeasurableOwner")
  measurableEntries             MeasurableEntry[]              @relation("EntryCreator")
  activityLogs                  ActivityLog[]
  vtoUpdates                    VisionTractionOrganiser[]      @relation("VTOUpdater")
  managedServices               Service[]                      @relation("ServiceManager")
  ownedProjects                 Project[]                      @relation("ProjectOwner")
  createdMeetings               Meeting[]                      @relation("MeetingCreator")
  uploadedDocuments             Document[]                     @relation("DocumentUploader")
  uploadedAttachments           Attachment[]                   @relation("AttachmentUploader")
  assignedTickets               SupportTicket[]                @relation("TicketAssignee")
  sentMessages                  TicketMessage[]                @relation("MessageSender")
  dismissedNotifications        NotificationDismissal[]
  marketingPosts                MarketingPost[]                @relation("MarketingPostAssignee")
  approvedPosts                 MarketingPost[]                @relation("MarketingPostApprover")
  marketingComments             MarketingComment[]             @relation("MarketingCommentAuthor")
  marketingTasks                MarketingTask[]                @relation("MarketingTaskAssignee")
  announcements                 Announcement[]                 @relation("AnnouncementAuthor")
  announcementReads             AnnouncementRead[]             @relation("AnnouncementReader")
  cascadeAcks                   CascadeAcknowledgment[]        @relation("CascadeAcknowledger")
  weeklyPulses                  WeeklyPulse[]                  @relation("PulseAuthor")
  passwordResetTokens           PasswordResetToken[]
  calendarIntegration           CalendarIntegration?
  onboardings                   StaffOnboarding[]              @relation("OnboardingUser")
  lmsEnrollments                LMSEnrollment[]                @relation("LMSStudent")
  certificates                  ComplianceCertificate[]        @relation("UserCertificates")
  recordedAttendance            DailyAttendance[]              @relation("AttendanceRecorder")
  budgetItemsCreated            BudgetItem[]                   @relation("BudgetItemCreator")
  programActivitiesCreated      ProgramActivity[]              @relation("ProgramCreator")
  menuWeeksCreated              MenuWeek[]                     @relation("MenuCreator")
  activityTemplatesCreated      ActivityTemplate[]             @relation("ActivityTemplateCreator")
  activityTemplateFilesUploaded ActivityTemplateFile[]         @relation("ActivityTemplateFileUploader")
  seatAssignments               AccountabilitySeatAssignment[]
  todoTemplatesAssigned         TodoTemplate[]                 @relation("TemplateAssignee")
  todoTemplatesCreated          TodoTemplate[]                 @relation("TemplateCreator")

  // ── Staff Profile Expansion ──────────────────────────────────
  phone             String?
  dateOfBirth       DateTime?       @db.Date
  addressStreet     String?
  addressSuburb     String?
  addressState      String?
  addressPostcode   String?
  taxFileNumber     String?         @db.Text // AES-256-GCM encrypted
  superFundName     String?
  superMemberNumber String?
  superUSI          String?
  visaStatus        VisaStatus?
  visaExpiry        DateTime?       @db.Date
  employmentType    EmploymentType?
  startDate         DateTime?       @db.Date
  probationEndDate  DateTime?       @db.Date
  bankDetailsNote      String?
  bankAccountName      String?
  bankBSB              String?
  bankAccountNumber    String?
  xeroEmployeeId    String?

  // ── HR Relations ─────────────────────────────────────────────
  emergencyContacts EmergencyContact[]
  qualifications    StaffQualification[]
  contracts         EmploymentContract[]    @relation("ContractEmployee")
  leaveRequests     LeaveRequest[]          @relation("LeaveRequester")
  approvedLeaves    LeaveRequest[]          @relation("LeaveApprover")
  leaveBalances     LeaveBalance[]
  timesheetEntries  TimesheetEntry[]        @relation("TimesheetStaff")
  policyAcks        PolicyAcknowledgement[] @relation("PolicyAcknowledger")
  offboardings      StaffOffboarding[]      @relation("OffboardingUser")
  apiKeys           ApiKey[]                @relation("ApiKeyCreator")

  // ── CRM Relations ───────────────────────────────────────────
  assignedLeads           Lead[]                         @relation("LeadAssignee")
  touchpointsSent         TouchpointLog[]                @relation("TouchpointSender")
  activationCoordinations CampaignActivationAssignment[] @relation("ActivationCoordinator")

  // ── Compliance Audit Relations
  conductedAudits AuditInstance[] @relation("AuditAuditor")

  // ── Scenario Modelling
  scenarios Scenario[] @relation("ScenarioCreator")

  // ── Marketing Operations ──────────────────────────────
  schoolCommsSent       SchoolComm[]           @relation("SchoolCommSender")
  photoComplianceConfs  PhotoComplianceLog[]   @relation("PhotoComplianceConfirmer")
  termCalendarAssigned  TermCalendarEntry[]    @relation("TermCalendarAssignee")

  // ── Parent Enquiry Pipeline ──────────────────────────
  assignedEnquiries     ParentEnquiry[]        @relation("EnquiryAssignee")

  // ── Recruitment Pipeline ───────────────────────────
  filledVacancies       RecruitmentVacancy[]   @relation("VacancyFilledBy")
  assignedVacancies     RecruitmentVacancy[]   @relation("VacancyAssignee")
  candidateReferrals    RecruitmentCandidate[] @relation("CandidateReferrer")
  staffReferrals        StaffReferral[]        @relation("StaffReferrer")
  pulseSurveys          StaffPulseSurvey[]     @relation("UserPulseSurveys")

  // ── Meeting & Todo Multi-assign ────────────────────────
  meetingAttendance    MeetingAttendee[] @relation("UserMeetingAttendance")
  todoMultiAssignments TodoAssignee[]    @relation("TodoMultiAssignee")

  // ── Billing ───────────────────────────────────────────
  assignedOverdueFees  OverdueFeeRecord[] @relation("OverdueFeeAssignee")

  // ── Finance ───────────────────────────────────────────
  createdAdjustments   EBITDAAdjustment[] @relation("AdjustmentCreator")

  // ── Operations ────────────────────────────────────────
  reviewedQIPs         QualityImprovementPlan[] @relation("QIPReviewer")
  createdIncidents     IncidentRecord[]         @relation("IncidentCreator")

  // ── Programming & Quality ──────────────────────────
  capturedInterests    ChildInterest[]          @relation("InterestCaptures")

  // ── Onboarding & Preferences ──────────────────────
  gettingStartedProgress Json?   // Tracks completed checklist items per role
  notificationPrefs      Json?   // { overdueTodos: true, newAssignments: true, ... }
  systemBanners          SystemBannerDismissal[] @relation("BannerDismissals")
  internalFeedback       InternalFeedback[]      @relation("FeedbackAuthor")

  // ── Cowork Reports ──────────────────────────────
  assignedCoworkReports  CoworkReport[] @relation("CoworkReportAssignee")
  reviewedCoworkReports  CoworkReport[] @relation("CoworkReportReviewer")
  assignedCoworkTodos    CoworkTodo[]   @relation("CoworkTodoAssignee")

  // ── Daily Checklists ──────────────────────────────
  completedChecklists    DailyChecklist[]     @relation("ChecklistCompletedBy")
  checkedItems           DailyChecklistItem[] @relation("ChecklistItemCheckedBy")

  @@index([serviceId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model CalendarIntegration {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String   @default("microsoft") // "microsoft" | "google" (future)
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  scope        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model VisionTractionOrganiser {
  id                String   @id @default(cuid())
  coreValues        String[]
  corePurpose       String?
  coreNiche         String?
  tenYearTarget     String?  @db.Text
  threeYearPicture  String?  @db.Text
  marketingStrategy String?  @db.Text
  sectionLabels     Json? // Custom section titles e.g. { tenYearTarget: "5-Year Target" }
  updatedAt         DateTime @updatedAt
  updatedById       String?
  updatedBy         User?    @relation("VTOUpdater", fields: [updatedById], references: [id])

  oneYearGoals OneYearGoal[]
}

model OneYearGoal {
  id          String                  @id @default(cuid())
  title       String
  description String?                 @db.Text
  targetDate  DateTime?
  status      GoalStatus              @default(on_track)
  vtoId       String
  vto         VisionTractionOrganiser @relation(fields: [vtoId], references: [id], onDelete: Cascade)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  rocks Rock[]
}

model Rock {
  id              String       @id @default(cuid())
  title           String
  description     String?      @db.Text
  ownerId         String?
  owner           User?        @relation("RockOwner", fields: [ownerId], references: [id])
  quarter         String
  status          RockStatus   @default(on_track)
  percentComplete Int          @default(0)
  priority        RockPriority @default(medium)
  rockType        RockType     @default(personal)
  oneYearGoalId   String?
  oneYearGoal     OneYearGoal? @relation(fields: [oneYearGoalId], references: [id], onDelete: SetNull)
  serviceId       String?
  service         Service?     @relation("ServiceRocks", fields: [serviceId], references: [id], onDelete: SetNull)
  deleted         Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  todos       Todo[]
  issues      Issue[]
  milestones  Milestone[]
  measurables Measurable[]
  attachments Attachment[]

  @@index([quarter])
  @@index([ownerId])
  @@index([status])
  @@index([serviceId])
  @@index([quarter, serviceId])
  @@index([quarter, ownerId])
  @@index([quarter, status])
}

model Milestone {
  id        String   @id @default(cuid())
  title     String
  dueDate   DateTime
  completed Boolean  @default(false)
  rockId    String
  rock      Rock     @relation(fields: [rockId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Todo {
  id          String     @id @default(cuid())
  title       String
  description String?    @db.Text
  assigneeId  String?
  assignee    User?      @relation("TodoAssignee", fields: [assigneeId], references: [id])
  createdById String?
  createdBy   User?      @relation("TodoCreator", fields: [createdById], references: [id])
  rockId      String?
  rock        Rock?      @relation(fields: [rockId], references: [id], onDelete: SetNull)
  issueId     String?
  issue       Issue?     @relation(fields: [issueId], references: [id], onDelete: SetNull)
  serviceId   String?
  service     Service?   @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  projectId   String?
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  dueDate     DateTime
  status      TodoStatus @default(pending)
  weekOf      DateTime
  isPrivate   Boolean    @default(false)
  deleted     Boolean    @default(false)
  createdAt   DateTime   @default(now())
  completedAt DateTime?
  updatedAt   DateTime   @updatedAt

  assignees   TodoAssignee[] @relation("TodoAssignees")

  @@index([assigneeId])
  @@index([rockId])
  @@index([weekOf])
  @@index([status])
  @@index([serviceId])
  @@index([projectId])
  @@index([createdById])
  @@index([weekOf, serviceId])
  @@index([assigneeId, status])
  @@index([dueDate, status])
}

model TodoAssignee {
  id     String @id @default(cuid())
  todoId String
  todo   Todo   @relation("TodoAssignees", fields: [todoId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation("TodoMultiAssignee", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([todoId, userId])
  @@index([todoId])
  @@index([userId])
}

model Issue {
  id           String        @id @default(cuid())
  title        String
  description  String?       @db.Text
  raisedById   String?
  raisedBy     User?         @relation("IssueRaiser", fields: [raisedById], references: [id])
  ownerId      String?
  owner        User?         @relation("IssueOwner", fields: [ownerId], references: [id])
  rockId       String?
  rock         Rock?         @relation(fields: [rockId], references: [id], onDelete: SetNull)
  serviceId    String?
  service      Service?      @relation("ServiceIssues", fields: [serviceId], references: [id], onDelete: SetNull)
  priority     IssuePriority @default(medium)
  status       IssueStatus   @default(open)
  identifiedAt DateTime      @default(now())
  discussedAt  DateTime?
  solvedAt     DateTime?
  resolution   String?       @db.Text
  deleted      Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  spawnedTodos Todo[]
  attachments  Attachment[]

  @@index([priority])
  @@index([status])
  @@index([ownerId])
  @@index([serviceId])
  @@index([raisedById])
  @@index([status, serviceId])
  @@index([status, priority])
  @@index([ownerId, status])
}

model Scorecard {
  id        String   @id @default(cuid())
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  measurables Measurable[]
}

model Measurable {
  id            String              @id @default(cuid())
  title         String
  description   String?
  ownerId       String?
  owner         User?               @relation("MeasurableOwner", fields: [ownerId], references: [id])
  goalValue     Float
  goalDirection GoalDirection       @default(above)
  unit          String?
  frequency     MeasurableFrequency @default(weekly)
  rockId        String?
  rock          Rock?               @relation(fields: [rockId], references: [id], onDelete: SetNull)
  scorecardId   String
  scorecard     Scorecard           @relation(fields: [scorecardId], references: [id], onDelete: Cascade)
  serviceId     String?
  service       Service?            @relation("ServiceMeasurables", fields: [serviceId], references: [id], onDelete: SetNull)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  entries MeasurableEntry[]

  @@index([ownerId])
  @@index([scorecardId])
  @@index([serviceId])
}

model MeasurableEntry {
  id           String     @id @default(cuid())
  measurableId String
  measurable   Measurable @relation(fields: [measurableId], references: [id], onDelete: Cascade)
  weekOf       DateTime
  value        Float
  onTrack      Boolean
  notes        String?
  enteredById  String?
  enteredBy    User?      @relation("EntryCreator", fields: [enteredById], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([measurableId, weekOf])
  @@index([weekOf])
  @@index([enteredById])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String
  details    Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@index([userId, createdAt])
}

// ============================================================
// Cron Job Idempotency
// ============================================================

model CronRun {
  id          String    @id @default(cuid())
  cronName    String
  period      String // e.g. "2025-03-05" for daily, "2025-W10" for weekly
  details     Json?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  status      String    @default("running") // running | completed | failed

  @@unique([cronName, period])
  @@index([cronName])
  @@index([startedAt])
}

// ============================================================
// Board Reports
// ============================================================

enum BoardReportStatus {
  draft
  final
  sent
}

model BoardReport {
  id        String            @id @default(cuid())
  month     Int               // 1-12
  year      Int
  status    BoardReportStatus @default(draft)
  data      Json              // Full structured report data snapshot

  executiveSummary    String? @db.Text
  financialNarrative  String? @db.Text
  operationsNarrative String? @db.Text
  complianceNarrative String? @db.Text
  growthNarrative     String? @db.Text
  peopleNarrative     String? @db.Text
  rocksNarrative      String? @db.Text

  generatedAt DateTime  @default(now())
  finalizedAt DateTime?
  sentAt      DateTime?
  sentById    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month, year])
  @@index([year])
  @@index([status])
}

// ============================================================
// Email Events & Suppression
// ============================================================

model EmailEvent {
  id        String   @id @default(cuid())
  messageId String   // Resend message ID
  type      String   // delivered, bounced, complained, opened, clicked
  email     String   // recipient email
  payload   Json?    // full webhook payload
  createdAt DateTime @default(now())

  @@index([messageId])
  @@index([email, type])
  @@index([createdAt])
}

model EmailSuppression {
  id        String   @id @default(cuid())
  email     String   @unique
  reason    String   // bounce, complaint
  source    String?  // messageId that triggered it
  createdAt DateTime @default(now())

  @@index([email])
}

// ============================================================
// Marketing
// ============================================================

model MarketingCampaign {
  id           String                  @id @default(cuid())
  name         String
  type         MarketingCampaignType   @default(campaign)
  status       MarketingCampaignStatus @default(draft)
  startDate    DateTime?
  endDate      DateTime?
  platforms    MarketingPlatform[]
  goal         String?                 @db.Text
  notes        String?                 @db.Text
  designLink   String?
  budget       Float?
  location     String?
  deliverables String?                 @db.Text
  deleted      Boolean                 @default(false)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  posts                 MarketingPost[]
  comments              MarketingComment[]
  services              MarketingCampaignService[]
  tasks                 MarketingTask[]
  activationAssignments CampaignActivationAssignment[]
  termCalendarEntries   TermCalendarEntry[]            @relation("TermCalendarCampaign")

  @@index([status])
  @@index([startDate])
}

model MarketingPost {
  id                 String                 @id @default(cuid())
  title              String
  platform           MarketingPlatform
  status             MarketingPostStatus    @default(draft)
  scheduledDate      DateTime?
  content            String?                @db.Text
  notes              String?                @db.Text
  designLink         String?
  canvaDesignId      String?               // Canva design ID (e.g., "DAGoPem3X54")
  canvaDesignUrl     String?               // Direct edit URL in Canva
  canvaExportUrl     String?               // Exported image URL for publishing
  pillar             String?
  assigneeId         String?
  assignee           User?                  @relation("MarketingPostAssignee", fields: [assigneeId], references: [id])
  campaignId         String?
  campaign           MarketingCampaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  likes              Int                    @default(0)
  comments           Int                    @default(0)
  shares             Int                    @default(0)
  reach              Int                    @default(0)
  recurring          MarketingRecurrence    @default(none)
  recurringParentId  String?
  recurringParent    MarketingPost?         @relation("RecurringPosts", fields: [recurringParentId], references: [id])
  recurringChildren  MarketingPost[]        @relation("RecurringPosts")
  clonedFromId       String?
  clonedFrom         MarketingPost?         @relation("PostClones", fields: [clonedFromId], references: [id])
  clones             MarketingPost[]        @relation("PostClones")
  services           MarketingPostService[]
  externalPostId     String?
  externalUrl        String?
  engagementSyncedAt DateTime?
  approvedById       String?
  approvedBy         User?                  @relation("MarketingPostApprover", fields: [approvedById], references: [id])
  approvedAt         DateTime?
  rejectionReason    String?                @db.Text
  deleted            Boolean                @default(false)
