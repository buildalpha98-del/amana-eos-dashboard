// ============================================================
// Compliance Audit System
// ============================================================

enum AuditFrequency {
  monthly
  half_yearly
  yearly
}

enum AuditStatus {
  scheduled
  in_progress
  completed
  overdue
  skipped
}

enum AuditItemResult {
  yes
  no
  na
  not_answered
}

enum AuditResponseFormat {
  yes_no
  rating_1_5
  compliant
  reverse_yes_no
  review_date
  inventory
}

model AuditTemplate {
  id               String              @id @default(cuid())
  name             String              @unique
  description      String?             @db.Text
  qualityArea      Int
  nqsReference     String
  frequency        AuditFrequency
  scheduledMonths  Int[]
  responseFormat   AuditResponseFormat @default(yes_no)
  estimatedMinutes Int?
  sourceFileName   String?
  isActive         Boolean             @default(true)
  sortOrder        Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  items     AuditTemplateItem[]
  instances AuditInstance[]

  @@index([qualityArea])
  @@index([frequency])
}

model AuditTemplateItem {
  id             String               @id @default(cuid())
  templateId     String
  template       AuditTemplate        @relation(fields: [templateId], references: [id], onDelete: Cascade)
  section        String?
  question       String               @db.Text
  guidance       String?              @db.Text
  responseFormat AuditResponseFormat?
  sortOrder      Int                  @default(0)
  isRequired     Boolean              @default(true)
  createdAt      DateTime             @default(now())

  responses AuditItemResponse[]

  @@index([templateId])
  @@index([templateId, sortOrder])
}

model AuditInstance {
  id                  String        @id @default(cuid())
  templateId          String
  template            AuditTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  serviceId           String
  service             Service       @relation("ServiceAudits", fields: [serviceId], references: [id], onDelete: Cascade)
  scheduledMonth      Int
  scheduledYear       Int
  dueDate             DateTime
  status              AuditStatus   @default(scheduled)
  startedAt           DateTime?
  completedAt         DateTime?
  auditorId           String?
  auditor             User?         @relation("AuditAuditor", fields: [auditorId], references: [id], onDelete: SetNull)
  auditorName         String?
  totalItems          Int           @default(0)
  yesCount            Int           @default(0)
  noCount             Int           @default(0)
  naCount             Int           @default(0)
  complianceScore     Float?
  strengths           String?       @db.Text
  areasForImprovement String?       @db.Text
  actionPlan          String?       @db.Text
  comments            String?       @db.Text
  reviewedAt          DateTime?
  reviewedById        String?
  reviewNotes         String?       @db.Text
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  responses AuditItemResponse[]
  reviews   AuditReview[] @relation("AuditReviews")

  @@unique([templateId, serviceId, scheduledMonth, scheduledYear])
  @@index([serviceId])
  @@index([templateId])
  @@index([status])
  @@index([dueDate])
  @@index([serviceId, status])
}

model AuditItemResponse {
  id              String            @id @default(cuid())
  instanceId      String
  instance        AuditInstance     @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  templateItemId  String
  templateItem    AuditTemplateItem @relation(fields: [templateItemId], references: [id], onDelete: Cascade)
  result          AuditItemResult   @default(not_answered)
  ratingValue     Int?
  actionRequired  String?           @db.Text
  evidenceSighted String?           @db.Text
  notes           String?           @db.Text
  photoUrl        String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([instanceId, templateItemId])
  @@index([instanceId])
  @@index([result])
}

// ============================================================
// Parent Enquiry Pipeline (B2C)
// ============================================================

model ParentEnquiry {
  id              String   @id @default(cuid())
  serviceId       String
  service         Service  @relation(fields: [serviceId], references: [id])
  parentName      String
  parentEmail     String?
  parentPhone     String?
  childName       String?
  childAge        Int?
  childrenDetails Json?    // Array of {name, age} for multiple children
  channel         String   // phone, email, whatsapp, walkin, referral, website
  parentDriver    String?  // homework, quran, enrichment, working_parent, traffic, sports
  stage           String   @default("new_enquiry") // new_enquiry, info_sent, nurturing, form_started, enrolled, first_session, day3, week2, month1, retained, cold
  stageChangedAt  DateTime @default(now())
  nextActionDue   DateTime?
  ccsEducated     Boolean  @default(false)
  formStarted     Boolean  @default(false)
  formCompleted   Boolean  @default(false)
  firstSessionDate DateTime?
  referralId      String?
  referral        Referral? @relation(fields: [referralId], references: [id])
  assigneeId      String?
  assignee        User?    @relation("EnquiryAssignee", fields: [assigneeId], references: [id])
  notes           String?  @db.Text
  deleted         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  touchpoints     ParentEnquiryTouchpoint[]
  nurtureSteps    ParentNurtureStep[]

  @@index([serviceId])
  @@index([stage])
  @@index([assigneeId])
  @@index([nextActionDue])
  @@index([stageChangedAt])
  @@index([stage, createdAt])
  @@index([serviceId, stage])
}

model ParentEnquiryTouchpoint {
  id                String        @id @default(cuid())
  enquiryId         String
  enquiry           ParentEnquiry @relation(fields: [enquiryId], references: [id])
  type              String        // first_response, nudge_1, form_support, nudge_2, final_nudge, welcome, day1_checkin, day3_checkin, week2_feedback, month1_referral, retention_alert, custom
  channel           String        // email, whatsapp, phone, sms
  content           String?       @db.Text
  scheduledFor      DateTime?
  sentAt            DateTime?
  status            String        @default("draft") // draft, pending_review, approved, sent, failed
  generatedByCowork Boolean       @default(false)
  createdAt         DateTime      @default(now())

  @@index([enquiryId])
  @@index([status])
}

model Referral {
  id                String         @id @default(cuid())
  serviceId         String
  service           Service        @relation(fields: [serviceId], references: [id])
  referrerName      String
  referrerContactId String?
  referrerContact   CentreContact? @relation("ReferrerContact", fields: [referrerContactId], references: [id])
  referredName      String
  referredEmail     String?
  referredPhone     String?
  status            String         @default("pending") // pending, enquired, enrolled, rewarded, expired
  rewardAmount      Float          @default(50)
  rewardIssuedAt    DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  enquiries         ParentEnquiry[]

  @@index([serviceId])
  @@index([status])
}

// ============================================================
// Recruitment Pipeline
// ============================================================

model RecruitmentVacancy {
  id                    String              @id @default(cuid())
  serviceId             String
  service               Service             @relation("ServiceVacancies", fields: [serviceId], references: [id])
  role                  String              // educator, senior_educator, coordinator, director
  employmentType        EmploymentType
  qualificationRequired String?             // none, cert_iii, diploma
  status                String              @default("open") // open, interviewing, offered, filled, cancelled
  postedChannels        String[]
  postedAt              DateTime?
  targetFillDate        DateTime?
  filledAt              DateTime?
  filledByUserId        String?
  filledByUser          User?               @relation("VacancyFilledBy", fields: [filledByUserId], references: [id])
  assignedToId          String?
  assignedTo            User?               @relation("VacancyAssignee", fields: [assignedToId], references: [id])
  notes                 String?             @db.Text
  deleted               Boolean             @default(false)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  candidates            RecruitmentCandidate[]

  @@index([serviceId])
  @@index([status])
  @@index([assignedToId])
}

model RecruitmentCandidate {
  id              String              @id @default(cuid())
  vacancyId       String
  vacancy         RecruitmentVacancy  @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  name            String
  email           String?
  phone           String?
  source          String              // indeed, seek, referral, community, mosque, university, walkin
  stage           String              @default("applied") // applied, screened, interviewed, offered, accepted, rejected, withdrawn
  appliedAt       DateTime            @default(now())
  stageChangedAt  DateTime            @default(now())
  interviewNotes  String?             @db.Text
  referredByUserId String?
  referredByUser  User?               @relation("CandidateReferrer", fields: [referredByUserId], references: [id])
  notes           String?             @db.Text
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  staffReferral   StaffReferral?

  @@index([vacancyId])
  @@index([stage])
}

model StaffReferral {
  id              String              @id @default(cuid())
  referrerUserId  String
  referrerUser    User                @relation("StaffReferrer", fields: [referrerUserId], references: [id])
  referredName    String
  referredEmail   String?
  candidateId     String?             @unique
  candidate       RecruitmentCandidate? @relation(fields: [candidateId], references: [id])
  status          String              @default("pending") // pending, hired, bonus_paid, expired
  bonusAmount     Float               @default(200)
  bonusPaidAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([referrerUserId])
  @@index([status])
}

model StaffPulseSurvey {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("UserPulseSurveys", fields: [userId], references: [id])
  serviceId   String
  service     Service   @relation("ServicePulseSurveys", fields: [serviceId], references: [id])
  periodMonth String    // format: "2026-03"
  q1Happy     Int?      // 1-5
  q2Supported Int?      // 1-5
  q3Schedule  Int?      // 1-5
  q4Recommend Int?      // 1-5
  q5Feedback  String?   @db.Text
  submittedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([userId, periodMonth])
  @@index([serviceId])
  @@index([periodMonth])
}

// ═══════════════════════════════════════════════════════════
// OVERDUE FEES MANAGEMENT
// ═══════════════════════════════════════════════════════════

model OverdueFeeRecord {
  id                   String    @id @default(cuid())
  serviceId            String
  service              Service   @relation("ServiceOverdueFees", fields: [serviceId], references: [id])
  parentName           String
  parentEmail          String?
  parentPhone          String?
  childName            String?
  invoiceRef           String?
  invoiceDate          DateTime  @db.Date
  dueDate              DateTime  @db.Date
  amountDue            Float
  amountPaid           Float     @default(0)
  balance              Float
  daysOverdue          Int       @default(0)
  agingBucket          String    @default("current") // current/7d/14d/30d/45d/60plus
  reminderStatus       String    @default("none") // none/first_sent/second_sent/formal_sent/escalated/resolved
  firstReminderSentAt  DateTime?
  secondReminderSentAt DateTime?
  formalNoticeSentAt   DateTime?
  escalatedAt          DateTime?
  resolvedAt           DateTime?
  resolution           String? // paid/payment_plan/written_off/cancelled
  notes                String?   @db.Text
  assigneeId           String?
  assignee             User?     @relation("OverdueFeeAssignee", fields: [assigneeId], references: [id])
  deleted              Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([serviceId])
  @@index([agingBucket])
  @@index([reminderStatus])
  @@index([dueDate])
}

// ═══════════════════════════════════════════════════════════
// ADJUSTED EBITDA & ADD-BACK SCHEDULE
// ═══════════════════════════════════════════════════════════

model EBITDAAdjustment {
  id                    String   @id @default(cuid())
  periodMonth           String // format: "2026-03"
  category              String // personal_expense/one_off_cost/non_operating/system_migration/founder_above_market/other
  description           String
  amount                Float
  isRecurring           Boolean  @default(false)
  verifiedByAccountant  Boolean  @default(false)
  notes                 String?  @db.Text
  createdById           String?
  createdBy             User?    @relation("AdjustmentCreator", fields: [createdById], references: [id])
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([periodMonth])
}

// ═══════════════════════════════════════════════════════════
// CASH FLOW FORECAST
// ═══════════════════════════════════════════════════════════

model CashFlowPeriod {
  id                String   @id @default(cuid())
  periodMonth       String   @unique // format: "2026-03"
  openingBalance    Float
  parentFeeReceipts Float    @default(0)
  ccsReceipts       Float    @default(0)
  otherReceipts     Float    @default(0)
  totalReceipts     Float    @default(0)
  payrollPayments   Float    @default(0)
  supplierPayments  Float    @default(0)
  rentPayments      Float    @default(0)
  overheadPayments  Float    @default(0)
  debtRepayments    Float    @default(0) // Amex etc
  investmentOutflows Float   @default(0) // new centre setup
  totalPayments     Float    @default(0)
  netMovement       Float    @default(0)
  closingBalance    Float    @default(0)
  isActual          Boolean  @default(false) // false = forecast, true = actual
  notes             String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════
// QIP / SAT DOCUMENT MANAGEMENT
// ═══════════════════════════════════════════════════════════

model QualityImprovementPlan {
  id              String   @id @default(cuid())
  serviceId       String   @unique
  service         Service  @relation("ServiceQIP", fields: [serviceId], references: [id])
  state           String
  documentType    String   @default("qip") // qip | sat
  status          String   @default("draft") // draft | in_review | current | archived
  lastReviewDate  DateTime?
  reviewedById    String?
  reviewedBy      User?    @relation("QIPReviewer", fields: [reviewedById], references: [id])
  qualityAreas    QIPQualityArea[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model QIPQualityArea {
  id                  String   @id @default(cuid())
  qipId               String
  qip                 QualityImprovementPlan @relation(fields: [qipId], references: [id], onDelete: Cascade)
  qualityArea         Int // 1-7
  qualityAreaName     String
  strengths           String?  @db.Text
  areasForImprovement String?  @db.Text
  improvementGoal     String?  @db.Text
  strategies          String?  @db.Text
  timeline            String?
  responsiblePerson   String?
  evidenceIndicators  String?  @db.Text
  evidenceCollected   String?  @db.Text
  progressNotes       String?  @db.Text
  progressStatus      String   @default("not_started") // not_started | in_progress | achieved | ongoing
  updatedAt           DateTime @updatedAt

  @@unique([qipId, qualityArea])
}

// ═══════════════════════════════════════════════════════════
// INCIDENT TRACKING & TREND ANALYSIS
// ═══════════════════════════════════════════════════════════

model IncidentRecord {
  id                     String    @id @default(cuid())
  serviceId              String
  service                Service   @relation("ServiceIncidents", fields: [serviceId], references: [id])
  incidentDate           DateTime
  childName              String?
  incidentType           String // injury | illness | behaviour | missing_child | near_miss | medication_error | property_damage | complaint
  severity               String // minor | moderate | reportable | serious
  location               String? // indoor | outdoor | playground | transition | bathroom | kitchen
  timeOfDay              String? // arrival | programme | meal_time | packdown | departure
  description            String   @db.Text
  actionTaken            String?  @db.Text
  parentNotified         Boolean  @default(false)
  reportableToAuthority  Boolean  @default(false)
  reportedToAuthorityAt  DateTime?
  followUpRequired       Boolean  @default(false)
  followUpCompleted      Boolean  @default(false)
  ownaIncidentId         String?
  createdById            String?
  createdBy              User?    @relation("IncidentCreator", fields: [createdById], references: [id])
  deleted                Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([serviceId])
  @@index([incidentDate])
  @@index([incidentType])
  @@index([severity])
}

// ============================================================
// Children's Interest Capture (NQS QA1)
// ============================================================

model ChildInterest {
  id                String    @id @default(cuid())
  serviceId         String
  service           Service   @relation("ServiceInterests", fields: [serviceId], references: [id], onDelete: Cascade)
  capturedDate      DateTime  @default(now())
  childName         String?   // optional — can be group-level
  interestTopic     String
  interestCategory  String?   // sport/animals/science/art/cooking/technology/nature/social/cultural/religious/other
  source            String    // interest_book/verbal/observation/parent/suggestion_box
  capturedById      String?
  capturedBy        User?     @relation("InterestCaptures", fields: [capturedById], references: [id], onDelete: SetNull)
  linkedToActivityId String?
  linkedToActivity  ProgramActivity? @relation("InterestToActivity", fields: [linkedToActivityId], references: [id], onDelete: SetNull)
  actioned          Boolean   @default(false)
  actionedDate      DateTime?
  notes             String?   @db.Text
  createdAt         DateTime  @default(now())

  @@index([serviceId, actioned])
  @@index([serviceId, capturedDate])
}

// ============================================================
// Audit Reviews (NQS Quality Area Evidence Packs)
// ============================================================

model AuditReview {
  id             String   @id @default(cuid())
  auditInstanceId String?
  auditInstance  AuditInstance? @relation("AuditReviews", fields: [auditInstanceId], references: [id], onDelete: SetNull)
  centreId       String
  qualityArea    Int      // 1-7 (NQS QA1–QA7)
  elements       Json     // Array of { element: string, rating: string, evidence: string }
  overallRating  String   // "exceeding" | "meeting" | "working_towards" | "not_met"
  reviewerNotes  String?  @db.Text
  reviewedAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([centreId])
  @@index([qualityArea])
  @@index([centreId, qualityArea])
}

// ============================================================
// Educator Reflections
// ============================================================

enum ReflectionType {
  daily_reflection
  friday_review
  child_observation
  iqra_feedback
}

model EducatorReflection {
  id             String          @id @default(cuid())
  centreId       String
  educatorName   String
  reflectionType ReflectionType
  date           DateTime        @db.Date
  content        Json            // Flexible structure per type
  tags           String[]
  linkedActivityId String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([centreId])
  @@index([reflectionType])
  @@index([centreId, date])
  @@index([date])
}

// ---------------------------------------------------------------------------
// Security Audit Log — tracks sensitive actions for compliance
// ---------------------------------------------------------------------------

model SecurityAuditLog {
  id        String   @id @default(cuid())
  action    String   // e.g. "user.login", "user.password_reset", "user.role_change"
  actorId   String?  // null for system/cron actions
  actorEmail String?
  targetId  String?  // affected resource ID
  targetType String? // e.g. "User", "ApiKey", "Service"
  metadata  Json?    // extra context (IP, old/new values, etc.)
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([action])
  @@index([actorId])
  @@index([targetId])
  @@index([createdAt])
}

// ============================================================
// System Banners (What's New / Announcements from HO)
// ============================================================

model SystemBanner {
  id          String    @id @default(cuid())
  title       String
  body        String    @db.Text
  type        String    @default("info") // info, success, warning, feature
  linkUrl     String?
  linkLabel   String?
  active      Boolean   @default(true)
  createdById String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  dismissals SystemBannerDismissal[]

  @@index([active])
  @@index([createdAt])
}

model SystemBannerDismissal {
  id        String       @id @default(cuid())
  bannerId  String
  banner    SystemBanner @relation(fields: [bannerId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation("BannerDismissals", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([bannerId, userId])
  @@index([userId])
}

// ============================================================
// Internal Feedback (Quick Feedback Widget → Head Office)
// ============================================================

model InternalFeedback {
  id          String   @id @default(cuid())
  authorId    String
  author      User     @relation("FeedbackAuthor", fields: [authorId], references: [id])
  category    String   // bug, feature_request, question, general
  message     String   @db.Text
  screenshotUrl String?
  page        String?  // URL path where feedback was submitted
  status      String   @default("new") // new, acknowledged, in_progress, resolved
  resolvedAt  DateTime?
  adminNotes  String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([authorId])
  @@index([status])
  @@index([category])
  @@index([createdAt])
}

// ============================================================
// Knowledge Base (FAQ articles)
// ============================================================

model KnowledgeBaseArticle {
  id          String   @id @default(cuid())
  title       String
  body        String   @db.Text
  category    String   // getting_started, eos_basics, hr, compliance, troubleshooting
  slug        String   @unique
  sortOrder   Int      @default(0)
  published   Boolean  @default(true)
  audienceRoles String[] // empty = all roles
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([published])
}

// ============================================================
// Cowork Reports (AI-generated seat reports)
// ============================================================

model CoworkReport {
  id           String   @id @default(cuid())
  seat         String   // "marketing", "people", "operations", "finance", "programming", "parent-experience", "partnerships"
  reportType   String   // e.g., "weekly-people-summary", "occupancy-enrolment-report"
  title        String
  content      String   @db.Text
  metrics      Json?    // optional structured metrics
  alerts       Json?    // optional alert flags
  serviceCode  String?  // centre code if centre-specific
  serviceId    String?
  service      Service? @relation("CoworkReportService", fields: [serviceId], references: [id], onDelete: SetNull)
  assignedToId String?
  assignedTo   User?    @relation("CoworkReportAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  status       String   @default("pending") // "pending", "reviewed", "actioned"
  reviewedAt   DateTime?
  reviewedById String?
  reviewedBy   User?    @relation("CoworkReportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  checklist    Json?    // { "action-0": true, "action-1": false }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([seat])
  @@index([reportType])
  @@index([assignedToId])
  @@index([serviceCode])
  @@index([status])
  @@index([createdAt])
  @@index([seat, assignedToId])
}

// ============================================================
// Daily Checklists (auto-populated by automation)
// ============================================================

model DailyChecklist {
  id            String               @id @default(cuid())
  serviceId     String
  service       Service              @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  date          DateTime             @db.Date
  sessionType   SessionType          @default(asc)
  status        String               @default("pending") // pending | in_progress | completed
  completedAt   DateTime?
  completedById String?
  completedBy   User?                @relation("ChecklistCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  notes         String?              @db.Text
  items         DailyChecklistItem[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@unique([serviceId, date, sessionType])
  @@index([serviceId])
  @@index([date])
  @@index([status])
}

model DailyChecklistItem {
  id          String         @id @default(cuid())
  checklistId String
  checklist   DailyChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  category    String         // "opening", "safety", "programming", "closing", "compliance"
  label       String
  sortOrder   Int            @default(0)
  isRequired  Boolean        @default(true)
  checked     Boolean        @default(false)
  checkedAt   DateTime?
  checkedById String?
  checkedBy   User?          @relation("ChecklistItemCheckedBy", fields: [checkedById], references: [id], onDelete: SetNull)
  notes       String?        @db.Text
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([checklistId])
}
