  @@index([serviceId])
}

model OffboardingTask {
  id          String          @id @default(cuid())
  packId      String
  pack        OffboardingPack @relation(fields: [packId], references: [id], onDelete: Cascade)
  title       String
  description String?         @db.Text
  category    String?
  sortOrder   Int             @default(0)
  isRequired  Boolean         @default(true)
