// ============================================================

model AccountabilitySeat {
  id               String   @id @default(cuid())
  title            String                          // "Visionary", "Marketing", "BAK Team Leader"
  responsibilities String[]                        // PostgreSQL native text array
  parentId         String?
  parent           AccountabilitySeat?  @relation("SeatHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children         AccountabilitySeat[] @relation("SeatHierarchy")
  order            Int      @default(0)            // Sort order among siblings
  assignees        AccountabilitySeatAssignment[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([parentId])
}

model AccountabilitySeatAssignment {
  id     String @id @default(cuid())
  seatId String
  seat   AccountabilitySeat @relation(fields: [seatId], references: [id], onDelete: Cascade)
  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([seatId, userId])
  @@index([userId])
}

// ============================================================
// Marketing Multi-Centre Scoping
// ============================================================

model MarketingPostService {
  id        String        @id @default(cuid())
  postId    String
  post      MarketingPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service       @relation("ServiceMarketingPosts", fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([postId, serviceId])
  @@index([postId])
  @@index([serviceId])
}

model MarketingCampaignService {
  id         String            @id @default(cuid())
  campaignId String
  campaign   MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  serviceId  String
  service    Service           @relation("ServiceMarketingCampaigns", fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt  DateTime          @default(now())

  @@unique([campaignId, serviceId])
  @@index([campaignId])
  @@index([serviceId])
}

// ============================================================
// Social Media Connections (Facebook + Instagram via Meta)
// ============================================================

model SocialConnection {
  id              String                  @id @default(cuid())
  platform        MarketingPlatform
  status          SocialConnectionStatus  @default(disconnected)
  accountId       String?
  accountName     String?
  accessToken     String?                 @db.Text
  refreshToken    String?                 @db.Text
  tokenExpiresAt  DateTime?
  pageAccessToken String?                 @db.Text
  scopes          String?
  lastSyncAt      DateTime?
  lastSyncStatus  String?
  lastSyncError   String?                 @db.Text
  serviceId       String?
  service         Service?                @relation("ServiceSocialConnections", fields: [serviceId], references: [id])
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@unique([platform, accountId])
  @@index([platform])
  @@index([serviceId])
}

// ============================================================
// Phase 1: Staff Profile — Emergency Contacts & Qualifications
// ============================================================

model EmergencyContact {
  id           String  @id @default(cuid())
  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  phone        String
  relationship String
  isPrimary    Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model StaffQualification {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            QualificationType
  name            String
  institution     String?
  completedDate   DateTime?         @db.Date
  expiryDate      DateTime?         @db.Date
  certificateUrl  String?
  verified        Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId])
  @@index([type])
}

// ============================================================
// Phase 2: Policy Acknowledgement
// ============================================================

model Policy {
  id            String       @id @default(cuid())
  title         String
  description   String?      @db.Text
  version       Int          @default(1)
  status        PolicyStatus @default(draft)
  category      String?
  documentUrl   String?
  documentId    String?
  publishedAt   DateTime?
  requiresReack Boolean      @default(true)
  deleted       Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  acknowledgements PolicyAcknowledgement[]

  @@index([status])
  @@index([category])
}

model PolicyAcknowledgement {
  id             String   @id @default(cuid())
  policyId       String
  policy         Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation("PolicyAcknowledger", fields: [userId], references: [id], onDelete: Cascade)
  policyVersion  Int
  acknowledgedAt DateTime @default(now())
  createdAt      DateTime @default(now())

  @@unique([policyId, userId, policyVersion])
  @@index([policyId])
  @@index([userId])
}

// ============================================================
// Phase 3: Contract Management
// ============================================================

model EmploymentContract {
  id                  String         @id @default(cuid())
  userId              String
  user                User           @relation("ContractEmployee", fields: [userId], references: [id], onDelete: Cascade)
  contractType        ContractType
  awardLevel          AwardLevel?
  awardLevelCustom    String?
  payRate             Float
  hoursPerWeek        Float?
  startDate           DateTime       @db.Date
  endDate             DateTime?      @db.Date
  status              ContractStatus @default(contract_draft)
  documentUrl         String?
  documentId          String?
  signedAt            DateTime?
  acknowledgedByStaff Boolean        @default(false)
  acknowledgedAt      DateTime?
  notes               String?        @db.Text
  previousContractId  String?
  previousContract    EmploymentContract?  @relation("ContractHistory", fields: [previousContractId], references: [id])
  supersededBy        EmploymentContract[] @relation("ContractHistory")
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([userId])
  @@index([status])
  @@index([contractType])
}

// ============================================================
// Phase 4: Leave Management
// ============================================================

model LeaveRequest {
  id            String             @id @default(cuid())
  userId        String
  user          User               @relation("LeaveRequester", fields: [userId], references: [id], onDelete: Cascade)
  leaveType     LeaveType
  startDate     DateTime           @db.Date
  endDate       DateTime           @db.Date
  totalDays     Float
  isHalfDay     Boolean            @default(false)
  reason        String?            @db.Text
  status        LeaveRequestStatus @default(leave_pending)
  reviewedById  String?
  reviewedBy    User?              @relation("LeaveApprover", fields: [reviewedById], references: [id])
  reviewedAt    DateTime?
  reviewNotes   String?            @db.Text
  serviceId     String?
  service       Service?           @relation("ServiceLeaveRequests", fields: [serviceId], references: [id], onDelete: SetNull)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([userId])
  @@index([status])
  @@index([startDate])
  @@index([serviceId])
  @@index([leaveType])
  @@index([reviewedById])
}

model LeaveBalance {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType       LeaveType
  balance         Float     @default(0)
  accrued         Float     @default(0)
  taken           Float     @default(0)
  pending         Float     @default(0)
  asOfDate        DateTime  @default(now())
  source          String    @default("manual")
  xeroSyncedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, leaveType])
  @@index([userId])
}

// ============================================================
// Phase 5: Timesheet Import from OWNA
// ============================================================

model Timesheet {
  id             String          @id @default(cuid())
  serviceId      String
  service        Service         @relation("ServiceTimesheets", fields: [serviceId], references: [id], onDelete: Cascade)
  weekEnding     DateTime        @db.Date
  status         TimesheetStatus @default(ts_draft)
  submittedAt    DateTime?
  submittedById  String?
  approvedAt     DateTime?
  approvedById   String?
  exportedAt     DateTime?
  xeroPayRunId   String?
  importSource   String?         @default("manual")
  importFileName String?
  notes          String?         @db.Text
  deleted        Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  entries TimesheetEntry[]

  @@unique([serviceId, weekEnding])
  @@index([serviceId])
  @@index([status])
  @@index([weekEnding])
}

model TimesheetEntry {
  id            String     @id @default(cuid())
  timesheetId   String
  timesheet     Timesheet  @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  userId        String
  user          User       @relation("TimesheetStaff", fields: [userId], references: [id])
  date          DateTime   @db.Date
  shiftStart    DateTime
  shiftEnd      DateTime
  breakMinutes  Int        @default(0)
  totalHours    Float
  shiftType     ShiftType
  notes         String?
  isOvertime    Boolean    @default(false)
  payRate       Float?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([timesheetId])
  @@index([userId])
  @@index([date])
}

// ============================================================
// Phase 6: Offboarding Workflow
// ============================================================

model OffboardingPack {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  serviceId   String?
  service     Service? @relation("ServiceOffboardingPacks", fields: [serviceId], references: [id], onDelete: SetNull)
  isDefault   Boolean  @default(false)
  deleted     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks       OffboardingTask[]
  assignments StaffOffboarding[]

  @@index([serviceId])
}

model OffboardingTask {
  id          String           @id @default(cuid())
  packId      String
  pack        OffboardingPack  @relation(fields: [packId], references: [id], onDelete: Cascade)
  title       String
  description String?          @db.Text
  category    String?
  sortOrder   Int              @default(0)
  isRequired  Boolean          @default(true)
  assignedTo  String?
  documentId  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  progress StaffOffboardingProgress[]

  @@index([packId])
}

model StaffOffboarding {
  id                   String            @id @default(cuid())
  userId               String
  user                 User              @relation("OffboardingUser", fields: [userId], references: [id], onDelete: Cascade)
  packId               String
  pack                 OffboardingPack   @relation(fields: [packId], references: [id], onDelete: Cascade)
  status               OnboardingStatus  @default(not_started)
  initiatedById        String?
  lastDay              DateTime?         @db.Date
  reason               String?
  exitInterviewNotes   String?           @db.Text
  startedAt            DateTime?
  completedAt          DateTime?
  deactivateOnComplete Boolean           @default(true)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  progress StaffOffboardingProgress[]

  @@unique([userId, packId])
  @@index([userId])
  @@index([packId])
  @@index([status])
}

model StaffOffboardingProgress {
  id               String            @id @default(cuid())
  offboardingId    String
  offboarding      StaffOffboarding  @relation(fields: [offboardingId], references: [id], onDelete: Cascade)
  taskId           String
  task             OffboardingTask   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  completed        Boolean           @default(false)
  completedAt      DateTime?
  completedById    String?
  notes            String?           @db.Text
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([offboardingId, taskId])
  @@index([offboardingId])
  @@index([taskId])
}

// ---------------------------------------------------------------------------
// API Key Management — database-backed API keys for external integrations
// ---------------------------------------------------------------------------

model ApiKey {
  id          String    @id @default(cuid())
  name        String                          // human label, e.g. "Cowork Production"
  keyPrefix   String                          // first 8 hex chars for display
  keyHash     String    @unique               // SHA-256 hex of the full key
  scopes      String[]                        // ["programs:write", "menus:write", "announcements:write"]
  expiresAt   DateTime?                       // null = never expires
  revokedAt   DateTime?                       // non-null = revoked
  lastUsedAt  DateTime?
  createdById String
  createdBy   User      @relation("ApiKeyCreator", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([keyHash])
  @@index([createdById])
}

// ---------------------------------------------------------------------------
// Cowork API Integration — external automation pushes content into dashboard
// ---------------------------------------------------------------------------

model CoworkProgram {
  id              String   @id @default(cuid())
  weekCommencing  DateTime @unique
  theme           String
  category        String?
  summary         String?  @db.Text
  programFileUrl  String?
  resourceFileUrl String?
  displayFileUrl  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CoworkTodo {
  id           String    @id @default(cuid())
  centreId     String
  date         DateTime
  title        String
  description  String?   @db.Text
  category     String    // "morning-prep", "afternoon-prep", "end-of-day"
  dueTime      String?   // "06:00", "15:00", etc.
  assignedRole String?   // "educator", "coordinator"
  completed    Boolean   @default(false)
  completedAt  DateTime?
  completedBy  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([centreId, date])
}

model CoworkAnnouncement {
  id            String   @id @default(cuid())
  title         String
  body          String   @db.Text
  type          String   // "program-update", "newsletter-summary", "general", "holiday-quest", "reminder"
  targetCentres String[] // ["all"] or specific centre IDs
  attachments   String[] // file URLs
  pinned        Boolean  @default(false)
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CalendarEvent {
  id        String    @id @default(cuid())
  title     String
  date      DateTime
  endDate   DateTime?
  centreId  String?   // null = all centres
  type      String    // "excursion", "incursion", "public-holiday", etc.
  details   String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([centreId, date])
}
