generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  owner
  admin
  member
  staff
}

enum RockStatus {
  on_track
  off_track
  complete
  dropped
}

enum RockPriority {
  critical
  high
  medium
}

enum RockType {
  company
  personal
}

enum TodoStatus {
  pending
  in_progress
  complete
  cancelled
}

enum IssuePriority {
  critical
  high
  medium
  low
}

enum IssueStatus {
  open
  in_discussion
  solved
  closed
}

enum GoalStatus {
  on_track
  at_risk
  off_track
  complete
}

enum GoalDirection {
  above
  below
  exact
}

enum MeasurableFrequency {
  weekly
  monthly
}

enum ServiceStatus {
  active
  onboarding
  pipeline
  closing
  closed
}

enum SessionType {
  bsc
  asc
  vc
}

enum WeekDay {
  monday
  tuesday
  wednesday
  thursday
  friday
}

enum MealSlot {
  morning_tea
  lunch
  afternoon_tea
}

enum ActivityCategory {
  physical_play
  creative_arts
  music_movement
  literacy
  numeracy
  nature_outdoors
  cooking_nutrition
  social_emotional
  quiet_time
  free_play
  other
}

enum BudgetItemCategory {
  kitchen
  sports
  art_craft
  furniture
  technology
  cleaning
  safety
  other
}

enum ProjectStatus {
  not_started
  in_progress
  complete
  on_hold
  cancelled
}

enum MeetingStatus {
  scheduled
  in_progress
  completed
  cancelled
}

// ============================================================
// Marketing
// ============================================================

enum MarketingPlatform {
  facebook
  instagram
  linkedin
  email
  newsletter
  website
  flyer
}

enum SocialConnectionStatus {
  connected
  disconnected
  expired
  error
}

enum MarketingPostStatus {
  draft
  in_review
  approved
  scheduled
  published
}

enum MarketingCampaignType {
  campaign
  event
  launch
  promotion
  awareness
  partnership
}

enum MarketingCampaignStatus {
  draft
  scheduled
  active
  completed
  paused
  cancelled
}

enum MarketingRecurrence {
  none
  weekly
  fortnightly
  monthly
}

enum MarketingKPIPeriod {
  monthly
  quarterly
  yearly
}

enum MarketingAssetType {
  image
  video
  document
  template
  graphic
}

enum MarketingHashtagCategory {
  brand
  campaign
  platform
  trending
}

enum MarketingKPICategory {
  engagement
  growth
  content
  conversion
}

// ============================================================
// Employment Hero Replacement — HR Enums
// ============================================================

enum EmploymentType {
  casual
  part_time
  permanent
  fixed_term
}

enum VisaStatus {
  citizen
  permanent_resident
  work_visa
  student_visa
  bridging_visa
  other
}

enum QualificationType {
  cert_iii
  diploma
  bachelor
  masters
  first_aid
  wwcc
  other
}

enum PolicyStatus {
  draft
  published
  archived
}

enum ContractStatus {
  contract_draft
  active
  superseded
  terminated
}

enum ContractType {
  ct_casual
  ct_part_time
  ct_permanent
  ct_fixed_term
}

enum AwardLevel {
  es1
  es2
  es3
  es4
  cs1
  cs2
  cs3
  cs4
  director
  coordinator
  custom
}

enum LeaveType {
  annual
  sick
  personal
  unpaid
  long_service
  parental
  compassionate
}

enum LeaveRequestStatus {
  leave_pending
  leave_approved
  leave_rejected
  leave_cancelled
}

enum TimesheetStatus {
  ts_draft
  submitted
  approved
  exported_to_xero
  rejected
}

enum ShiftType {
  shift_bsc
  shift_asc
  shift_vac
  pd
  shift_admin
  shift_other
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(member)
  avatar       String?
  active       Boolean  @default(true)
  serviceId    String?
  service      Service? @relation("ServiceStaff", fields: [serviceId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedRocks        Rock[]            @relation("RockOwner")
  assignedTodos     Todo[]            @relation("TodoAssignee")
  createdTodos      Todo[]            @relation("TodoCreator")
  raisedIssues      Issue[]           @relation("IssueRaiser")
  ownedIssues       Issue[]           @relation("IssueOwner")
  ownedMeasurables  Measurable[]      @relation("MeasurableOwner")
  measurableEntries MeasurableEntry[] @relation("EntryCreator")
  activityLogs      ActivityLog[]
  vtoUpdates        VisionTractionOrganiser[] @relation("VTOUpdater")
  managedServices   Service[]         @relation("ServiceManager")
  ownedProjects     Project[]         @relation("ProjectOwner")
  createdMeetings   Meeting[]         @relation("MeetingCreator")
  uploadedDocuments Document[]        @relation("DocumentUploader")
  uploadedAttachments Attachment[]    @relation("AttachmentUploader")
  assignedTickets   SupportTicket[]   @relation("TicketAssignee")
  sentMessages      TicketMessage[]   @relation("MessageSender")
  dismissedNotifications NotificationDismissal[]
  marketingPosts    MarketingPost[]   @relation("MarketingPostAssignee")
  marketingComments MarketingComment[] @relation("MarketingCommentAuthor")
  announcements     Announcement[]    @relation("AnnouncementAuthor")
  announcementReads AnnouncementRead[] @relation("AnnouncementReader")
  cascadeAcks       CascadeAcknowledgment[] @relation("CascadeAcknowledger")
  weeklyPulses      WeeklyPulse[]     @relation("PulseAuthor")
  passwordResetTokens PasswordResetToken[]
  calendarIntegration CalendarIntegration?
  onboardings       StaffOnboarding[] @relation("OnboardingUser")
  lmsEnrollments    LMSEnrollment[]   @relation("LMSStudent")
  certificates      ComplianceCertificate[] @relation("UserCertificates")
  recordedAttendance DailyAttendance[]     @relation("AttendanceRecorder")
  budgetItemsCreated BudgetItem[]          @relation("BudgetItemCreator")
  programActivitiesCreated ProgramActivity[] @relation("ProgramCreator")
  menuWeeksCreated  MenuWeek[]             @relation("MenuCreator")
  activityTemplatesCreated ActivityTemplate[] @relation("ActivityTemplateCreator")
  activityTemplateFilesUploaded ActivityTemplateFile[] @relation("ActivityTemplateFileUploader")
  seatAssignments    AccountabilitySeatAssignment[]
  todoTemplatesAssigned TodoTemplate[]  @relation("TemplateAssignee")
  todoTemplatesCreated  TodoTemplate[]  @relation("TemplateCreator")

  // ── Staff Profile Expansion ──────────────────────────────────
  phone             String?
  dateOfBirth       DateTime?    @db.Date
  addressStreet     String?
  addressSuburb     String?
  addressState      String?
  addressPostcode   String?
  taxFileNumber     String?      @db.Text  // AES-256-GCM encrypted
  superFundName     String?
  superMemberNumber String?
  superUSI          String?
  visaStatus        VisaStatus?
  visaExpiry        DateTime?    @db.Date
  employmentType    EmploymentType?
  startDate         DateTime?    @db.Date
  probationEndDate  DateTime?    @db.Date
  bankDetailsNote   String?
  xeroEmployeeId    String?

  // ── HR Relations ─────────────────────────────────────────────
  emergencyContacts   EmergencyContact[]
  qualifications      StaffQualification[]
  contracts           EmploymentContract[]    @relation("ContractEmployee")
  leaveRequests       LeaveRequest[]          @relation("LeaveRequester")
  approvedLeaves      LeaveRequest[]          @relation("LeaveApprover")
  leaveBalances       LeaveBalance[]
  timesheetEntries    TimesheetEntry[]        @relation("TimesheetStaff")
  policyAcks          PolicyAcknowledgement[] @relation("PolicyAcknowledger")
  offboardings        StaffOffboarding[]      @relation("OffboardingUser")
  apiKeys             ApiKey[]                @relation("ApiKeyCreator")

  @@index([serviceId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model CalendarIntegration {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String   @default("microsoft") // "microsoft" | "google" (future)
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  scope        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model VisionTractionOrganiser {
  id                String   @id @default(cuid())
  coreValues        String[]
  corePurpose       String?
  coreNiche         String?
  tenYearTarget     String?  @db.Text
  threeYearPicture  String?  @db.Text
  marketingStrategy String?  @db.Text
  sectionLabels     Json?    // Custom section titles e.g. { tenYearTarget: "5-Year Target" }
  updatedAt         DateTime @updatedAt
  updatedById       String?
  updatedBy         User?    @relation("VTOUpdater", fields: [updatedById], references: [id])

  oneYearGoals OneYearGoal[]
}

model OneYearGoal {
  id          String     @id @default(cuid())
  title       String
  description String?    @db.Text
  targetDate  DateTime?
  status      GoalStatus @default(on_track)
  vtoId       String
  vto         VisionTractionOrganiser @relation(fields: [vtoId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  rocks Rock[]
}

model Rock {
  id              String       @id @default(cuid())
  title           String
  description     String?      @db.Text
  ownerId         String
  owner           User         @relation("RockOwner", fields: [ownerId], references: [id])
  quarter         String
  status          RockStatus   @default(on_track)
  percentComplete Int          @default(0)
  priority        RockPriority @default(medium)
  rockType        RockType     @default(personal)
  oneYearGoalId   String?
  oneYearGoal     OneYearGoal? @relation(fields: [oneYearGoalId], references: [id], onDelete: SetNull)
  serviceId       String?
  service         Service?     @relation("ServiceRocks", fields: [serviceId], references: [id], onDelete: SetNull)
  deleted         Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  todos       Todo[]
  issues      Issue[]
  milestones  Milestone[]
  measurables Measurable[]
  attachments Attachment[]

  @@index([quarter])
  @@index([ownerId])
  @@index([status])
  @@index([serviceId])
  @@index([quarter, serviceId])
}

model Milestone {
  id        String   @id @default(cuid())
  title     String
  dueDate   DateTime
  completed Boolean  @default(false)
  rockId    String
  rock      Rock     @relation(fields: [rockId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Todo {
  id          String     @id @default(cuid())
  title       String
  description String?    @db.Text
  assigneeId  String
  assignee    User       @relation("TodoAssignee", fields: [assigneeId], references: [id])
  createdById String?
  createdBy   User?      @relation("TodoCreator", fields: [createdById], references: [id])
  rockId      String?
  rock        Rock?      @relation(fields: [rockId], references: [id], onDelete: SetNull)
  issueId     String?
  issue       Issue?     @relation(fields: [issueId], references: [id], onDelete: SetNull)
  serviceId   String?
  service     Service?   @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  projectId   String?
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  dueDate     DateTime
  status      TodoStatus @default(pending)
  weekOf      DateTime
  isPrivate   Boolean    @default(false)
  deleted     Boolean    @default(false)
  createdAt   DateTime   @default(now())
  completedAt DateTime?
  updatedAt   DateTime   @updatedAt

  @@index([assigneeId])
  @@index([rockId])
  @@index([weekOf])
  @@index([status])
  @@index([serviceId])
  @@index([projectId])
  @@index([createdById])
  @@index([weekOf, serviceId])
}

model Issue {
  id           String        @id @default(cuid())
  title        String
  description  String?       @db.Text
  raisedById   String
  raisedBy     User          @relation("IssueRaiser", fields: [raisedById], references: [id])
  ownerId      String?
  owner        User?         @relation("IssueOwner", fields: [ownerId], references: [id])
  rockId       String?
  rock         Rock?         @relation(fields: [rockId], references: [id], onDelete: SetNull)
  serviceId    String?
  service      Service?      @relation("ServiceIssues", fields: [serviceId], references: [id], onDelete: SetNull)
  priority     IssuePriority @default(medium)
  status       IssueStatus   @default(open)
  identifiedAt DateTime      @default(now())
  discussedAt  DateTime?
  solvedAt     DateTime?
  resolution   String?       @db.Text
  deleted      Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  spawnedTodos Todo[]
  attachments Attachment[]

  @@index([priority])
  @@index([status])
  @@index([ownerId])
  @@index([serviceId])
  @@index([raisedById])
  @@index([status, serviceId])
}

model Scorecard {
  id        String   @id @default(cuid())
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  measurables Measurable[]
}

model Measurable {
  id            String              @id @default(cuid())
  title         String
  description   String?
  ownerId       String
  owner         User                @relation("MeasurableOwner", fields: [ownerId], references: [id])
  goalValue     Float
  goalDirection GoalDirection       @default(above)
  unit          String?
  frequency     MeasurableFrequency @default(weekly)
  rockId        String?
  rock          Rock?               @relation(fields: [rockId], references: [id], onDelete: SetNull)
  scorecardId   String
  scorecard     Scorecard           @relation(fields: [scorecardId], references: [id], onDelete: Cascade)
  serviceId     String?
  service       Service?            @relation("ServiceMeasurables", fields: [serviceId], references: [id], onDelete: SetNull)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  entries MeasurableEntry[]

  @@index([ownerId])
  @@index([scorecardId])
  @@index([serviceId])
}

model MeasurableEntry {
  id           String     @id @default(cuid())
  measurableId String
  measurable   Measurable @relation(fields: [measurableId], references: [id], onDelete: Cascade)
  weekOf       DateTime
  value        Float
  onTrack      Boolean
  notes        String?
  enteredById  String
  enteredBy    User       @relation("EntryCreator", fields: [enteredById], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([measurableId, weekOf])
  @@index([weekOf])
  @@index([enteredById])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String
  details    Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================================
// Cron Job Idempotency
// ============================================================

model CronRun {
  id        String   @id @default(cuid())
  cronName  String
  period    String   // e.g. "2025-03-05" for daily, "2025-W10" for weekly
  details   Json?
  startedAt DateTime @default(now())
  completedAt DateTime?
  status    String   @default("running") // running | completed | failed

  @@unique([cronName, period])
  @@index([cronName])
  @@index([startedAt])
}

// ============================================================
// Marketing
// ============================================================

model MarketingCampaign {
  id          String                  @id @default(cuid())
  name        String
  type        MarketingCampaignType   @default(campaign)
  status      MarketingCampaignStatus @default(draft)
  startDate   DateTime?
  endDate     DateTime?
  platforms   MarketingPlatform[]
  goal        String?                 @db.Text
  notes       String?                 @db.Text
  designLink  String?
  deleted     Boolean                 @default(false)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  posts    MarketingPost[]
  comments MarketingComment[]
  services MarketingCampaignService[]

  @@index([status])
  @@index([startDate])
}

model MarketingPost {
  id               String               @id @default(cuid())
  title            String
  platform         MarketingPlatform
  status           MarketingPostStatus   @default(draft)
  scheduledDate    DateTime?
  content          String?               @db.Text
  notes            String?               @db.Text
  designLink       String?
  pillar           String?
  assigneeId       String?
  assignee         User?                 @relation("MarketingPostAssignee", fields: [assigneeId], references: [id])
  campaignId       String?
  campaign         MarketingCampaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  likes            Int                   @default(0)
  comments         Int                   @default(0)
  shares           Int                   @default(0)
  reach            Int                   @default(0)
  recurring        MarketingRecurrence   @default(none)
  recurringParentId String?
  recurringParent  MarketingPost?        @relation("RecurringPosts", fields: [recurringParentId], references: [id])
  recurringChildren MarketingPost[]      @relation("RecurringPosts")
  clonedFromId     String?
  clonedFrom       MarketingPost?        @relation("PostClones", fields: [clonedFromId], references: [id])
  clones           MarketingPost[]       @relation("PostClones")
  services         MarketingPostService[]
  externalPostId   String?
  externalUrl      String?
  engagementSyncedAt DateTime?
  deleted          Boolean               @default(false)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([platform])
  @@index([status])
  @@index([assigneeId])
  @@index([campaignId])
  @@index([scheduledDate])
  @@index([externalPostId])
}

model MarketingComment {
  id         String            @id @default(cuid())
  campaignId String
  campaign   MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  authorId   String
  author     User              @relation("MarketingCommentAuthor", fields: [authorId], references: [id])
  text       String            @db.Text
  createdAt  DateTime          @default(now())

  @@index([campaignId])
  @@index([authorId])
}

model MarketingKPI {
  id        String               @id @default(cuid())
  name      String
  target    Float
  current   Float                @default(0)
  unit      String?
  period    MarketingKPIPeriod   @default(monthly)
  category  MarketingKPICategory @default(engagement)
  deleted   Boolean              @default(false)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([category])
  @@index([period])
}

model MarketingAsset {
  id        String             @id @default(cuid())
  name      String
  type      MarketingAssetType @default(image)
  url       String
  tags      String[]
  deleted   Boolean            @default(false)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([type])
}

model MarketingTemplate {
  id        String            @id @default(cuid())
  name      String
  platform  MarketingPlatform
  pillar    String?
  content   String            @db.Text
  notes     String?           @db.Text
  hashtags  String?
  deleted   Boolean           @default(false)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([platform])
}

model MarketingHashtagSet {
  id        String                  @id @default(cuid())
  name      String
  category  MarketingHashtagCategory
  tags      String                  @db.Text
  deleted   Boolean                 @default(false)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  @@index([category])
}

// ============================================================
// Services (OSHC Centres) & Projects
// ============================================================

model Service {
  id          String        @id @default(cuid())
  name        String
  code        String        @unique
  address     String?
  suburb      String?
  state       String?
  postcode    String?
  phone       String?
  email       String?
  status      ServiceStatus @default(active)
  managerId   String?
  manager     User?         @relation("ServiceManager", fields: [managerId], references: [id])
  capacity    Int?
  operatingDays String?
  notes       String?       @db.Text
  bscDailyRate  Float?
  ascDailyRate  Float?
  vcDailyRate   Float?
  bscCasualRate Float     @default(0)
  ascCasualRate Float     @default(0)
  bscGroceryRate Float    @default(0.80)
  ascGroceryRate Float    @default(1.20)
  vcGroceryRate  Float    @default(4.50)
  xeroTrackingOptionId String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  todos    Todo[]
  projects Project[]
  issues   Issue[]    @relation("ServiceIssues")
  rocks    Rock[]     @relation("ServiceRocks")
  measurables Measurable[] @relation("ServiceMeasurables")
  financials FinancialPeriod[] @relation("ServiceFinancials")
  metrics    CentreMetrics[]   @relation("ServiceMetrics")
  documents  Document[] @relation("ServiceDocuments")
  tickets    SupportTicket[]  @relation("ServiceTickets")
  whatsappContacts WhatsAppContact[] @relation("ServiceContacts")
  announcements Announcement[] @relation("ServiceAnnouncements")
  healthScores      HealthScore[]      @relation("ServiceHealthScores")
  staffMembers      User[]             @relation("ServiceStaff")
  onboardingPacks   OnboardingPack[]   @relation("ServiceOnboardingPacks")
  lmsCourses        LMSCourse[]        @relation("ServiceCourses")
  certificates      ComplianceCertificate[] @relation("ServiceCertificates")
  attendance        DailyAttendance[]      @relation("ServiceAttendance")
  budgetItems       BudgetItem[]           @relation("ServiceBudgetItems")
  programActivities ProgramActivity[]      @relation("ServicePrograms")
  menuWeeks         MenuWeek[]             @relation("ServiceMenus")
  todoTemplates     TodoTemplate[]         @relation("ServiceTemplates")
  marketingPosts    MarketingPostService[]     @relation("ServiceMarketingPosts")
  marketingCampaigns MarketingCampaignService[] @relation("ServiceMarketingCampaigns")
  socialConnections SocialConnection[]         @relation("ServiceSocialConnections")

  // ── HR Relations ─────────────────────────────────────────────
  leaveRequests      LeaveRequest[]          @relation("ServiceLeaveRequests")
  timesheets         Timesheet[]             @relation("ServiceTimesheets")
  offboardingPacks   OffboardingPack[]       @relation("ServiceOffboardingPacks")

  @@index([status])
  @@index([managerId])
}

model ProjectTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks    ProjectTemplateTask[]
  projects Project[]
}

model ProjectTemplateTask {
  id          String          @id @default(cuid())
  templateId  String
  template    ProjectTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  title       String
  description String?         @db.Text
  category    String?
  sortOrder   Int             @default(0)
  defaultDays Int?

  @@index([templateId])
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?       @db.Text
  serviceId   String?
  service     Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  templateId  String?
  template    ProjectTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  ownerId     String
  owner       User          @relation("ProjectOwner", fields: [ownerId], references: [id])
  status      ProjectStatus @default(not_started)
  startDate   DateTime?
  targetDate  DateTime?
  completedAt DateTime?
  deleted     Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  todos Todo[]
  attachments Attachment[]

  @@index([serviceId])
  @@index([ownerId])
  @@index([status])
}

// ============================================================
// L10 Meetings
// ============================================================

model Meeting {
  id            String        @id @default(cuid())
  title         String
  date          DateTime
  status        MeetingStatus @default(scheduled)
  currentSection Int          @default(0)
  rating        Float?
  notes         String?       @db.Text
  headlines     String?       @db.Text
  segueNotes    String?       @db.Text
  concludeNotes   String?       @db.Text
  cascadeMessages String?       @db.Text
  serviceIds    String[]      // IDs of services scoped to this meeting
  rockIds       String[]      // IDs of rocks linked to this meeting
  startedAt       DateTime?
  completedAt   DateTime?
  createdById   String
  createdBy     User          @relation("MeetingCreator", fields: [createdById], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  cascades CascadeMessage[] @relation("MeetingCascade")

  @@index([date])
  @@index([status])
  @@index([createdById])
}

// ============================================================
// Documents & Attachments
// ============================================================

enum DocumentCategory {
  program
  policy
  procedure
  template
  guide
  compliance
