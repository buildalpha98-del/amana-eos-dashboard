  @@index([surveyType])
  @@index([status])
  @@index([serviceId, status])
  @@index([source])
  @@index([contactId])
  @@index([childId])
}

// ============================================================
// Partnership Meetings (Cowork ERM — linked to SchoolRelationship)
// ============================================================

model PartnershipMeeting {
  id                   String              @id @default(cuid())
  serviceId            String
  service              Service             @relation("ServicePartnershipMeetings", fields: [serviceId], references: [id], onDelete: Cascade)
  schoolRelationshipId String?
  schoolRelationship   SchoolRelationship? @relation(fields: [schoolRelationshipId], references: [id], onDelete: SetNull)
  date                 DateTime
  attendees            String
  agenda               String?             @db.Text
  notes                String?             @db.Text
  actionItems          Json? // [{ action: "...", owner: "...", dueDate: "..." }]
  createdAt            DateTime            @default(now())

  @@index([serviceId])
  @@index([date])
}

// ============================================================
// Parent Experience Metrics (Cowork ERM)
// ============================================================

model ParentExperience {
  id          String   @id @default(cuid())
  serviceId   String?
  service     Service? @relation("ServiceParentExperience", fields: [serviceId], references: [id], onDelete: Cascade)
  serviceCode String
  metricType  String // photo_compliance, satisfaction_score, communication_audit, engagement_score, nps_snapshot, welcome_pack_sent, first_week_checkin, birthday_celebration
  period      String // e.g. "2026-W12", "2026-03", "2026-Q1"
  value       Float?
  target      Float?
  status      String? // on_track, at_risk, below_target, exceeding
  details     Json?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([serviceCode, metricType, period])
  @@index([serviceCode])
  @@index([metricType])
}

// ── Info Snippets (Acknowledge New Information) ──────────────

model InfoSnippet {
  id          String    @id @default(cuid())
  title       String
  summary     String    @db.Text
  category    String? // e.g. "policy", "update", "safety", "general"
  priority    String    @default("normal") // low, normal, high
  active      Boolean   @default(true)
  expiresAt   DateTime?
  createdById String?
  createdBy   User?     @relation("SnippetCreator", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  acknowledgements SnippetAck[] @relation("SnippetAcknowledgements")

  @@index([active])
  @@index([createdById])
}

model SnippetAck {
  id             String      @id @default(cuid())
  snippetId      String
  snippet        InfoSnippet @relation("SnippetAcknowledgements", fields: [snippetId], references: [id], onDelete: Cascade)
  userId         String
  user           User        @relation("UserSnippetAcks", fields: [userId], references: [id], onDelete: Cascade)
  acknowledgedAt DateTime    @default(now())

  @@unique([snippetId, userId])
  @@index([snippetId])
  @@index([userId])
}

// ============================================================
// Enrolment Submissions (Public parent enrolment form)
// ============================================================

model EnrolmentSubmission {
  id        String  @id @default(cuid())
  token     String  @unique @default(cuid())
  enquiryId String?
  serviceId String?

  // Phase 1+2: Family data
  primaryParent   Json // { firstName, surname, dob, email, mobile, address, relationship, occupation, workplace, workPhone, crn }
  secondaryParent Json? // same structure
  children        Json // [{ firstName, surname, dob, gender, address, cultural, school, yearLevel, crn, medical, dietary, bookingPrefs }]

  // Phase 4: Emergency & authorised persons
  emergencyContacts Json // [{ name, relationship, phone, email }]
  authorisedPickup  Json? // [{ name, relationship }]

  // Phase 5: Consents
  consents Json // { firstAid, medication, ambulance, transport, excursions, photos, sunscreen }

  // Phase 7: Payment (masked for security)
  paymentMethod  String? // "credit_card" or "bank_account"
  paymentDetails Json? // { lastFour, cardType } or { bsbLastThree, accountLastFour } — MASKED

  // Phase 8: Submission
  referralSource  String?
  signature       String? @db.Text
  termsAccepted   Boolean @default(false)
  privacyAccepted Boolean @default(false)
  debitAgreement  Boolean @default(false)

  // Court orders
  courtOrders     Boolean @default(false)
  courtOrderFiles Json? // [{ filename, url }]

  // Medical uploads
  medicalFiles Json? // [{ childIndex, type, filename, url }]

  // Document uploads (child photos, birth certificates, immunisation records)
  documentUploads Json? // [{ childIndex, type, filename, url }]

  // Status
  status        String    @default("submitted")
  processedById String?
  processedAt   DateTime?
  pdfUrl        String?
  notes         String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  childRecords Child[]

  @@index([status])
  @@index([enquiryId])
  @@index([token])
}

// ============================================================
// Children (structured records from enrolment submissions)
// ============================================================

model Child {
  id                    String               @id @default(cuid())
  enrolmentId           String?
  enrolment             EnrolmentSubmission? @relation(fields: [enrolmentId], references: [id], onDelete: Cascade)
  serviceId             String?
  service               Service?             @relation("ServiceChildren", fields: [serviceId], references: [id])
  firstName             String
  surname               String
  dob                   DateTime?
  gender                String?
  address               Json? // { street, suburb, state, postcode }
  culturalBackground    String[]
  schoolName            String?
  yearLevel             String?
  crn                   String?
  countryOfBirth        String? // "Australia" | "New Zealand" | free text for "Other"
  medical               Json? // Full medical info (legacy — from enrolment import)
  dietary               Json? // Dietary requirements (legacy — from enrolment import)
  bookingPrefs          Json? // Session types, days, booking type
  // ── Expanded profile fields ──
  medicalConditions     String[] // e.g. ["Asthma", "Anaphylaxis"]
  medicationDetails     String? // Free text: medications, dosage, administration
  anaphylaxisActionPlan Boolean              @default(false) // Flag: action plan document exists
  dietaryRequirements   String[] // e.g. ["Halal", "Nut Free", "Vegetarian"]
  additionalNeeds       String? // Free text: other care requirements
  // ── Medicare + immunisation (consumed by Services Medical tab) ──
  medicareNumber        String?
  medicareExpiry        DateTime?
  medicareRef           String?
  vaccinationStatus     String?
  nextImmunisationDue   DateTime?            @db.Date
  // ── Custody / guardianship (admin-set, surfaced on sign-out + medical) ──
  custodyArrangements   Json? // { type: "shared" | "sole" | "court_order" | "informal", primaryGuardian?, details?, courtOrderUrl? }
  // ── CCS + room + tags (first-class filter dimensions, 4b) ──
  ccsStatus             String? // "eligible" | "pending" | "ineligible" — documented values, free-text for forward compat
  room                  String? // dashboard-controlled room label; decoupled from OWNA's ownaRoomName
  tags                  String[]             @default([]) // optional filter tags; empty-array default means existing rows don't need backfill
  photo                 String? // URL to profile photo (Vercel Blob)
  status                String               @default("pending") // pending, active, withdrawn
  // OWNA sync fields
  ownaChildId           String?              @unique
  ownaRoomId            String?
  ownaRoomName          String?
  ownaSyncedAt          DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  bookings           Booking[]            @relation("ChildBookings")
  absences           Absence[]            @relation("ChildAbsences")
  documents          ParentDocument[]     @relation("ChildDocuments")
  childDocuments     ChildDocument[]      @relation("ChildProfileDocuments")
  authorisedPickups  AuthorisedPickup[]   @relation("ChildPickups")
  postTags           ParentPostChildTag[] @relation("ChildPostTags")
  attendanceRecords  AttendanceRecord[]   @relation("ChildAttendance")
  statementLineItems StatementLineItem[]  @relation("ChildStatementLines")

  // ── NQS relations ─────────────────────────────────
  observations  LearningObservation[]      @relation("ChildObservations")
  medications   MedicationAdministration[] @relation("ChildMedications")
  allAboutMe    AllAboutMe?                @relation("ChildAllAboutMe")
  feedbackItems ParentFeedback[]           @relation("ChildFeedback")

  @@index([enrolmentId])
  @@index([serviceId])
  @@index([status])
  @@index([ownaChildId])
  @@index([serviceId, ccsStatus])
  @@index([serviceId, room])
  @@index([serviceId, nextImmunisationDue])
}

// ── All About Me (Amana Way stage 5 — Reassurance) ───────────
//
// Parent-portal form filled before first session. Surfaces to staff
// on the child's roll-call card so they can greet the child with
// the right context (nickname, favourite foods, calming techniques).

model AllAboutMe {
  id                String    @id @default(cuid())
  childId           String    @unique
  child             Child     @relation("ChildAllAboutMe", fields: [childId], references: [id], onDelete: Cascade)
  nickname          String?
  favouriteFood     String?
  favouriteToys     String?
  favouriteSubjects String?
  hobbies           String?
  fears             String?
  calmingTechniques String?   @db.Text
  additionalNotes   String?   @db.Text
  submittedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([childId])
}

// ── Sequences (Parent Nurture + CRM Outreach) ───────────────

enum SequenceType {
  parent_nurture
  crm_outreach
}

model Sequence {
  id           String       @id @default(cuid())
  name         String
  type         SequenceType
  triggerStage String? // enquiry stage (info_sent, nurturing, etc.) or PipelineStage (new_lead, etc.)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  steps      SequenceStep[]
  enrolments SequenceEnrolment[]

  @@unique([name, type])
  @@index([type])
  @@index([triggerStage])
}

model SequenceStep {
  id              String         @id @default(cuid())
  sequenceId      String
  sequence        Sequence       @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  stepNumber      Int
  name            String
  delayHours      Int // hours after anchor date (negative = before)
  templateKey     String // backward-compat key (e.g. "nudge_1", "ccs_assist")
  emailTemplateId String? // FK to EmailTemplate for visual template override
  emailTemplate   EmailTemplate? @relation("StepEmailTemplate", fields: [emailTemplateId], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  executions SequenceStepExecution[]

  @@unique([sequenceId, stepNumber])
  @@index([sequenceId])
}

model SequenceEnrolment {
  id                String         @id @default(cuid())
  sequenceId        String
  sequence          Sequence       @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  contactId         String? // for parent nurture
  contact           CentreContact? @relation("ContactSequenceEnrolments", fields: [contactId], references: [id])
  leadId            String? // for CRM outreach
  lead              Lead?          @relation("LeadSequenceEnrolments", fields: [leadId], references: [id])
  enquiryId         String?
  serviceId         String?
  status            String         @default("active") // active, paused, completed, cancelled
  currentStepNumber Int            @default(1)
  anchorDate        DateTime       @default(now())
  enrolledAt        DateTime       @default(now())
  completedAt       DateTime?
  pausedAt          DateTime?

  executions SequenceStepExecution[]

  @@unique([sequenceId, contactId])
  @@unique([sequenceId, leadId])
  @@index([sequenceId])
  @@index([status])
}

model SequenceStepExecution {
  id           String            @id @default(cuid())
  enrolmentId  String
  enrolment    SequenceEnrolment @relation(fields: [enrolmentId], references: [id], onDelete: Cascade)
  stepId       String
  step         SequenceStep      @relation(fields: [stepId], references: [id], onDelete: Cascade)
  scheduledFor DateTime
  sentAt       DateTime?
  status       String            @default("pending") // pending, sent, failed, cancelled
  error        String?
  attempts     Int               @default(0) // failed send attempts; capped before marking "failed"
  createdAt    DateTime          @default(now())

  @@index([status, scheduledFor])
  @@index([enrolmentId])
}

// ── Parent Portal ───────────────────────────────────────────

model ParentMagicLink {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([tokenHash])
}

model Booking {
  id            String         @id @default(cuid())
  childId       String
  child         Child          @relation("ChildBookings", fields: [childId], references: [id], onDelete: Cascade)
  serviceId     String
  service       Service        @relation("ServiceBookings_Portal", fields: [serviceId], references: [id], onDelete: Cascade)
  date          DateTime       @db.Date
  sessionType   SessionType
  status        BookingStatus  @default(requested)
  type          BookingType    @default(casual)
  fee           Float?
  ccsApplied    Float? // CCS subsidy amount applied
  gapFee        Float? // Fee after CCS applied
  requestedById String? // CentreContact who requested (parent)
  requestedBy   CentreContact? @relation("ContactBookings", fields: [requestedById], references: [id])
  reviewedById  String? // User (staff) who approved/declined
  reviewedBy    User?          @relation("BookingReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt    DateTime?
  declineReason String?        @db.Text
  notes         String?        @db.Text
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([childId, serviceId, date, sessionType])
  @@index([childId])
  @@index([serviceId])
  @@index([date])
  @@index([status])
  @@index([serviceId, date])
  @@index([childId, status])
  @@index([date, status])
  @@index([status, serviceId])
}

model Absence {
  id                    String      @id @default(cuid())
  childId               String
  child                 Child       @relation("ChildAbsences", fields: [childId], references: [id], onDelete: Cascade)
  serviceId             String
  service               Service     @relation("ServiceAbsences", fields: [serviceId], references: [id], onDelete: Cascade)
  date                  DateTime    @db.Date
  sessionType           SessionType
  isIllness             Boolean     @default(false)
  medicalCertificateUrl String?
  reason                String? // "sick" | "holiday" | "other"
  notifiedById          String? // CentreContact or User ID who submitted
  notifiedAt            DateTime    @default(now())
  notes                 String?     @db.Text
  createdAt             DateTime    @default(now())

  @@unique([childId, serviceId, date, sessionType])
  @@index([childId, date])
  @@index([serviceId, date])
  @@index([childId])
}

model Statement {
  id          String          @id @default(cuid())
  contactId   String
  contact     CentreContact   @relation("ContactStatements", fields: [contactId], references: [id], onDelete: Cascade)
  serviceId   String
  service     Service         @relation("ServiceStatements", fields: [serviceId], references: [id], onDelete: Cascade)
  periodStart DateTime        @db.Date
  periodEnd   DateTime        @db.Date
  totalFees   Float
  totalCcs    Float           @default(0)
  gapFee      Float           @default(0)
  amountPaid  Float           @default(0)
  balance     Float           @default(0)
  issuedAt    DateTime?
  notes       String?         @db.Text
  status      StatementStatus @default(draft)
  pdfUrl      String?
  dueDate     DateTime?       @db.Date
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  lineItems StatementLineItem[]
  payments  Payment[]

  @@index([contactId])
  @@index([serviceId, periodStart])
  @@index([status])
  @@index([status, dueDate])
}

model StatementLineItem {
  id          String      @id @default(cuid())
  statementId String
  childId     String
  date        DateTime    @db.Date
  sessionType SessionType
  description String
  grossFee    Float
  ccsHours    Float       @default(0)
  ccsRate     Float       @default(0)
  ccsAmount   Float       @default(0)
  gapAmount   Float
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  statement Statement @relation(fields: [statementId], references: [id], onDelete: Cascade)
  child     Child     @relation("ChildStatementLines", fields: [childId], references: [id])

  @@index([statementId])
}

model Payment {
  id           String        @id @default(cuid())
  statementId  String?
  contactId    String
  serviceId    String
  amount       Float
  method       PaymentMethod
  reference    String?
  receivedAt   DateTime      @default(now())
  recordedById String?
  notes        String?       @db.Text
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  statement  Statement?    @relation(fields: [statementId], references: [id], onDelete: SetNull)
  contact    CentreContact @relation("ContactPayments", fields: [contactId], references: [id])
  service    Service       @relation("ServicePayments", fields: [serviceId], references: [id])
  recordedBy User?         @relation("PaymentRecordedBy", fields: [recordedById], references: [id])

  @@index([contactId, receivedAt])
  @@index([statementId])
}

model ParentDocument {
  id         String        @id @default(cuid())
  childId    String
  child      Child         @relation("ChildDocuments", fields: [childId], references: [id], onDelete: Cascade)
  contactId  String
  contact    CentreContact @relation("ContactDocuments", fields: [contactId], references: [id], onDelete: Cascade)
  docType    String // immunisation, medical_action_plan, birth_certificate, custody_order, other
  fileName   String
  fileUrl    String
  uploadedAt DateTime      @default(now())
  expiryDate DateTime?     @db.Date
  notes      String?       @db.Text

  @@index([childId])
  @@index([contactId])
}

model AuthorisedPickup {
  id                 String   @id @default(cuid())
  childId            String
  child              Child    @relation("ChildPickups", fields: [childId], references: [id], onDelete: Cascade)
  name               String
  relationship       String
  phone              String
  photoUrl           String?
  photoId            String? // Description of ID they carry for verification
  isEmergencyContact Boolean  @default(false)
  hasPassword        Boolean  @default(false)
  passwordHash       String?
  active             Boolean  @default(true)
  notes              String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([childId])
}

enum ChildDocumentType {
  ANAPHYLAXIS_PLAN
  ASTHMA_PLAN
  MEDICAL_CERTIFICATE
  IMMUNISATION_RECORD
  COURT_ORDER
  OTHER
}

model ChildDocument {
  id           String            @id @default(cuid())
  childId      String
  child        Child             @relation("ChildProfileDocuments", fields: [childId], references: [id], onDelete: Cascade)
  documentType ChildDocumentType
  fileName     String
  fileUrl      String // Vercel Blob URL
  uploadedById String
  uploadedBy   User              @relation("UploadedChildDocuments", fields: [uploadedById], references: [id])
  uploaderType String? // "staff" | "parent"
  expiresAt    DateTime?
  isVerified   Boolean           @default(false)
  verifiedById String?
  verifiedAt   DateTime?
  notes        String?           @db.Text
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @default(now()) @updatedAt

  @@index([childId])
  @@index([uploadedById])
}

// ── Parent Posts (Staff-to-Parent Timeline) ─────────────────

model ParentPost {
  id          String         @id @default(cuid())
  serviceId   String
  service     Service        @relation("ServiceParentPosts", fields: [serviceId], references: [id], onDelete: Cascade)
  title       String
  content     String         @db.Text
  type        ParentPostType @default(observation)
  mediaUrls   String[] // Array of image/video URLs
  authorId    String?
  author      User?          @relation("PostAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  isCommunity Boolean        @default(false) // If true, visible to all parents at the service. If false, only tagged children's parents.
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tags     ParentPostChildTag[]
  likes    ParentPostLike[]
  comments ParentPostComment[]

  @@index([serviceId])
  @@index([createdAt])
}

model ParentPostChildTag {
  id      String     @id @default(cuid())
  postId  String
  post    ParentPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  childId String
  child   Child      @relation("ChildPostTags", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([postId, childId])
  @@index([childId])
}

model ParentPostLike {
  id        String        @id @default(cuid())
  postId    String
  post      ParentPost    @relation(fields: [postId], references: [id], onDelete: Cascade)
  likerId   String
  liker     CentreContact @relation("ParentPostLikes", fields: [likerId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([postId, likerId])
  @@index([postId])
  @@index([likerId])
}

model ParentPostComment {
  id             String         @id @default(cuid())
  postId         String
  post           ParentPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentAuthorId String?
  parentAuthor   CentreContact? @relation("ParentPostComments", fields: [parentAuthorId], references: [id], onDelete: SetNull)
  staffAuthorId  String?
  staffAuthor    User?          @relation("ParentPostStaffComments", fields: [staffAuthorId], references: [id], onDelete: SetNull)
  body           String         @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([postId, createdAt])
  @@index([parentAuthorId])
  @@index([staffAuthorId])
}

// ── Parent Notifications (In-App Bell) ──────────────────

model ParentNotification {
  id          String   @id @default(cuid())
  parentEmail String
  type        String // post, booking, message, attendance
  title       String
  body        String
  link        String // deep link path e.g. "/parent/messages/abc123"
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([parentEmail, read])
  @@index([parentEmail, createdAt])
}

// ── In-App Messaging ────────────────────────────────────

model Conversation {
  id            String   @id @default(cuid())
  serviceId     String
  familyId      String // CentreContact id
  subject       String
  status        String   @default("open") // "open" | "resolved" | "archived"
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  service  Service       @relation(fields: [serviceId], references: [id])
  family   CentreContact @relation(fields: [familyId], references: [id])
  messages Message[]

  @@index([serviceId, status, lastMessageAt])
  @@index([familyId, lastMessageAt])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  body           String    @db.Text
  attachmentUrls String[]  @default([])
  senderType     String // "staff" | "parent"
  senderId       String // User.id or CentreContact.id depending on senderType
  senderName     String // Denormalised for display
  isRead         Boolean   @default(false)
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId, senderType])
}

model Broadcast {
  id                String   @id @default(cuid())
  serviceId         String
  subject           String
  body              String   @db.Text
  /// Channels to dispatch on: "email" | "sms" | "push". Pre-G broadcasts
  /// default to email-only; new ones can opt into multi-channel send.
  channels          String[] @default(["email"])
  sentById          String // User.id
  sentByName        String
  recipientCount    Int      @default(0)
  smsRecipientCount Int      @default(0)
  sentAt            DateTime @default(now())
  createdAt         DateTime @default(now())

  service Service @relation(fields: [serviceId], references: [id])
  sentBy  User    @relation("BroadcastSentBy", fields: [sentById], references: [id])

  @@index([serviceId, sentAt])
}

// ============================================================
// Sibling Enrolment Applications
// ============================================================

model EnrolmentApplication {
  id        String @id @default(cuid())
  serviceId String
  familyId  String // CentreContact id (existing parent)
  status    String @default("pending") // "pending" | "approved" | "declined" | "withdrawn"
  type      String @default("sibling") // "new" | "sibling"

  // Child details
  childFirstName   String
  childLastName    String
  childDateOfBirth DateTime @db.Date
  childGender      String?
  childSchool      String?
  childYear        String?

  // Care requirements
  sessionTypes String[] // ["BSC", "ASC", "VAC"]
  startDate    DateTime? @db.Date

  // Medical
  medicalConditions     String[]
  dietaryRequirements   String[]
  medicationDetails     String?
  anaphylaxisActionPlan String?
  additionalNeeds       String?

  // Consents
  consentPhotography Boolean @default(false)
  consentSunscreen   Boolean @default(false)
  consentFirstAid    Boolean @default(false)
  consentExcursions  Boolean @default(false)

  // Copy from sibling flag
  copyAuthorisedPickups Boolean @default(true)
  copyEmergencyContacts Boolean @default(true)

  // Review
  reviewedById  String?
  reviewedAt    DateTime?
  declineReason String?
  notes         String?

  // If approved, the created child record
  createdChildId String?

  // OWNA CSV export tracking (set when admin downloads the OWNA-import CSV)
  ownaExportedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  service    Service       @relation("ServiceEnrolmentApplications", fields: [serviceId], references: [id])
  family     CentreContact @relation("ContactEnrolmentApplications", fields: [familyId], references: [id])
  reviewedBy User?         @relation("EnrolmentReviewedBy", fields: [reviewedById], references: [id])

  @@index([serviceId, status])
  @@index([familyId, status])
}

// ============================================================
// Notification Log — records every email sent by the system
// ============================================================

model NotificationLog {
  id             String   @id @default(cuid())
  type           String // e.g. "attendance_signin" | "booking_confirmed" | "statement_issued" etc.
  recipientEmail String
  recipientName  String?
  subject        String
  status         String   @default("sent") // "sent" | "failed"
  errorMessage   String?
  relatedId      String? // id of the related record (bookingId, statementId, etc.)
  relatedType    String? // "Booking" | "Statement" | "Message" etc.
  createdAt      DateTime @default(now())

  @@index([type, createdAt])
  @@index([recipientEmail, createdAt])
  @@index([relatedId, relatedType])
}

/// In-app notification for a staff user. Surfaced via bell icon.
model UserNotification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  type      String // see src/lib/notification-types.ts for known values
  title     String
  body      String
  link      String? // deep link path, e.g. "/staff/{userId}?tab=compliance"
  read      Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
}

// ============================================================
// Push Subscriptions — browser push notification endpoints
// ============================================================

model PushSubscription {
  id        String         @id @default(cuid())
  userId    String? // Staff user
  familyId  String? // Parent CentreContact
  family    CentreContact? @relation("ContactPushSubscriptions", fields: [familyId], references: [id], onDelete: Cascade)
  endpoint  String         @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([userId])
  @@index([familyId])
}

// ============================================================
// Parent Auth Tokens — magic link verification tokens
// ============================================================

model ParentAuthToken {
  id        String    @id @default(cuid())
  familyId  String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  family CentreContact @relation("ContactAuthTokens", fields: [familyId], references: [id], onDelete: Cascade)

  @@index([token])
