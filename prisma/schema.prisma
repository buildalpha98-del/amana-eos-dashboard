  aiDrafts   AiTaskDraft[]  @relation("TodoAiDraft")
  sourceCall VapiCall?      @relation("TodoFromCall")

  @@index([assigneeId])
  @@index([rockId])
  @@index([weekOf])
  @@index([status])
  @@index([serviceId])
  @@index([projectId])
  @@index([createdById])
  @@index([weekOf, serviceId])
  @@index([assigneeId, status])
  @@index([dueDate, status])
}

model TodoAssignee {
  id     String @id @default(cuid())
  todoId String
  todo   Todo   @relation("TodoAssignees", fields: [todoId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation("TodoMultiAssignee", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([todoId, userId])
  @@index([todoId])
  @@index([userId])
}

model Issue {
  id           String        @id @default(cuid())
  title        String
  description  String?       @db.Text
  raisedById   String?
  raisedBy     User?         @relation("IssueRaiser", fields: [raisedById], references: [id])
  ownerId      String?
  owner        User?         @relation("IssueOwner", fields: [ownerId], references: [id])
  rockId       String?
  rock         Rock?         @relation(fields: [rockId], references: [id], onDelete: SetNull)
  serviceId    String?
  service      Service?      @relation("ServiceIssues", fields: [serviceId], references: [id], onDelete: SetNull)
  priority     IssuePriority @default(medium)
  status       IssueStatus   @default(open)
  category     IssueCategory @default(short_term)
  identifiedAt DateTime      @default(now())
