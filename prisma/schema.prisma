  enquiries ParentEnquiry[]
  referrals Referral[]

  // ── Recruitment Pipeline ───────────────────────────
  vacancies    RecruitmentVacancy[] @relation("ServiceVacancies")
  pulseSurveys StaffPulseSurvey[]   @relation("ServicePulseSurveys")

  // ── Billing ───────────────────────────────────────────
  overdueFees OverdueFeeRecord[] @relation("ServiceOverdueFees")
  payments    Payment[]          @relation("ServicePayments")

  // ── Operations ────────────────────────────────────────
  qip       QualityImprovementPlan? @relation("ServiceQIP")
  incidents IncidentRecord[]        @relation("ServiceIncidents")

  // Purchase approval requests raised by staff working at this
  // service. Admin approves/rejects from the Finance → Approvals tab.
  purchaseApprovals PurchaseApproval[] @relation("ServicePurchaseApprovals")

  // ── Programming & Quality ──────────────────────────
  childInterests ChildInterest[] @relation("ServiceInterests")

  // ── Parent Experience ──────────────────────────────
  quickFeedback    QuickFeedback[]    @relation("ServiceQuickFeedback")
  exitSurveys      ExitSurvey[]       @relation("ServiceExitSurveys")
  parentFeedback   ParentFeedback[]   @relation("ServiceParentFeedback")
  parentExperience ParentExperience[] @relation("ServiceParentExperience")
  childRecords     Child[]            @relation("ServiceChildren")

  // ── Parent Portal Relations ──────────────────────
  bookings    Booking[]    @relation("ServiceBookings_Portal")
  absences    Absence[]    @relation("ServiceAbsences")
  statements  Statement[]  @relation("ServiceStatements")
  parentPosts ParentPost[] @relation("ServiceParentPosts")

  // ── Cowork Reports ──────────────────────────────
  coworkReports CoworkReport[] @relation("CoworkReportService")

  // ── AI Phase 2 Relations ──────────────────────────
  sentimentScores     SentimentScore[]    @relation("SentimentScoreService")
  attendanceAnomalies AttendanceAnomaly[] @relation("AttendanceAnomalyService")
  trendInsights       TrendInsight[]      @relation("TrendInsightService")

  // ── Daily Checklists ──────────────────────────────
  dailyChecklists DailyChecklist[]

  // ── Partnerships ──────────────────────────────────
  schoolRelationship  SchoolRelationship?
  partnershipMeetings PartnershipMeeting[] @relation("ServicePartnershipMeetings")

  // ── Finance Reports ─────────────────────────────
  financeReports FinanceReport[] @relation("ServiceFinanceReports")

  // ── In-App Messaging ─────────────────────────────
  conversations Conversation[]
  broadcasts    Broadcast[]

  // ── Sibling Enrolment Applications ────────────────
  enrolmentApplications EnrolmentApplication[] @relation("ServiceEnrolmentApplications")

  // ── Service Events (excursions, incursions, etc.) ─
  events ServiceEvent[] @relation("ServiceEvents")

  // ── NQS Models ───────────────────────────────────
  reflections     StaffReflection[]          @relation("ServiceReflections")
  observations    LearningObservation[]      @relation("ServiceObservations")
  medications     MedicationAdministration[] @relation("ServiceMedications")
  riskAssessments RiskAssessment[]           @relation("ServiceRiskAssessments")
  ratioSnapshots  RatioSnapshot[]            @relation("ServiceRatios")
  handovers       ShiftHandover[]            @relation("ServiceHandovers")
  safeReports     SafeReport[]

  // ── Marketing Cockpit (Sprint 2) ──────────────
  centreAvatar             CentreAvatar?
  vendorBriefs             VendorBrief[]             @relation("ServiceVendorBriefs")
  whatsappCoordinatorPosts WhatsAppCoordinatorPost[] @relation("ServiceWhatsAppPosts")

  // 2026-05-14 (service-staff v1): additional staff memberships layered on
  // top of staffMembers (which is the User.serviceId one-to-many). Lets a
  // single staff member be at multiple centres with per-service role+access.
  serviceMemberships UserServiceMembership[] @relation("ServiceMemberships")

  @@index([status])
  @@index([managerId])
}

/// 2026-05-14: Per-service additional memberships layered on top of
/// User.serviceId (which models the staff member's primary/home service).
/// A user can be primary at one centre AND have UserServiceMembership rows
/// for any other centres they work at. Removing a membership is soft —
/// flip status=inactive and set endDate — so audit history survives.
model UserServiceMembership {
  id            String                  @id @default(cuid())
  userId        String
  user          User                    @relation("UserMemberships", fields: [userId], references: [id], onDelete: Cascade)
  serviceId     String
  service       Service                 @relation("ServiceMemberships", fields: [serviceId], references: [id], onDelete: Cascade)
  roleAtService String // free-text label: "Educator", "Room Leader", "Director", ...
  accessLevel   ServiceAccessLevel      @default(contributor)
  startDate     DateTime                @db.Date
  endDate       DateTime?               @db.Date
  status        ServiceMembershipStatus @default(active)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@unique([userId, serviceId])
  @@index([serviceId, status])
  @@index([userId, status])
}

enum ServiceEventType {
  excursion
  incursion
  public_holiday
  event
  meeting
  parent_engagement
}

model ServiceEvent {
  id               String           @id @default(cuid())
  serviceId        String
  service          Service          @relation("ServiceEvents", fields: [serviceId], references: [id], onDelete: Cascade)
  eventType        ServiceEventType
  title            String
  /// Event date (day-only — start/end time held separately).
  date             DateTime         @db.Date
  startTime        DateTime?
  endTime          DateTime?
  notes            String?          @db.Text
  /// Optional FK to a RiskAssessment that approves this event.
  /// Nullable until a RiskAssessment is linked; required before creating
  /// excursion events (enforced in the API route).
  /// Kept as a nullable string (no FK relation) for now — the RiskAssessment
  /// model is added in a later migration, at which point the relation is
  /// formalised. Referential integrity is still enforced at the app layer.
  riskAssessmentId String?
  createdById      String
  createdBy        User             @relation("ServiceEventCreator", fields: [createdById], references: [id])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([serviceId, date])
  @@index([eventType, date])
}

// ============================================================
// NQS (National Quality Standard) Models
// ============================================================

/// Educator/staff reflections — weekly/monthly/critical/team. NQS QA1.3.
/// Named `StaffReflection` to avoid clashing with legacy `EducatorReflection`
/// (centreId-based, owned by the Cowork ingest pipeline). The public "Reflection"
/// UX / API naming stays parent-facing; this is the internal model name.
model StaffReflection {
  id                   String   @id @default(cuid())
  serviceId            String
  authorId             String
  type                 String // "weekly" | "monthly" | "critical" | "team"
  title                String
  content              String   @db.Text
  qualityAreas         Int[]    @default([])
  linkedObservationIds String[] @default([])
  mood                 String? // "positive" | "neutral" | "concern"
  /// UUID generated by the client for offline-queue dedupe.
  clientMutationId     String?  @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  service Service @relation("ServiceReflections", fields: [serviceId], references: [id], onDelete: Cascade)
  author  User    @relation("StaffReflections", fields: [authorId], references: [id])

  @@index([serviceId, createdAt])
  @@index([authorId, createdAt])
}

/// Individual-child learning observations — MTOP outcomes + interests + photos. NQS QA1.1/1.2.
model LearningObservation {
  id               String   @id @default(cuid())
  childId          String
  serviceId        String
  authorId         String
  title            String
  narrative        String   @db.Text
  mtopOutcomes     String[] @default([]) // Identity | Community | Wellbeing | Learners | Communicators
  interests        String[] @default([])
  mediaUrls        String[] @default([])
  visibleToParent  Boolean  @default(false)
  /// UUID generated by the client for offline-queue dedupe.
  clientMutationId String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  child   Child   @relation("ChildObservations", fields: [childId], references: [id], onDelete: Cascade)
  service Service @relation("ServiceObservations", fields: [serviceId], references: [id], onDelete: Cascade)
  author  User    @relation("LearningObservations", fields: [authorId], references: [id])

  @@index([childId, createdAt])
  @@index([serviceId, createdAt])
}

/// Medication Administration Record (MAR). NQS QA2.1. Dual sign-off for injections.
model MedicationAdministration {
  id               String   @id @default(cuid())
  childId          String
  serviceId        String
  medicationName   String
  dose             String
  route            String // oral | topical | inhaled | injection | other
  administeredAt   DateTime
  administeredById String
  /// Required when route = "injection" (server-side Zod).
  witnessedById    String?
  parentConsentUrl String?
  notes            String?  @db.Text
  /// UUID generated by the client for offline-queue dedupe.
  clientMutationId String   @unique
  createdAt        DateTime @default(now())

  child          Child   @relation("ChildMedications", fields: [childId], references: [id], onDelete: Cascade)
  service        Service @relation("ServiceMedications", fields: [serviceId], references: [id], onDelete: Cascade)
  administeredBy User    @relation("MedicationAdministered", fields: [administeredById], references: [id])
  witnessedBy    User?   @relation("MedicationWitnessed", fields: [witnessedById], references: [id])

  @@index([childId, administeredAt])
  @@index([serviceId, administeredAt])
}

/// Risk assessments for routine / incursion / excursion / special activities. NQS QA2.2.
/// Required (when approved) for excursion ServiceEvents.
model RiskAssessment {
  id             String    @id @default(cuid())
  serviceId      String
  authorId       String
  title          String
  activityType   String // routine | incursion | excursion | special
  date           DateTime  @db.Date
  location       String?
  /// Array<{ hazard, likelihood: 1..5, severity: 1..5, controls }>
  hazards        Json
  approvedById   String?
  approvedAt     DateTime?
  attachmentUrls String[]  @default([])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  service    Service @relation("ServiceRiskAssessments", fields: [serviceId], references: [id], onDelete: Cascade)
  author     User    @relation("RiskAssessments", fields: [authorId], references: [id])
  approvedBy User?   @relation("RiskAssessmentApprovals", fields: [approvedById], references: [id])

  @@index([serviceId, date])
}

/// Hourly-or-on-change educator:child ratio snapshot. NQS QA2.2 + QA4.1.
/// Live ratio for v1 = (rostered-now count) × (currently-in-care count) —
/// true precision (StaffAttendance) is a follow-on spec.
model RatioSnapshot {
  id            String   @id @default(cuid())
  serviceId     String
  date          DateTime @db.Date
  sessionType   String // bsc | asc | vc
  capturedAt    DateTime
  educatorCount Int
  childCount    Int
  ratioText     String // "1:10"
  belowRatio    Boolean
  educatorIds   String[] @default([])
  notes         String?

  service Service @relation("ServiceRatios", fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, date, sessionType])
}

/// Short-lived shift handover notes between coordinators. Auto-expire after 48h.
model ShiftHandover {
  id               String   @id @default(cuid())
  serviceId        String
  authorId         String
  content          String   @db.Text
  mentionedUserIds String[] @default([])
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  service Service @relation("ServiceHandovers", fields: [serviceId], references: [id], onDelete: Cascade)
  author  User    @relation("ShiftHandovers", fields: [authorId], references: [id])

  @@index([serviceId, expiresAt])
}

model ProjectTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks    ProjectTemplateTask[]
  projects Project[]
}

model ProjectTemplateTask {
  id          String          @id @default(cuid())
  templateId  String
  template    ProjectTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  title       String
  description String?         @db.Text
  category    String?
  sortOrder   Int             @default(0)
  defaultDays Int?

  @@index([templateId])
}

model Project {
  id          String           @id @default(cuid())
  name        String
  description String?          @db.Text
  serviceId   String?
  service     Service?         @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  templateId  String?
  template    ProjectTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  ownerId     String?
  owner       User?            @relation("ProjectOwner", fields: [ownerId], references: [id])
  status      ProjectStatus    @default(not_started)
  startDate   DateTime?
  targetDate  DateTime?
  completedAt DateTime?
  deleted     Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  todos       Todo[]
  attachments Attachment[]

  @@index([serviceId])
  @@index([ownerId])
  @@index([status])
}

// ============================================================
// L10 Meetings
// ============================================================

model Meeting {
  id              String        @id @default(cuid())
  title           String
  date            DateTime
  status          MeetingStatus @default(scheduled)
  currentSection  Int           @default(0)
  rating          Float?
  notes           String?       @db.Text
  headlines       String?       @db.Text
  segueNotes      String?       @db.Text
  concludeNotes   String?       @db.Text
  cascadeMessages String?       @db.Text
  serviceIds      String[] // IDs of services scoped to this meeting
  rockIds         String[] // IDs of rocks linked to this meeting
  // 2026-07-05 (draft-first L10): AI-prepared agenda — proposed IDS
  // order, scorecard commentary, rock suggestions. Generated by
  // POST /api/meetings/[id]/prepare or the morning-briefing cron for
  // same-day meetings. Null until prepared; facilitators can regenerate.
  aiAgendaDraft   Json?
  aiAgendaDraftAt DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  createdById     String?
  createdBy       User?         @relation("MeetingCreator", fields: [createdById], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  cascades  CascadeMessage[]  @relation("MeetingCascade")
  attendees MeetingAttendee[] @relation("MeetingAttendees")

  @@index([date])
  @@index([status])
  @@index([createdById])
}

enum AttendeeStatus {
  present
  absent
}

model MeetingAttendee {
  id        String         @id @default(cuid())
  meetingId String
  meeting   Meeting        @relation("MeetingAttendees", fields: [meetingId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation("UserMeetingAttendance", fields: [userId], references: [id], onDelete: Cascade)
  status    AttendeeStatus @default(present)
  rating    Int?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([meetingId, userId])
  @@index([meetingId])
  @@index([userId])
}

// ============================================================
// Documents & Attachments
// ============================================================

enum DocumentCategory {
  program
  policy
  procedure
  template
  guide
  compliance
  financial
  marketing
  hr
  other
}

model Document {
  id           String           @id @default(cuid())
  title        String
  description  String?          @db.Text
  category     DocumentCategory @default(other)
  fileName     String
  fileUrl      String
  fileSize     Int?
  mimeType     String?
  centreId     String?
  centre       Service?         @relation("ServiceDocuments", fields: [centreId], references: [id], onDelete: SetNull)
  uploadedById String?
  uploadedBy   User?            @relation("DocumentUploader", fields: [uploadedById], references: [id])
  // Staff member this document is *about* (e.g. their employment
  // contract or working-with-children check). Distinct from
  // `uploadedById` (the actor) so admin-uploaded HR docs surface on
  // the staff profile. Nullable for org-wide / service-wide docs.
  assignedToId String?
  assignedTo   User?            @relation("DocumentAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  version      Int              @default(1)
  allServices  Boolean          @default(false)
  tags         String[]
  folderId     String?
  folder       DocumentFolder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  deleted      Boolean          @default(false)
  indexed      Boolean          @default(false)
  indexedAt    DateTime?
  indexError   String?
  chunks       DocumentChunk[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([category])
  @@index([centreId])
  @@index([uploadedById])
  @@index([assignedToId])
  @@index([folderId])
  @@index([allServices])
}

model DocumentFolder {
  id        String           @id @default(cuid())
  name      String
  parentId  String?
  parent    DocumentFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  children  DocumentFolder[] @relation("FolderHierarchy")
  documents Document[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([parentId])
}

model DocumentChunk {
  id           String                   @id @default(cuid())
  documentId   String
  document     Document                 @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunkIndex   Int
  content      String                   @db.Text
  heading      String?
  pageNumber   Int?
  tokenCount   Int
  searchVector Unsupported("tsvector")?
  createdAt    DateTime                 @default(now())

  @@unique([documentId, chunkIndex])
  @@index([documentId])
}

model Attachment {
  id           String   @id @default(cuid())
  fileName     String
  fileUrl      String
  fileSize     Int?
  mimeType     String?
  rockId       String?
  rock         Rock?    @relation(fields: [rockId], references: [id], onDelete: Cascade)
  issueId      String?
  issue        Issue?   @relation(fields: [issueId], references: [id], onDelete: Cascade)
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedById String?
  uploadedBy   User?    @relation("AttachmentUploader", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([rockId])
  @@index([issueId])
  @@index([projectId])
}

// ============================================================
// Financial & Performance Data
// ============================================================

enum FinancialPeriodType {
  weekly
  monthly
  quarterly
}

model FinancialPeriod {
  id          String              @id @default(cuid())
  serviceId   String
  service     Service             @relation("ServiceFinancials", fields: [serviceId], references: [id], onDelete: Cascade)
  periodType  FinancialPeriodType
  periodStart DateTime
  periodEnd   DateTime

  // Revenue
  bscRevenue   Float @default(0)
  ascRevenue   Float @default(0)
  vcRevenue    Float @default(0)
  otherRevenue Float @default(0)
  totalRevenue Float @default(0)

  // Costs
  staffCosts    Float @default(0)
  foodCosts     Float @default(0)
  suppliesCosts Float @default(0)
  rentCosts     Float @default(0)
  adminCosts    Float @default(0)
  otherCosts    Float @default(0)
  totalCosts    Float @default(0)

  // Derived
  grossProfit Float @default(0)
  margin      Float @default(0)

  // Budget
  budgetRevenue Float?
  budgetCosts   Float?

  // Attendance
  bscEnrolments Int @default(0)
  ascEnrolments Int @default(0)
  bscAttendance Int @default(0)
  ascAttendance Int @default(0)
  vcAttendance  Int @default(0)

  // Data source
  dataSource   String    @default("manual")
  xeroSyncedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serviceId, periodType, periodStart])
  @@index([serviceId])
  @@index([periodStart])
  @@index([periodType])
}

// ─── Scenario Modelling ──────────────────────────────────────────────────────

model Scenario {
  id          String   @id @default(cuid())
  name        String
  description String?
  inputs      Json
  outputs     Json
  createdById String
  createdBy   User     @relation("ScenarioCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, createdById]) // prevent duplicate scenario names per user
  @@index([createdById])
}

model CentreMetrics {
  id         String   @id @default(cuid())
  serviceId  String
  service    Service  @relation("ServiceMetrics", fields: [serviceId], references: [id], onDelete: Cascade)
  recordedAt DateTime @default(now())

  // Occupancy
  bscCapacity  Int   @default(0)
  ascCapacity  Int   @default(0)
  bscOccupancy Float @default(0)
  ascOccupancy Float @default(0)

  // Staff
  totalEducators    Int   @default(0)
  educatorsTurnover Float @default(0)
  ratioCompliance   Float @default(100)

  // Quality
  parentNps      Float?
  incidentCount  Int    @default(0)
  complaintCount Int    @default(0)

  // Compliance
  wwccCompliance     Float   @default(100)
  firstAidCompliance Float   @default(100)
  overallCompliance  Float   @default(100)
  nqsRating          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([serviceId])
  @@index([recordedAt])
}

// ============================================================
// Support Ticket System (WhatsApp Integration)
// ============================================================

enum TicketStatus {
  new
  open
  pending_parent
  resolved
  closed
}

enum TicketPriority {
  urgent
  high
  normal
  low
}

enum MessageDirection {
  inbound
  outbound
}

enum MessageDeliveryStatus {
  sent
  delivered
  read
  failed
}

model WhatsAppContact {
  id          String   @id @default(cuid())
  waId        String   @unique
  phoneNumber String
  name        String?
  parentName  String?
  childName   String?
  serviceId   String?
  service     Service? @relation("ServiceContacts", fields: [serviceId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tickets SupportTicket[]

  @@index([waId])
  @@index([serviceId])
}

model SupportTicket {
  id              String          @id @default(cuid())
  ticketNumber    Int             @unique @default(autoincrement())
  contactId       String
  contact         WhatsAppContact @relation(fields: [contactId], references: [id])
  parentContactId String?
  parentContact   CentreContact?  @relation("ParentTickets", fields: [parentContactId], references: [id], onDelete: SetNull)
  source          String? // "whatsapp" | "portal" | "email" | null (legacy)
  subject         String?
  status          TicketStatus    @default(new)
  priority        TicketPriority  @default(normal)
  assignedToId    String?
  assignedTo      User?           @relation("TicketAssignee", fields: [assignedToId], references: [id])
  serviceId       String?
  service         Service?        @relation("ServiceTickets", fields: [serviceId], references: [id], onDelete: SetNull)
  firstResponseAt DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?
  lastInboundAt   DateTime?
  tags            String[]
  deleted         Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  messages TicketMessage[]
  emails   TicketEmail[]   @relation("TicketEmails")
  aiDrafts AiTaskDraft[]   @relation("TicketAiDraft")

  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([contactId])
  @@index([serviceId])
  @@index([createdAt])
}

model TicketEmail {
  id          String        @id @default(cuid())
  ticketId    String
  ticket      SupportTicket @relation("TicketEmails", fields: [ticketId], references: [id], onDelete: Cascade)
  messageId   String? // Email message-id header for dedup
  from        String
  to          String
  subject     String
  bodyPreview String        @db.Text
  receivedAt  DateTime
  linkedBy    String? // "auto" or userId who manually linked
  createdAt   DateTime      @default(now())

  @@unique([messageId])
  @@index([ticketId])
  @@index([receivedAt])
}

model TicketMessage {
  id             String                @id @default(cuid())
  ticketId       String
  ticket         SupportTicket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  waMessageId    String?               @unique
  direction      MessageDirection
  senderName     String?
  agentId        String?
  agent          User?                 @relation("MessageSender", fields: [agentId], references: [id])
  body           String                @db.Text
  mediaUrl       String?
  mediaType      String?
  deliveryStatus MessageDeliveryStatus @default(sent)
  deliveredAt    DateTime?
  readAt         DateTime?
  createdAt      DateTime              @default(now())

  @@index([ticketId])
  @@index([waMessageId])
}

model ResponseTemplate {
  id        String   @id @default(cuid())
  title     String
  body      String   @db.Text
  category  String?
  shortcut  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// Internal Communication
// ============================================================

enum AnnouncementAudience {
  all
  owners_admins
  managers
  custom
}

enum AnnouncementPriority {
  normal
  important
  urgent
}

model Announcement {
  id          String               @id @default(cuid())
  title       String
  body        String               @db.Text
  authorId    String?
  author      User?                @relation("AnnouncementAuthor", fields: [authorId], references: [id])
  audience    AnnouncementAudience @default(all)
  priority    AnnouncementPriority @default(normal)
  pinned      Boolean              @default(false)
  serviceId   String?
  service     Service?             @relation("ServiceAnnouncements", fields: [serviceId], references: [id], onDelete: SetNull)
  publishedAt DateTime?
  expiresAt   DateTime?
