// ============================================================
// Compliance Calendar
// ============================================================

enum CertificateType {
  wwcc
  first_aid
  anaphylaxis
  asthma
  cpr
  police_check
  annual_review
  child_protection
  geccko
  food_safety
  food_handler
  // Added 2026-06-01 per HR audit:
  // - Annual mandatory-reporter refresher (NSW Children and Young
  //   Persons (Care and Protection) Act 1998 + state equivalents);
  //   OSHC educators are mandatory reporters and FWC / DCJ expect
  //   evidence of yearly training as an aggravating-factor mitigator.
  mandatory_reporter_training
  // - Annual Child Safe Code of Conduct acknowledgement under the
  //   National Principles for Child Safe Organisations (also
  //   Victorian Child Safe Standards 2022, NSW Office of the
  //   Children's Guardian, etc).
  child_safe_code_of_conduct
  other
}

model ComplianceCertificate {
  id                    String                 @id @default(cuid())
  // 2026-06-05: serviceId relaxed to nullable. Personal certs
  // (WWCC, First Aid, Child Safe Code of Conduct, etc.) belong to
  // the individual staff member — they aren't tied to a specific
  // centre. Pre-2026-06 the column was NOT NULL and the upload UI
  // forced session.user.serviceId, which 400'd "Service ID is
  // required" for any staff member without a service assigned.
  // userId is now the only required identity for a personal cert;
  // serviceId is optional and only used by service-level certs.
  serviceId             String?
  service               Service?               @relation("ServiceCertificates", fields: [serviceId], references: [id], onDelete: Cascade)
  userId                String?
  user                  User?                  @relation("UserCertificates", fields: [userId], references: [id], onDelete: SetNull)
  type                  CertificateType
  label                 String?
  issueDate             DateTime
  // Nullable so certs that legitimately never expire (e.g. annual policy
  // ack, induction confirmation) can be modelled as `expiryDate: null`
  // instead of a sentinel far-future date. The expiring-soon warning
  // system treats null as "valid forever".
  expiryDate            DateTime?
  notes                 String?                @db.Text
  fileUrl               String?
  fileName              String?
  alertDays             Int                    @default(30)
  acknowledged          Boolean                @default(false)
  /// Renewal chain — points at the prior certificate this one renews.
  /// `previous.supersededAt` gets set when this cert is created via the renew flow.
  previousCertificateId String?                @unique
  previous              ComplianceCertificate? @relation("CertificateRenewal", fields: [previousCertificateId], references: [id])
  renewedBy             ComplianceCertificate? @relation("CertificateRenewal")
  /// Set on the OLD cert when a successor (renewal) is created.
  supersededAt          DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  alerts ComplianceCertificateAlert[] @relation("CertificateAlerts")

  @@index([serviceId])
  @@index([userId])
  @@index([expiryDate])
}

/// Dedup tracking for compliance expiry alerts. One row per (cert, threshold).
/// Ensures the cron doesn't send duplicate emails on re-runs or retries.
model ComplianceCertificateAlert {
  id            String                @id @default(cuid())
  certificateId String
  certificate   ComplianceCertificate @relation("CertificateAlerts", fields: [certificateId], references: [id], onDelete: Cascade)
  threshold     Int // 30 | 14 | 7 | 0 — which cadence milestone
  sentAt        DateTime              @default(now())
  channels      String[] // "email" | "in_app"

  @@unique([certificateId, threshold])
  @@index([certificateId])
  @@index([sentAt])
}

