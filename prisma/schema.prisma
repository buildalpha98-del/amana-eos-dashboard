// ============================================================
// Services (OSHC Centres) & Projects
// ============================================================

model Service {
  id                   String        @id @default(cuid())
  name                 String
  code                 String        @unique
  address              String?
  suburb               String?
  state                String?
  postcode             String?
  phone                String?
  email                String?
  status               ServiceStatus @default(active)
  managerId            String?
  manager              User?         @relation("ServiceManager", fields: [managerId], references: [id])
  capacity             Int?
  operatingDays        String?
  notes                String?       @db.Text
  bscDailyRate         Float?
  ascDailyRate         Float?
  vcDailyRate          Float?
  bscCasualRate        Float         @default(0)
  ascCasualRate        Float         @default(0)
  bscGroceryRate       Float         @default(0.80)
  ascGroceryRate       Float         @default(1.20)
  vcGroceryRate        Float         @default(4.50)
  xeroTrackingOptionId String?
  ownaServiceId        String? // OWNA's internal service ID
  ownaLocationId       String? // OWNA's location reference
  ownaSyncedAt         DateTime? // Last successful OWNA sync

  // ── Marketing / Growth Fields (Sprint 0) ───────────────────
  schoolPopulation         Int?       // Total students at the partner school
  ascTarget                Int?       // Target number of ASC children
  bscTarget                Int?       // Target number of BSC children
  weeklyAttendanceTarget   Int?       // Target weekly attendances (BSC + ASC combined)
  parentSegment            String?    // Primary parent segment: "need", "want", or "mixed"
  parentDriver             String?    // Primary driver: "homework", "quran", "enrichment", "working_parents", "traffic"
  launchDate               DateTime?  // Date service launched (for launch-phase tracking)
  launchPhase              String?    // Phase: "pre_launch", "launch", "ramp_up", "mature"

  // ── School Partnership / Contract ──────────────────────────
  contractStartDate        DateTime?
  contractEndDate          DateTime?
  licenceFeeAnnual         Float?     // Annual licence fee paid to school
  schoolPrincipalName      String?
  schoolPrincipalEmail     String?
  schoolBusinessManagerName  String?
  schoolBusinessManagerEmail String?
  lastPrincipalVisit       DateTime?
  buildAlphaKidsActive     Boolean    @default(false)

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  todos                 Todo[]
  projects              Project[]
  issues                Issue[]                        @relation("ServiceIssues")
  rocks                 Rock[]                         @relation("ServiceRocks")
  measurables           Measurable[]                   @relation("ServiceMeasurables")
  financials            FinancialPeriod[]              @relation("ServiceFinancials")
  metrics               CentreMetrics[]                @relation("ServiceMetrics")
  documents             Document[]                     @relation("ServiceDocuments")
  tickets               SupportTicket[]                @relation("ServiceTickets")
  whatsappContacts      WhatsAppContact[]              @relation("ServiceContacts")
  announcements         Announcement[]                 @relation("ServiceAnnouncements")
  healthScores          HealthScore[]                  @relation("ServiceHealthScores")
  staffMembers          User[]                         @relation("ServiceStaff")
  onboardingPacks       OnboardingPack[]               @relation("ServiceOnboardingPacks")
  lmsCourses            LMSCourse[]                    @relation("ServiceCourses")
  certificates          ComplianceCertificate[]        @relation("ServiceCertificates")
  attendance            DailyAttendance[]              @relation("ServiceAttendance")
  budgetItems           BudgetItem[]                   @relation("ServiceBudgetItems")
  programActivities     ProgramActivity[]              @relation("ServicePrograms")
  menuWeeks             MenuWeek[]                     @relation("ServiceMenus")
  todoTemplates         TodoTemplate[]                 @relation("ServiceTemplates")
  marketingPosts        MarketingPostService[]         @relation("ServiceMarketingPosts")
  marketingCampaigns    MarketingCampaignService[]     @relation("ServiceMarketingCampaigns")
  marketingTasks        MarketingTask[]                @relation("ServiceMarketingTasks")
  socialConnections     SocialConnection[]             @relation("ServiceSocialConnections")
  activationAssignments CampaignActivationAssignment[] @relation("ServiceActivations")

  // ── HR Relations ─────────────────────────────────────────────
  leaveRequests    LeaveRequest[]    @relation("ServiceLeaveRequests")
  timesheets       Timesheet[]       @relation("ServiceTimesheets")
  offboardingPacks OffboardingPack[] @relation("ServiceOffboardingPacks")

  // ── CRM Relations ──────────────────────────────────────────
  leads Lead[] @relation("LeadService")

  // ── Delivery Relations ────────────────────────────────────
  centreContacts CentreContact[] @relation("ServiceContacts_Email")
  nurtureSteps   ParentNurtureStep[] @relation("ServiceNurtureSteps")

  // ── Holiday Quest Relations ──────────────────────────────
  holidayQuests HolidayQuestDay[] @relation("ServiceHolidayQuest")

  // ── OWNA Integration Relations ──────────────────────────
  bookingForecasts        BookingForecast[]       @relation("ServiceBookings")
  rosterShifts            RosterShift[]           @relation("ServiceRosterShifts")
  conversionOpportunities ConversionOpportunity[] @relation("ServiceConversions")

  // ── Compliance Audit Relations ─────────────────────────
  audits AuditInstance[] @relation("ServiceAudits")

  // ── Marketing Operations Relations ─────────────────────
  schoolComms          SchoolComm[]          @relation("ServiceSchoolComms")
  photoComplianceLogs  PhotoComplianceLog[]  @relation("ServicePhotoCompliance")
  npsResponses         NpsSurveyResponse[]   @relation("ServiceNpsResponses")
  termCalendarEntries  TermCalendarEntry[]   @relation("ServiceTermCalendar")

  // ── Parent Enquiry Pipeline ──────────────────────────
  enquiries            ParentEnquiry[]
  referrals            Referral[]

  // ── Recruitment Pipeline ───────────────────────────
  vacancies            RecruitmentVacancy[] @relation("ServiceVacancies")
  pulseSurveys         StaffPulseSurvey[]   @relation("ServicePulseSurveys")

  // ── Billing ───────────────────────────────────────────
  overdueFees          OverdueFeeRecord[]   @relation("ServiceOverdueFees")

  // ── Operations ────────────────────────────────────────
  qip                  QualityImprovementPlan? @relation("ServiceQIP")
  incidents            IncidentRecord[]        @relation("ServiceIncidents")

  // ── Programming & Quality ──────────────────────────
  childInterests       ChildInterest[]         @relation("ServiceInterests")

  // ── Parent Experience ──────────────────────────────
  quickFeedback        QuickFeedback[]         @relation("ServiceQuickFeedback")
  exitSurveys          ExitSurvey[]            @relation("ServiceExitSurveys")

  // ── Cowork Reports ──────────────────────────────
  coworkReports        CoworkReport[]          @relation("CoworkReportService")

  // ── Daily Checklists ──────────────────────────────
  dailyChecklists      DailyChecklist[]

  // ── Partnerships ──────────────────────────────────
  schoolRelationship   SchoolRelationship?

  @@index([status])
  @@index([managerId])
}

model ProjectTemplate {
