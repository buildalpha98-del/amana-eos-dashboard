model MarketingCampaign {
  id           String                  @id @default(cuid())
  name         String
  type         MarketingCampaignType   @default(campaign)
  status       MarketingCampaignStatus @default(draft)
  startDate    DateTime?
  endDate      DateTime?
  platforms    MarketingPlatform[]
  goal         String?                 @db.Text
  notes        String?                 @db.Text
  designLink   String?
  budget       Float?
  location     String?
  deliverables String?                 @db.Text
  deleted      Boolean                 @default(false)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  posts                 MarketingPost[]
  comments              MarketingComment[]
  services              MarketingCampaignService[]
  tasks                 MarketingTask[]
  activationAssignments CampaignActivationAssignment[]
  termCalendarEntries   TermCalendarEntry[]            @relation("TermCalendarCampaign")
  centreAvatarLogs      CentreAvatarCampaignLog[]      @relation("MarketingCampaignCentreAvatarLog")

  @@index([status])
  @@index([startDate])
}

model MarketingPost {
  id                   String                        @id @default(cuid())
  title                String
  platform             MarketingPlatform
  status               MarketingPostStatus           @default(draft)
  scheduledDate        DateTime?
  content              String?                       @db.Text
  notes                String?                       @db.Text
  designLink           String?
  canvaDesignId        String? // Canva design ID (e.g., "DAGoPem3X54")
  canvaDesignUrl       String? // Direct edit URL in Canva
  canvaExportUrl       String? // Exported image URL for publishing
  format               MarketingPostFormat?
  pillar               String?
  assigneeId           String?
  assignee             User?                         @relation("MarketingPostAssignee", fields: [assigneeId], references: [id])
  campaignId           String?
  campaign             MarketingCampaign?            @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  likes                Int                           @default(0)
  comments             Int                           @default(0)
  shares               Int                           @default(0)
  reach                Int                           @default(0)
  recurring            MarketingRecurrence           @default(none)
  recurringParentId    String?
  recurringParent      MarketingPost?                @relation("RecurringPosts", fields: [recurringParentId], references: [id])
  recurringChildren    MarketingPost[]               @relation("RecurringPosts")
  clonedFromId         String?
  clonedFrom           MarketingPost?                @relation("PostClones", fields: [clonedFromId], references: [id])
  clones               MarketingPost[]               @relation("PostClones")
  services             MarketingPostService[]
  externalPostId       String?
  externalUrl          String?
  engagementSyncedAt   DateTime?
  deliveryLogId        String?
  approvedById         String?
  approvedBy           User?                         @relation("MarketingPostApprover", fields: [approvedById], references: [id])
  approvedAt           DateTime?
  rejectionReason      String?                       @db.Text
  deleted              Boolean                       @default(false)
  recapForActivationId String?
  recapForActivation   CampaignActivationAssignment? @relation("MarketingPostRecapFor", fields: [recapForActivationId], references: [id], onDelete: SetNull)
  createdAt            DateTime                      @default(now())
