// ============================================================
// AI Infrastructure
// ============================================================

model AiPromptTemplate {
  id             String   @id @default(cuid())
  slug           String   @unique // e.g. "marketing/post-writer"
  name           String
  description    String?  @db.Text
  model          String   @default("claude-sonnet-4-5-20250514")
  maxTokens      Int      @default(1024)
  promptTemplate String   @db.Text // supports {{variable}} placeholders
  variables      Json     @default("[]") // array of expected variable names
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AiUsage {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("AiUsageLogs", fields: [userId], references: [id], onDelete: Cascade)
  templateSlug String? // null for freeform assistant chat
  model        String
  inputTokens  Int
  outputTokens Int
  durationMs   Int
  section      String // dashboard section e.g. "marketing", "compliance"
  metadata     Json? // extra context (serviceId, postId, etc.)
  monthBudget  Float? // reserved for future budget enforcement
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([templateSlug])
  @@index([section])
  @@index([createdAt])
}

model AiTaskDraft {
  id String @id @default(cuid())

  // Polymorphic source — one of these will be set
  todoId          String?
  todo            Todo?          @relation("TodoAiDraft", fields: [todoId], references: [id], onDelete: Cascade)
  marketingTaskId String?
  marketingTask   MarketingTask? @relation("MarketingTaskAiDraft", fields: [marketingTaskId], references: [id], onDelete: Cascade)
  coworkTodoId    String?
  coworkTodo      CoworkTodo?    @relation("CoworkTodoAiDraft", fields: [coworkTodoId], references: [id], onDelete: Cascade)
  ticketId        String?
  ticket          SupportTicket? @relation("TicketAiDraft", fields: [ticketId], references: [id], onDelete: Cascade)
  issueId         String?
  issue           Issue?         @relation("IssueAiDraft", fields: [issueId], references: [id], onDelete: Cascade)

  taskType String // "communication" | "research" | "document" | "admin"
  title    String // Human-readable draft title
  content  String @db.Text // The AI-generated draft content (markdown)
  metadata Json? // Extra context (email recipients, template used, etc.)

  /// Discriminator for where this draft came from.
  /// e.g. "todo" | "marketing_task" | "cowork_todo" | "ticket" | "issue" |
  /// "reflection" | "observation" | "parent_reply" | "incident" | "newsletter".
  /// Redundant with the *Id foreign keys above for the first five, but
  /// mandatory once we add polymorphic draft sources (reflections etc.) that
  /// don't have an *Id column here.
  source   String  @default("todo")
  /// Optional free-form target ID for non-FK sources (e.g. a reflection ID).
  targetId String?

  status       String    @default("ready") // "ready" | "accepted" | "edited" | "dismissed"
  reviewedAt   DateTime?
  reviewedById String?
  reviewedBy   User?     @relation("DraftReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  tokensUsed Int    @default(0)
  model      String @default("claude-haiku-3-5-20241022")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([todoId])
  @@index([marketingTaskId])
  @@index([coworkTodoId])
  @@index([ticketId])
  @@index([issueId])
  @@index([status])
  @@index([createdAt])
}

/// Cached output for AI generations keyed by (kind, inputHash). Used by the
/// hybrid AI provider (anthropic + groq) to avoid re-generating identical
/// prompts within a TTL window. Pulled from on cache hit; written on miss.
///
/// `kind` examples: "centre_avatar.parent_avatar".
/// `inputHash` is a sha256 of the canonicalised input payload.
model AiGenerationCache {
  id            String   @id @default(cuid())
  kind          String
  inputHash     String
  output        Json
  provider      String // "anthropic" | "groq"
  modelId       String
  costUsd       Float    @default(0)
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  generatedById String?
  generatedBy   User?    @relation("AiGenerationCacheUser", fields: [generatedById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  expiresAt     DateTime

  @@unique([kind, inputHash])
  @@index([kind])
  @@index([expiresAt])
}

