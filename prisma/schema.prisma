  @@index([priority])
  @@index([status])
  @@index([ownerId])
  @@index([serviceId])
  @@index([raisedById])
  @@index([status, serviceId])
  @@index([status, priority])
  @@index([ownerId, status])
  @@index([category])
  @@index([category, status])
}

model Scorecard {
  id        String   @id @default(cuid())
  title     String
  // 2026-05-12 (Bucket O Stage 1): scorecards are now first-class
  // entities with an owner + invited members. Existing rows backfilled
  // to the first owner-role user. New scorecards record their creator
  // as owner; the owner controls renaming + membership.
  ownerId   String
  owner     User     @relation("ScorecardOwner", fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  measurables Measurable[]
  members     ScorecardMember[]

  @@index([ownerId])
}

/// Per-scorecard membership. Members can view the scorecard and own
/// measurables within it. The scorecard's `owner` is implicitly also
/// a member but not stored here — permission checks add the owner
/// in code. ON DELETE CASCADE on both FKs so deleting a scorecard or
/// user cleans up memberships.
model ScorecardMember {
  id          String    @id @default(cuid())
  scorecardId String
  scorecard   Scorecard @relation(fields: [scorecardId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation("ScorecardMembership", fields: [userId], references: [id], onDelete: Cascade)
  addedAt     DateTime  @default(now())

  @@unique([scorecardId, userId])
  @@index([userId])
  @@index([scorecardId])
}

model Measurable {
  id            String              @id @default(cuid())
  title         String
  description   String?
  ownerId       String?
  owner         User?               @relation("MeasurableOwner", fields: [ownerId], references: [id])
  goalValue     Float
  goalDirection GoalDirection       @default(above)
  unit          String?
  frequency     MeasurableFrequency @default(weekly)
  sortOrder     Int                 @default(0)
  rockId        String?
  rock          Rock?               @relation(fields: [rockId], references: [id], onDelete: SetNull)
  scorecardId   String
  scorecard     Scorecard           @relation(fields: [scorecardId], references: [id], onDelete: Cascade)
  serviceId     String?
  service       Service?            @relation("ServiceMeasurables", fields: [serviceId], references: [id], onDelete: SetNull)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  entries MeasurableEntry[]

  @@index([ownerId])
  @@index([scorecardId])
  @@index([serviceId])
}

model MeasurableEntry {
  id           String     @id @default(cuid())
  measurableId String
  measurable   Measurable @relation(fields: [measurableId], references: [id], onDelete: Cascade)
  weekOf       DateTime
