// ============================================================
// L10 Meetings
// ============================================================

model Meeting {
  id              String        @id @default(cuid())
  title           String
  date            DateTime
  status          MeetingStatus @default(scheduled)
  currentSection  Int           @default(0)
  rating          Float?
  notes           String?       @db.Text
  headlines       String?       @db.Text
  segueNotes      String?       @db.Text
  concludeNotes   String?       @db.Text
  cascadeMessages String?       @db.Text
  serviceIds      String[] // IDs of services scoped to this meeting
  rockIds         String[] // IDs of rocks linked to this meeting
  startedAt       DateTime?
  completedAt     DateTime?
  createdById     String?
  createdBy       User?         @relation("MeetingCreator", fields: [createdById], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  cascades CascadeMessage[] @relation("MeetingCascade")
  attendees     MeetingAttendee[] @relation("MeetingAttendees")

  @@index([date])
  @@index([status])
  @@index([createdById])
}

enum AttendeeStatus {
  present
  absent
}

model MeetingAttendee {
  id        String         @id @default(cuid())
  meetingId String
  meeting   Meeting        @relation("MeetingAttendees", fields: [meetingId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation("UserMeetingAttendance", fields: [userId], references: [id], onDelete: Cascade)
  status    AttendeeStatus @default(present)
  rating    Int?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([meetingId, userId])
  @@index([meetingId])
  @@index([userId])
}

// ============================================================
// Documents & Attachments
// ============================================================

enum DocumentCategory {
  program
  policy
  procedure
  template
  guide
  compliance
  financial
  marketing
  hr
  other
}

model Document {
  id           String           @id @default(cuid())
  title        String
  description  String?          @db.Text
  category     DocumentCategory @default(other)
  fileName     String
  fileUrl      String
  fileSize     Int?
  mimeType     String?
  centreId     String?
  centre       Service?         @relation("ServiceDocuments", fields: [centreId], references: [id], onDelete: SetNull)
  uploadedById String?
  uploadedBy   User?            @relation("DocumentUploader", fields: [uploadedById], references: [id])
  version      Int              @default(1)
  tags         String[]
  folderId     String?
  folder       DocumentFolder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  deleted      Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([category])
  @@index([centreId])
  @@index([uploadedById])
  @@index([folderId])
}

model DocumentFolder {
  id        String           @id @default(cuid())
  name      String
  parentId  String?
  parent    DocumentFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  children  DocumentFolder[] @relation("FolderHierarchy")
  documents Document[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([parentId])
}

model Attachment {
  id           String   @id @default(cuid())
  fileName     String
  fileUrl      String
  fileSize     Int?
  mimeType     String?
  rockId       String?
  rock         Rock?    @relation(fields: [rockId], references: [id], onDelete: Cascade)
  issueId      String?
  issue        Issue?   @relation(fields: [issueId], references: [id], onDelete: Cascade)
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedById String?
  uploadedBy   User?    @relation("AttachmentUploader", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([rockId])
  @@index([issueId])
  @@index([projectId])
}

// ============================================================
// Financial & Performance Data
// ============================================================

enum FinancialPeriodType {
  weekly
  monthly
  quarterly
}

model FinancialPeriod {
  id          String              @id @default(cuid())
  serviceId   String
  service     Service             @relation("ServiceFinancials", fields: [serviceId], references: [id], onDelete: Cascade)
  periodType  FinancialPeriodType
  periodStart DateTime
  periodEnd   DateTime

  // Revenue
  bscRevenue   Float @default(0)
  ascRevenue   Float @default(0)
  vcRevenue    Float @default(0)
  otherRevenue Float @default(0)
  totalRevenue Float @default(0)

  // Costs
  staffCosts    Float @default(0)
  foodCosts     Float @default(0)
  suppliesCosts Float @default(0)
  rentCosts     Float @default(0)
  adminCosts    Float @default(0)
  otherCosts    Float @default(0)
  totalCosts    Float @default(0)

  // Derived
  grossProfit Float @default(0)
  margin      Float @default(0)

  // Budget
  budgetRevenue Float?
  budgetCosts   Float?

  // Attendance
  bscEnrolments Int @default(0)
  ascEnrolments Int @default(0)
  bscAttendance Int @default(0)
  ascAttendance Int @default(0)
  vcAttendance  Int @default(0)

  // Data source
  dataSource   String    @default("manual")
  xeroSyncedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serviceId, periodType, periodStart])
  @@index([serviceId])
  @@index([periodStart])
  @@index([periodType])
}

// ─── Scenario Modelling ──────────────────────────────────────────────────────

model Scenario {
  id          String   @id @default(cuid())
  name        String
  description String?
  inputs      Json
  outputs     Json
  createdById String
  createdBy   User     @relation("ScenarioCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdById])
}

model CentreMetrics {
  id         String   @id @default(cuid())
  serviceId  String
  service    Service  @relation("ServiceMetrics", fields: [serviceId], references: [id], onDelete: Cascade)
  recordedAt DateTime @default(now())

  // Occupancy
  bscCapacity  Int   @default(0)
  ascCapacity  Int   @default(0)
  bscOccupancy Float @default(0)
  ascOccupancy Float @default(0)

  // Staff
  totalEducators    Int   @default(0)
  educatorsTurnover Float @default(0)
  ratioCompliance   Float @default(100)

  // Quality
  parentNps      Float?
  incidentCount  Int    @default(0)
  complaintCount Int    @default(0)

  // Compliance
  wwccCompliance     Float   @default(100)
  firstAidCompliance Float   @default(100)
  overallCompliance  Float   @default(100)
  nqsRating          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([serviceId])
  @@index([recordedAt])
}

// ============================================================
// Support Ticket System (WhatsApp Integration)
// ============================================================

enum TicketStatus {
  new
  open
  pending_parent
  resolved
  closed
}

enum TicketPriority {
  urgent
  high
  normal
  low
}

enum MessageDirection {
  inbound
  outbound
}

enum MessageDeliveryStatus {
  sent
  delivered
  read
  failed
}

model WhatsAppContact {
  id          String   @id @default(cuid())
  waId        String   @unique
  phoneNumber String
  name        String?
  parentName  String?
  childName   String?
  serviceId   String?
  service     Service? @relation("ServiceContacts", fields: [serviceId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tickets SupportTicket[]

  @@index([waId])
  @@index([serviceId])
}

model SupportTicket {
  id              String          @id @default(cuid())
  ticketNumber    Int             @unique @default(autoincrement())
  contactId       String
  contact         WhatsAppContact @relation(fields: [contactId], references: [id])
  subject         String?
  status          TicketStatus    @default(new)
  priority        TicketPriority  @default(normal)
  assignedToId    String?
  assignedTo      User?           @relation("TicketAssignee", fields: [assignedToId], references: [id])
  serviceId       String?
  service         Service?        @relation("ServiceTickets", fields: [serviceId], references: [id], onDelete: SetNull)
  firstResponseAt DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?
  lastInboundAt   DateTime?
  tags            String[]
  deleted         Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  messages TicketMessage[]

  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([contactId])
  @@index([serviceId])
  @@index([createdAt])
}

model TicketMessage {
  id             String                @id @default(cuid())
  ticketId       String
  ticket         SupportTicket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  waMessageId    String?               @unique
  direction      MessageDirection
  senderName     String?
  agentId        String?
  agent          User?                 @relation("MessageSender", fields: [agentId], references: [id])
  body           String                @db.Text
  mediaUrl       String?
  mediaType      String?
  deliveryStatus MessageDeliveryStatus @default(sent)
  deliveredAt    DateTime?
  readAt         DateTime?
  createdAt      DateTime              @default(now())

  @@index([ticketId])
  @@index([waMessageId])
}

model ResponseTemplate {
  id        String   @id @default(cuid())
  title     String
  body      String   @db.Text
  category  String?
  shortcut  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// Internal Communication
// ============================================================

enum AnnouncementAudience {
  all
  owners_admins
  managers
  custom
}

enum AnnouncementPriority {
  normal
  important
  urgent
}

model Announcement {
  id          String               @id @default(cuid())
  title       String
  body        String               @db.Text
  authorId    String?
  author      User?                @relation("AnnouncementAuthor", fields: [authorId], references: [id])
  audience    AnnouncementAudience @default(all)
  priority    AnnouncementPriority @default(normal)
  pinned      Boolean              @default(false)
  serviceId   String?
  service     Service?             @relation("ServiceAnnouncements", fields: [serviceId], references: [id], onDelete: SetNull)
  publishedAt DateTime?
  expiresAt   DateTime?
  deleted     Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  readReceipts AnnouncementRead[]

  @@index([audience])
  @@index([pinned])
  @@index([publishedAt])
  @@index([serviceId])
}

model AnnouncementRead {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("AnnouncementReader", fields: [userId], references: [id])
  readAt         DateTime     @default(now())

  @@unique([announcementId, userId])
  @@index([announcementId])
  @@index([userId])
}

model CascadeMessage {
  id          String   @id @default(cuid())
  meetingId   String
  meeting     Meeting  @relation("MeetingCascade", fields: [meetingId], references: [id], onDelete: Cascade)
  message     String   @db.Text
  publishedAt DateTime @default(now())
  deleted     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  acknowledgments CascadeAcknowledgment[]

  @@index([meetingId])
  @@index([publishedAt])
}

model CascadeAcknowledgment {
  id               String         @id @default(cuid())
  cascadeMessageId String
  cascadeMessage   CascadeMessage @relation(fields: [cascadeMessageId], references: [id], onDelete: Cascade)
  userId           String
  user             User           @relation("CascadeAcknowledger", fields: [userId], references: [id])
  acknowledgedAt   DateTime       @default(now())

  @@unique([cascadeMessageId, userId])
  @@index([cascadeMessageId])
  @@index([userId])
}

model WeeklyPulse {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("PulseAuthor", fields: [userId], references: [id])
  weekOf      DateTime
  wins        String?   @db.Text
  priorities  String?   @db.Text
  blockers    String?   @db.Text
  mood        Int? // 1-5 scale
  notes       String?   @db.Text
  submittedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, weekOf])
  @@index([userId])
  @@index([weekOf])
}

model NotificationDismissal {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  notificationId String
  dismissedAt    DateTime @default(now())

  @@unique([userId, notificationId])
  @@index([userId])
}

model OrgSettings {
  id           String   @id @default("singleton")
  name         String   @default("Amana OSHC")
  primaryColor String   @default("#004E64")
  accentColor  String   @default("#FECE00")
  updatedAt    DateTime @updatedAt
}

// ============================================================
// Xero Integration
// ============================================================

enum XeroConnectionStatus {
  connected
  disconnected
  error
}

model XeroConnection {
  id                     String               @id @default("singleton")
  status                 XeroConnectionStatus @default(disconnected)
  tenantId               String?
  tenantName             String?
  accessToken            String?              @db.Text
  refreshToken           String?              @db.Text
  tokenExpiresAt         DateTime?
  scopes                 String?
  trackingCategoryId     String?
  lastSyncAt             DateTime?
  lastSyncStatus         String?
  lastSyncError          String?              @db.Text
  connectedById          String?
  syncedFinancialPeriods Int                  @default(0)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  accountMappings XeroAccountMapping[]
}

// ============================================================
// Health Score (Centre Health Score - Phase 2)
// ============================================================

model HealthScore {
  id          String   @id @default(cuid())
  serviceId   String
  service     Service  @relation("ServiceHealthScores", fields: [serviceId], references: [id], onDelete: Cascade)
  periodStart DateTime
  periodType  String   @default("monthly")

  overallScore Float
  trend        String @default("stable") // improving | declining | stable

  financialScore    Float @default(0)
  operationalScore  Float @default(0)
  complianceScore   Float @default(0)
  satisfactionScore Float @default(0)
  teamCultureScore  Float @default(0)

  financialBreakdown    Json?
  operationalBreakdown  Json?
  complianceBreakdown   Json?
  satisfactionBreakdown Json?
  teamCultureBreakdown  Json?

  computedAt DateTime @default(now())

  @@unique([serviceId, periodType, periodStart])
  @@index([serviceId])
  @@index([periodStart])
}

model XeroAccountMapping {
  id               String         @id @default(cuid())
  xeroConnectionId String
  xeroConnection   XeroConnection @relation(fields: [xeroConnectionId], references: [id], onDelete: Cascade)
  xeroAccountCode  String
  xeroAccountName  String
  xeroAccountType  String
  localCategory    String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([xeroConnectionId, xeroAccountCode])
  @@index([xeroConnectionId])
}

// ============================================================
// Staff Onboarding
// ============================================================

enum OnboardingStatus {
  not_started
  in_progress
  completed
}

model OnboardingPack {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  serviceId   String?
  service     Service? @relation("ServiceOnboardingPacks", fields: [serviceId], references: [id], onDelete: SetNull)
  isDefault   Boolean  @default(false)
  deleted     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks       OnboardingTask[]
  assignments StaffOnboarding[]

  @@index([serviceId])
}

model OnboardingTask {
  id          String         @id @default(cuid())
  packId      String
  pack        OnboardingPack @relation(fields: [packId], references: [id], onDelete: Cascade)
  title       String
  description String?        @db.Text
  category    String?
  sortOrder   Int            @default(0)
  isRequired  Boolean        @default(true)
  documentId  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  progress StaffOnboardingProgress[]

  @@index([packId])
}

model StaffOnboarding {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation("OnboardingUser", fields: [userId], references: [id], onDelete: Cascade)
  packId      String
  pack        OnboardingPack   @relation(fields: [packId], references: [id], onDelete: Cascade)
  status      OnboardingStatus @default(not_started)
  startedAt   DateTime?
  completedAt DateTime?
  dueDate     DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  progress StaffOnboardingProgress[]

  @@unique([userId, packId])
  @@index([userId])
  @@index([packId])
  @@index([status])
}

model StaffOnboardingProgress {
  id           String          @id @default(cuid())
  onboardingId String
  onboarding   StaffOnboarding @relation(fields: [onboardingId], references: [id], onDelete: Cascade)
  taskId       String
  task         OnboardingTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  completed    Boolean         @default(false)
  completedAt  DateTime?
  notes        String?         @db.Text
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([onboardingId, taskId])
  @@index([onboardingId])
  @@index([taskId])
}

// ============================================================
// LMS (Learning Management System)
// ============================================================

enum LMSCourseStatus {
  draft
  published
  archived
}

enum LMSModuleType {
  document
  video
  quiz
  checklist
  external_link
}

enum LMSEnrollmentStatus {
  enrolled
  in_progress
  completed
  expired
}

model LMSCourse {
  id          String          @id @default(cuid())
  title       String
  description String?         @db.Text
  category    String?
  thumbnail   String?
  status      LMSCourseStatus @default(draft)
  isRequired  Boolean         @default(false)
  serviceId   String?
  service     Service?        @relation("ServiceCourses", fields: [serviceId], references: [id], onDelete: SetNull)
  sortOrder   Int             @default(0)
  deleted     Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  modules     LMSModule[]
  enrollments LMSEnrollment[]

  @@index([status])
  @@index([serviceId])
}

model LMSModule {
  id          String        @id @default(cuid())
  courseId    String
  course      LMSCourse     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  description String?       @db.Text
  type        LMSModuleType @default(document)
  content     String?       @db.Text
  resourceUrl String?
  documentId  String?
  duration    Int?
  sortOrder   Int           @default(0)
  isRequired  Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  progress LMSModuleProgress[]

  @@index([courseId])
}

model LMSEnrollment {
  id          String              @id @default(cuid())
  userId      String
  user        User                @relation("LMSStudent", fields: [userId], references: [id], onDelete: Cascade)
  courseId    String
  course      LMSCourse           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  status      LMSEnrollmentStatus @default(enrolled)
  enrolledAt  DateTime            @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  dueDate     DateTime?
  score       Float?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  moduleProgress LMSModuleProgress[]

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
}

model LMSModuleProgress {
  id           String        @id @default(cuid())
  enrollmentId String
  enrollment   LMSEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  moduleId     String
  module       LMSModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  completed    Boolean       @default(false)
  completedAt  DateTime?
  score        Float?
  timeSpent    Int?
  notes        String?       @db.Text
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([enrollmentId, moduleId])
  @@index([enrollmentId])
  @@index([moduleId])
}

// ============================================================
// Compliance Calendar
// ============================================================

enum CertificateType {
  wwcc
  first_aid
  anaphylaxis
  asthma
  cpr
  police_check
  annual_review
  child_protection
  geccko
  food_safety
  food_handler
  other
}

model ComplianceCertificate {
  id           String          @id @default(cuid())
  serviceId    String
  service      Service         @relation("ServiceCertificates", fields: [serviceId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?           @relation("UserCertificates", fields: [userId], references: [id], onDelete: SetNull)
  type         CertificateType
  label        String?
  issueDate    DateTime
  expiryDate   DateTime
  notes        String?         @db.Text
  fileUrl      String?
  fileName     String?
  alertDays    Int             @default(30)
  acknowledged Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([serviceId])
  @@index([userId])
  @@index([expiryDate])
}

// ── Attendance & Enrolment Tracking ─────────────────────────

model DailyAttendance {
  id           String      @id @default(cuid())
  serviceId    String
  service      Service     @relation("ServiceAttendance", fields: [serviceId], references: [id], onDelete: Cascade)
  date         DateTime    @db.Date
  sessionType  SessionType
  enrolled     Int         @default(0)
  attended     Int         @default(0)
  capacity     Int         @default(0)
  casual       Int         @default(0)
  absent       Int         @default(0)
  notes        String?     @db.Text
  recordedById String?
  recordedBy   User?       @relation("AttendanceRecorder", fields: [recordedById], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([serviceId, date, sessionType])
  @@index([serviceId])
  @@index([date])
  @@index([serviceId, date])
}

// ── Budget Items ────────────────────────────────────────────

model BudgetItem {
  id          String             @id @default(cuid())
  serviceId   String
  service     Service            @relation("ServiceBudgetItems", fields: [serviceId], references: [id], onDelete: Cascade)
  name        String
  amount      Float
  category    BudgetItemCategory @default(other)
  date        DateTime           @db.Date
  notes       String?            @db.Text
  createdById String?
  createdBy   User?              @relation("BudgetItemCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([serviceId])
  @@index([serviceId, date])
  @@index([category])
}

// ============================================================
// Weekly Program & Menu
// ============================================================

model ProgramActivity {
  id            String   @id @default(cuid())
  serviceId     String
  service       Service  @relation("ServicePrograms", fields: [serviceId], references: [id], onDelete: Cascade)
  weekStart     DateTime @db.Date
  day           WeekDay
  startTime     String // "HH:mm"
  endTime       String // "HH:mm"
  title         String
  description   String?  @db.Text
  staffName     String?
  location      String?
  notes         String?  @db.Text
  templateId    String?
  mtopOutcomes  Int[]    // Array of 1-5 representing MTOP learning outcomes
  programmeBrand String? // homework_heroes, iqra_circle, imagination_station, little_champions, fuel_up, free_play
  createdById   String?
  createdBy     User?    @relation("ProgramCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // ── Interest linkage ──
  linkedInterests ChildInterest[] @relation("InterestToActivity")

  @@unique([serviceId, weekStart, day, startTime])
  @@index([serviceId])
  @@index([serviceId, weekStart])
}

model MenuWeek {
  id          String     @id @default(cuid())
  serviceId   String
  service     Service    @relation("ServiceMenus", fields: [serviceId], references: [id], onDelete: Cascade)
  weekStart   DateTime   @db.Date
  notes       String?    @db.Text
  fileUrl     String?
  fileName    String?
  createdById String?
  createdBy   User?      @relation("MenuCreator", fields: [createdById], references: [id], onDelete: SetNull)
  items       MenuItem[] @relation("MenuWeekItems")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([serviceId, weekStart])
  @@index([serviceId])
}

model MenuItem {
  id          String   @id @default(cuid())
  menuWeekId  String
  menuWeek    MenuWeek @relation("MenuWeekItems", fields: [menuWeekId], references: [id], onDelete: Cascade)
  day         WeekDay
  slot        MealSlot
  description String   @db.Text
  allergens   String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([menuWeekId, day, slot])
  @@index([menuWeekId])
}

// ============================================================
// Activity Library
// ============================================================

model ActivityTemplate {
  id              String           @id @default(cuid())
  title           String
  description     String?          @db.Text
  howTo           String?          @db.Text
  resourcesNeeded String?          @db.Text
  category        ActivityCategory @default(other)
  ageGroup        String?
  durationMinutes Int?
  deleted         Boolean          @default(false)
  createdById     String?
  createdBy       User?            @relation("ActivityTemplateCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  files ActivityTemplateFile[]

  @@index([category])
  @@index([deleted])
}

model ActivityTemplateFile {
  id           String           @id @default(cuid())
  templateId   String
  template     ActivityTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fileName     String
  fileUrl      String
  fileSize     Int?
  mimeType     String?
  uploadedById String?
  uploadedBy   User?            @relation("ActivityTemplateFileUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime         @default(now())

  @@index([templateId])
}

// ============================================================
// Recurring Todo Templates
// ============================================================

enum RecurrenceRule {
  daily
  weekly
  fortnightly
  monthly
  quarterly
}

model TodoTemplate {
  id          String         @id @default(cuid())
  title       String
  description String?        @db.Text
  assigneeId  String?
  assignee    User?          @relation("TemplateAssignee", fields: [assigneeId], references: [id])
  serviceId   String?
  service     Service?       @relation("ServiceTemplates", fields: [serviceId], references: [id], onDelete: SetNull)
  recurrence  RecurrenceRule
  nextRunAt   DateTime // Next date this template should create a todo
  isActive    Boolean        @default(true)
  createdById String?
  createdBy   User?          @relation("TemplateCreator", fields: [createdById], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([isActive, nextRunAt])
  @@index([assigneeId])
  @@index([serviceId])
  @@index([createdById])
}

// ============================================================
// Accountability Chart (EOS)
// ============================================================

model AccountabilitySeat {
  id               String                         @id @default(cuid())
  title            String // "Visionary", "Marketing", "BAK Team Leader"
  responsibilities String[] // PostgreSQL native text array
  parentId         String?
  parent           AccountabilitySeat?            @relation("SeatHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children         AccountabilitySeat[]           @relation("SeatHierarchy")
  order            Int                            @default(0) // Sort order among siblings
  assignees        AccountabilitySeatAssignment[]
  createdAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt

  @@index([parentId])
}

model AccountabilitySeatAssignment {
  id     String             @id @default(cuid())
  seatId String
  seat   AccountabilitySeat @relation(fields: [seatId], references: [id], onDelete: Cascade)
  userId String
  user   User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([seatId, userId])
  @@index([userId])
}

// ============================================================
// Marketing Multi-Centre Scoping
// ============================================================

model MarketingPostService {
  id        String        @id @default(cuid())
  postId    String
  post      MarketingPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service       @relation("ServiceMarketingPosts", fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([postId, serviceId])
  @@index([postId])
  @@index([serviceId])
}

model MarketingCampaignService {
  id         String            @id @default(cuid())
  campaignId String
  campaign   MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  serviceId  String
  service    Service           @relation("ServiceMarketingCampaigns", fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt  DateTime          @default(now())

  @@unique([campaignId, serviceId])
  @@index([campaignId])
  @@index([serviceId])
}

// ============================================================
// Social Media Connections (Facebook + Instagram via Meta)
// ============================================================

model SocialConnection {
  id              String                 @id @default(cuid())
  platform        MarketingPlatform
  status          SocialConnectionStatus @default(disconnected)
  accountId       String?
  accountName     String?
  accessToken     String?                @db.Text
  refreshToken    String?                @db.Text
  tokenExpiresAt  DateTime?
  pageAccessToken String?                @db.Text
  scopes          String?
  lastSyncAt      DateTime?
  lastSyncStatus  String?
  lastSyncError   String?                @db.Text
  serviceId       String?
  service         Service?               @relation("ServiceSocialConnections", fields: [serviceId], references: [id])
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@unique([platform, accountId])
  @@index([platform])
  @@index([serviceId])
