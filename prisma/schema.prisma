generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  owner
  head_office
  admin
  marketing
  coordinator
  member
  staff
}

enum RockStatus {
  on_track
  off_track
  complete
  dropped
}

enum RockPriority {
  critical
  high
  medium
}

enum RockType {
  company
  personal
}

enum TodoStatus {
  pending
  in_progress
  complete
  cancelled
}

enum IssuePriority {
  critical
  high
  medium
  low
}

enum IssueStatus {
  open
  in_discussion
  solved
  closed
}

enum GoalStatus {
  on_track
  at_risk
  off_track
  complete
}

enum GoalDirection {
  above
  below
  exact
}

enum MeasurableFrequency {
  weekly
  monthly
}

enum ServiceStatus {
  active
  onboarding
  pipeline
  closing
  closed
}

enum SessionType {
  bsc
  asc
  vc
}

enum WeekDay {
  monday
  tuesday
  wednesday
  thursday
  friday
}

enum MealSlot {
  morning_tea
  lunch
  afternoon_tea
}

enum ActivityCategory {
  physical_play
  creative_arts
  music_movement
  literacy
  numeracy
  nature_outdoors
  cooking_nutrition
  social_emotional
  quiet_time
  free_play
  quran_iqra
  homework_help
  stem_science
  other
}

enum BudgetItemCategory {
  kitchen
  sports
  art_craft
  furniture
  technology
  cleaning
  safety
  other
}

enum ProjectStatus {
  not_started
  in_progress
  complete
  on_hold
  cancelled
}

enum MeetingStatus {
  scheduled
  in_progress
  completed
  cancelled
}

