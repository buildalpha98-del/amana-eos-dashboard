  updatedAt DateTime          @updatedAt

  @@index([platform])
}

model MarketingHashtagSet {
  id        String                   @id @default(cuid())
  name      String
  category  MarketingHashtagCategory
  tags      String                   @db.Text
  deleted   Boolean                  @default(false)
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

