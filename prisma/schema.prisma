// ============================================================
// Marketing Cockpit (Sprint 2) — Models
// ============================================================

model CentreAvatar {
  id        String  @id @default(cuid())
  serviceId String  @unique
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  version Int @default(1)

  snapshot     Json?
  parentAvatar Json?
  programmeMix Json?
  assetLibrary Json?

  lastUpdatedAt   DateTime @default(now())
  lastUpdatedById String?
  lastUpdatedBy   User?    @relation("CentreAvatarUpdater", fields: [lastUpdatedById], references: [id], onDelete: SetNull)

  lastReviewedAt   DateTime?
  lastReviewedById String?
  lastReviewedBy   User?     @relation("CentreAvatarReviewer", fields: [lastReviewedById], references: [id], onDelete: SetNull)

  lastFullReviewAt DateTime?

  lastOpenedAt   DateTime?
  lastOpenedById String?
  lastOpenedBy   User?     @relation("CentreAvatarOpener", fields: [lastOpenedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  insights            CentreAvatarInsight[]
  campaignLog         CentreAvatarCampaignLog[]
  coordinatorCheckIns CentreAvatarCoordinatorCheckIn[]
  schoolLiaisonLog    CentreAvatarSchoolLiaisonLog[]
  updateLog           CentreAvatarUpdateLog[]

  @@index([lastUpdatedAt])
}

enum CentreAvatarInsightSource {
  coordinator_checkin
  parent_conversation
  parent_feedback
  complaint
  compliment
  social_comment_or_dm
  whatsapp_message
  enrolment_conversation
  exit_conversation
  other
}

enum CentreAvatarInsightStatus {
  pending_review
  approved
  dismissed
}

enum CentreAvatarInsightHarvestSource {
  nps_survey_response
  quick_feedback
  parent_feedback
  manual
}

model CentreAvatarInsight {
  id             String       @id @default(cuid())
  centreAvatarId String
  centreAvatar   CentreAvatar @relation(fields: [centreAvatarId], references: [id], onDelete: Cascade)

  occurredAt     DateTime
  source         CentreAvatarInsightSource
  insight        String                    @db.Text
  impactOnAvatar String?                   @db.Text

  status         CentreAvatarInsightStatus         @default(approved)
  harvestedFrom  CentreAvatarInsightHarvestSource?
  sourceRecordId String?

  createdById String?
  createdBy   User?   @relation("CentreAvatarInsightCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([harvestedFrom, sourceRecordId], name: "harvest_dedup")
  @@index([centreAvatarId, occurredAt])
  @@index([status])
}

model CentreAvatarCampaignLog {
  id             String       @id @default(cuid())
  centreAvatarId String
  centreAvatar   CentreAvatar @relation(fields: [centreAvatarId], references: [id], onDelete: Cascade)

  occurredAt   DateTime
  campaignName String
  contentUsed  String?  @db.Text
  result       String?  @db.Text
  learnings    String?  @db.Text

  marketingCampaignId String?
  marketingCampaign   MarketingCampaign? @relation("MarketingCampaignCentreAvatarLog", fields: [marketingCampaignId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation("CentreAvatarCampaignLogCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([centreAvatarId, occurredAt])
  @@index([marketingCampaignId])
}

model CentreAvatarCoordinatorCheckIn {
  id             String       @id @default(cuid())
  centreAvatarId String
  centreAvatar   CentreAvatar @relation(fields: [centreAvatarId], references: [id], onDelete: Cascade)

  occurredAt      DateTime
  topicsDiscussed String    @db.Text
  actionItems     String?   @db.Text
  followUpDate    DateTime?

  coordinatorUserId String?
  coordinator       User?   @relation("CentreAvatarCheckInCoordinator", fields: [coordinatorUserId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation("CentreAvatarCheckInCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([centreAvatarId, occurredAt])
  @@index([followUpDate])
}

model CentreAvatarSchoolLiaisonLog {
  id             String       @id @default(cuid())
  centreAvatarId String
  centreAvatar   CentreAvatar @relation(fields: [centreAvatarId], references: [id], onDelete: Cascade)

  occurredAt  DateTime
  contactName String
  purpose     String   @db.Text
  outcome     String?  @db.Text
  nextStep    String?  @db.Text

  schoolCommId String?
