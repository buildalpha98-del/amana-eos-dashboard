  @@index([type])
}

/// Lightweight ongoing CPD/PD log — sits alongside the static StaffQualification
/// (initial credentials) and ComplianceCertificate (renewable cards). One row
/// per attended training, course, conference, mentoring session, etc. Hours sum
/// up for state-regulator CPD requirements.
model ProfessionalDevelopmentRecord {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation("UserPdRecords", fields: [userId], references: [id], onDelete: Cascade)
  title         String
  type          String // "course" | "workshop" | "conference" | "online" | "mentoring" | "reading" | "other"
  hours         Decimal  @db.Decimal(5, 2)
  completedAt   DateTime @db.Date
  provider      String? // e.g. "ACECQA", "TAFE NSW", internal name
  attachmentUrl String? // certificate or completion proof (Vercel Blob)
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, completedAt])
}

// ============================================================
// Phase 2: Policies & Procedures (versioned PDF library)
// ============================================================

enum PolicyDocumentCategory {
  policy
  procedure
  other
}

model PolicyDocument {
  id               String                  @id @default(cuid())
  title            String                  @unique
  description      String?                 @db.Text
  category         PolicyDocumentCategory  @default(policy)
  currentVersionId String?                 @unique
  currentVersion   PolicyDocumentVersion?  @relation("CurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  versions         PolicyDocumentVersion[] @relation("DocumentVersions")
  isArchived       Boolean                 @default(false)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([category])
  @@index([isArchived])
}

model PolicyDocumentVersion {
  id               String                          @id @default(cuid())
  documentId       String
  document         PolicyDocument                  @relation("DocumentVersions", fields: [documentId], references: [id], onDelete: Cascade)
  versionNumber    Int
  fileUrl          String
  fileName         String
  fileSize         Int
  uploadedById     String?
  uploadedBy       User?                           @relation("PolicyDocVersionUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  uploadedAt       DateTime                        @default(now())
  acknowledgements PolicyDocumentAcknowledgement[]
  currentOf        PolicyDocument?                 @relation("CurrentVersion")

  @@unique([documentId, versionNumber])
  @@index([documentId])
}

model PolicyDocumentAcknowledgement {
  id             String                @id @default(cuid())
  versionId      String
  version        PolicyDocumentVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  userId         String
  user           User                  @relation("PolicyDocAcknowledger", fields: [userId], references: [id], onDelete: Cascade)
  acknowledgedAt DateTime              @default(now())

  @@unique([versionId, userId])
  @@index([versionId])
  @@index([userId])
}

// ============================================================
// Phase 3: Contract Management
// ============================================================

model EmploymentContract {
  id                  String               @id @default(cuid())
  userId              String
  user                User                 @relation("ContractEmployee", fields: [userId], references: [id], onDelete: Cascade)
  contractType        ContractType
  awardLevel          AwardLevel?
  awardLevelCustom    String?
  payRate             Float
  hoursPerWeek        Float?
  startDate           DateTime             @db.Date
  endDate             DateTime?            @db.Date
  status              ContractStatus       @default(contract_draft)
  documentUrl         String?
  documentId          String?
  signedAt            DateTime?
  acknowledgedByStaff Boolean              @default(false)
  acknowledgedAt      DateTime?

  // ── Two-party signatures (2026-06-02) ────────────────────────────
  // Captured client-side as transparent PNG data URLs from an HTML5
  // canvas signature pad. Stored on the row (typical size 5-30 KB) so
  // every consumer (PDF render, UI, audit) can read from the same
  // source. The PDF document at `documentUrl` is re-rendered with
  // both signatures embedded after the staff member signs, so the
  // final downloadable contract carries both signatures in-doc.
  //
  // Legacy contracts (issued before this feature) leave these null;
  // the render-html signature placeholder substitution treats null
  // as "no signature available" and renders blank.
  adminSignatureDataUrl  String?           @db.Text
  adminSignedById        String?
  adminSignedBy          User?             @relation("ContractAdminSigner", fields: [adminSignedById], references: [id], onDelete: SetNull)
  adminSignedAt          DateTime?
  staffSignatureDataUrl  String?           @db.Text
  // staffSignedAt is intentionally NOT a new column — `acknowledgedAt`
  // already records the moment the staff member completed their
  // acknowledgement, which under the new flow IS the signature.
  notes               String?              @db.Text
  previousContractId  String?
  previousContract    EmploymentContract?  @relation("ContractHistory", fields: [previousContractId], references: [id])
  supersededBy        EmploymentContract[] @relation("ContractHistory")
  templateId          String?
  template            ContractTemplate?    @relation("ContractFromTemplate", fields: [templateId], references: [id], onDelete: SetNull)
  templateValues      Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  // Back-ref for CasualConversionElection — when this contract was the
  // result of an accepted conversion election, the election row points
  // back here. Unique because one contract = one election (or null).
  conversionElection  CasualConversionElection? @relation("ConversionResultContract")

  @@index([userId])
  @@index([status])
  @@index([contractType])
  @@index([templateId])
}

model ContractTemplate {
  id              String                 @id @default(cuid())
  name            String
  description     String?                @db.Text
  contentJson     Json
  manualFields    Json
  status          ContractTemplateStatus @default(active)
  createdById     String
  createdBy       User                   @relation("TemplateCreator", fields: [createdById], references: [id])
  updatedById     String?
  updatedBy       User?                  @relation("TemplateUpdater", fields: [updatedById], references: [id])
  issuedContracts EmploymentContract[]   @relation("ContractFromTemplate")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([status])
  @@index([name])
}

// 2026-05-18: Org-level user-defined merge tags for the contract template
// editor. Surfaced in MergeTagPanel as the "Custom Tags" section, alongside
// the hardcoded system catalog. `key` is always prefixed `custom.` and is
// camelCased from the user-entered label at write time. Shared across all
// admins (single-tenant) — `createdById` is audit-only and the row remains
// even if the creator's user record is deleted.
model ContractCustomTag {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  createdById String?
  createdBy   User?    @relation("ContractCustomTagCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
}

// ============================================================
// Phase 4: Leave Management
// ============================================================

model LeaveRequest {
  id           String             @id @default(cuid())
  userId       String
  user         User               @relation("LeaveRequester", fields: [userId], references: [id], onDelete: Cascade)
  leaveType    LeaveType
  startDate    DateTime           @db.Date
  endDate      DateTime           @db.Date
  totalDays    Float
  isHalfDay    Boolean            @default(false)
  reason       String?            @db.Text
  status       LeaveRequestStatus @default(leave_pending)
  reviewedById String?
  reviewedBy   User?              @relation("LeaveApprover", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  reviewNotes  String?            @db.Text
  serviceId    String?
  service      Service?           @relation("ServiceLeaveRequests", fields: [serviceId], references: [id], onDelete: SetNull)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([userId])
  @@index([status])
  @@index([startDate])
  @@index([serviceId])
  @@index([leaveType])
  @@index([reviewedById])
  @@index([userId, status])
  @@index([serviceId, status])
}

model LeaveBalance {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType    LeaveType
  balance      Float     @default(0)
  accrued      Float     @default(0)
  taken        Float     @default(0)
  pending      Float     @default(0)
  asOfDate     DateTime  @default(now())
  source       String    @default("manual")
  xeroSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, leaveType])
  @@index([userId])
}

// ============================================================
// Phase 5: Timesheet Import from OWNA
// ============================================================

model Timesheet {
  id             String          @id @default(cuid())
  serviceId      String
  service        Service         @relation("ServiceTimesheets", fields: [serviceId], references: [id], onDelete: Cascade)
  weekEnding     DateTime        @db.Date
  status         TimesheetStatus @default(ts_draft)
  submittedAt    DateTime?
  submittedById  String?
  approvedAt     DateTime?
  approvedById   String?
  exportedAt     DateTime?
  xeroPayRunId   String?
  importSource   String?         @default("manual")
  importFileName String?
  notes          String?         @db.Text
  deleted        Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  entries TimesheetEntry[]

  @@unique([serviceId, weekEnding])
  @@index([serviceId])
  @@index([status])
  @@index([weekEnding])
}

model TimesheetEntry {
  id           String    @id @default(cuid())
  timesheetId  String
  timesheet    Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  userId       String
  user         User      @relation("TimesheetStaff", fields: [userId], references: [id])
  date         DateTime  @db.Date
  shiftStart   DateTime
  shiftEnd     DateTime
  breakMinutes Int       @default(0)
  totalHours   Float
  shiftType    ShiftType
  notes        String?
  isOvertime   Boolean   @default(false)
  payRate      Float?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([timesheetId])
  @@index([userId])
  @@index([date])
}

// ============================================================
// Phase 6: Offboarding Workflow
// ============================================================

model OffboardingPack {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  serviceId   String?
  service     Service? @relation("ServiceOffboardingPacks", fields: [serviceId], references: [id], onDelete: SetNull)
  isDefault   Boolean  @default(false)
  // 2026-07-08: employment-type-aware packs. When set, the assign
  // endpoint auto-picks this pack for departing staff whose active
  // contract has a matching type. Empty array = fallback / manual only.
  // Introduced with the MA000120 Casual + Permanent packs so casuals
  // don't get the full-time NES notice checklist and vice versa.
  applicableEmploymentTypes EmploymentType[] @default([])
  deleted     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks       OffboardingTask[]
  assignments StaffOffboarding[]

  @@index([serviceId])
}

model OffboardingTask {
  id          String          @id @default(cuid())
  packId      String
  pack        OffboardingPack @relation(fields: [packId], references: [id], onDelete: Cascade)
  title       String
  description String?         @db.Text
  category    String?
  sortOrder   Int             @default(0)
  isRequired  Boolean         @default(true)
  assignedTo  String?
  documentId  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  progress StaffOffboardingProgress[]

  @@index([packId])
}

model StaffOffboarding {
  id                   String           @id @default(cuid())
  userId               String
  user                 User             @relation("OffboardingUser", fields: [userId], references: [id], onDelete: Cascade)
  packId               String
  pack                 OffboardingPack  @relation(fields: [packId], references: [id], onDelete: Cascade)
  status               OnboardingStatus @default(not_started)
  initiatedById        String?
  lastDay              DateTime?        @db.Date
  reason               String?
  exitInterviewNotes   String?          @db.Text
  startedAt            DateTime?
  completedAt          DateTime?
  deactivateOnComplete Boolean          @default(true)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  progress StaffOffboardingProgress[]

  @@unique([userId, packId])
  @@index([userId])
  @@index([packId])
  @@index([status])
}

model StaffOffboardingProgress {
  id            String           @id @default(cuid())
  offboardingId String
  offboarding   StaffOffboarding @relation(fields: [offboardingId], references: [id], onDelete: Cascade)
  taskId        String
  task          OffboardingTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  completed     Boolean          @default(false)
  completedAt   DateTime?
  completedById String?
  notes         String?          @db.Text
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([offboardingId, taskId])
  @@index([offboardingId])
  @@index([taskId])
}

// ---------------------------------------------------------------------------
// API Key Management — database-backed API keys for external integrations
// ---------------------------------------------------------------------------

model ApiKey {
  id          String    @id @default(cuid())
  name        String // human label, e.g. "Cowork Production"
  keyPrefix   String // first 8 hex chars for display
  keyHash     String    @unique // SHA-256 hex of the full key
  scopes      String[] // ["programs:write", "menus:write", "announcements:write"]
  allowedIps  String[] // empty = allow all; otherwise restrict to these IPs/CIDRs
  expiresAt   DateTime? // null = never expires
  revokedAt   DateTime? // non-null = revoked
  lastUsedAt  DateTime?
  createdById String
  createdBy   User      @relation("ApiKeyCreator", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([keyHash])
  @@index([createdById])
}

// ---------------------------------------------------------------------------
// Cowork API Integration — external automation pushes content into dashboard
// ---------------------------------------------------------------------------

model CoworkProgram {
  id              String   @id @default(cuid())
  weekCommencing  DateTime @unique
  theme           String
  category        String?
  summary         String?  @db.Text
  programFileUrl  String?
  resourceFileUrl String?
  displayFileUrl  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CoworkTodo {
  id           String    @id @default(cuid())
  centreId     String
  date         DateTime
  title        String
  description  String?   @db.Text
  category     String // "morning-prep", "afternoon-prep", "end-of-day"
  dueTime      String? // "06:00", "15:00", etc.
  assignedRole String? // "educator", "coordinator"
  assignedToId String?
  assignedTo   User?     @relation("CoworkTodoAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  completed    Boolean   @default(false)
  completedAt  DateTime?
  completedBy  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  aiDrafts AiTaskDraft[] @relation("CoworkTodoAiDraft")

  @@index([centreId, date])
  @@index([assignedToId])
}

model CoworkAnnouncement {
  id            String    @id @default(cuid())
  title         String
  body          String    @db.Text
  type          String // "program-update", "newsletter-summary", "general", "holiday-quest", "reminder"
  targetCentres String[] // ["all"] or specific centre IDs
  attachments   String[] // file URLs
  pinned        Boolean   @default(false)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model CalendarEvent {
  id        String    @id @default(cuid())
  title     String
  date      DateTime
  endDate   DateTime?
  centreId  String? // null = all centres
  type      String // "excursion", "incursion", "public-holiday", etc.
  details   String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([centreId, date])
}

// ============================================================
// CRM Models
// ============================================================

model Lead {
  id                   String        @id @default(cuid())
  schoolName           String
  contactName          String?
  contactEmail         String?
  contactPhone         String?
  address              String?
  suburb               String?
  state                String?
  postcode             String?
  source               LeadSource    @default(direct)
  pipelineStage        PipelineStage @default(new_lead)
  tenderRef            String?       @unique
  tenderCloseDate      DateTime?
  tenderUrl            String?
  estimatedCapacity    Int?
  notes                String?       @db.Text
  buildAlphaKidsStatus String? // active, prospect, not_applicable, unknown
  communityConnections String?       @db.Text
  assignedToId         String?
  assignedTo           User?         @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  serviceId            String?
  service              Service?      @relation("LeadService", fields: [serviceId], references: [id], onDelete: SetNull)
  wonAt                DateTime?
  lostAt               DateTime?
  lostReason           String?
  stageChangedAt       DateTime      @default(now())
  nextTouchpointAt     DateTime?
  deleted              Boolean       @default(false)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  // AI Lead Scoring
  aiScore        Int? // 0-100 score
  aiScoreSummary String?   @db.Text
  aiScoredAt     DateTime?

  touchpoints        TouchpointLog[]
  sequenceEnrolments SequenceEnrolment[] @relation("LeadSequenceEnrolments")

  @@index([pipelineStage])
  @@index([assignedToId])
  @@index([source])
  @@index([state])
  @@index([nextTouchpointAt])
  @@index([pipelineStage, serviceId])
  @@index([deleted, stageChangedAt])
}

model TouchpointLog {
  id       String         @id @default(cuid())
  leadId   String
  lead     Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type     TouchpointType
  subject  String?
  body     String?        @db.Text
  sentAt   DateTime       @default(now())
  sentById String?
  sentBy   User?          @relation("TouchpointSender", fields: [sentById], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([sentAt])
}

model CrmEmailTemplate {
  id           String         @id @default(cuid())
  name         String         @unique // template names must be unique
  subject      String
  body         String         @db.Text
  triggerStage PipelineStage?
  pipeline     LeadSource?
  sortOrder    Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model TenderScrapeRun {
  id           String    @id @default(cuid())
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  status       String    @default("running") // running, completed, failed
  leadsFound   Int       @default(0)
  leadsCreated Int       @default(0)
  error        String?
  details      Json?
}

// ============================================================
// Tier 1 Delivery Automation
// ============================================================

model CentreContact {
  id               String    @id @default(cuid())
  email            String
  firstName        String?
  lastName         String?
  serviceId        String
  service          Service   @relation("ServiceContacts_Email", fields: [serviceId], references: [id], onDelete: Cascade)
  subscribed       Boolean   @default(true)
  status           String    @default("active") // active, withdrawn, paused
  withdrawalDate   DateTime?
  withdrawalReason String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // ── Parent profile (populated from EnrolmentSubmission.primaryParent on approval) ──
  dob          DateTime? @db.Date
  mobile       String?
  crn          String?
  address      Json? // { street, suburb, state, postcode }
  relationship String? // "Mother" | "Father" | "Guardian" | etc.
  occupation   String?
  workplace    String?
  workPhone    String?
  parentRole   String? // "primary" | "secondary"

  // Link to any enrolment submission this contact was created from (provenance)
  sourceEnrolmentId String?

  // OWNA legacy mapping — populated when OWNA family sync is wired
  ownaFamilyId String? @unique

  // SMS opt-in — required before broadcast SMS dispatch (Spam Act 2003 compliance)
  smsOptIn Boolean @default(false)

  nurtureSteps          ParentNurtureStep[]    @relation("ContactNurtureSteps")
  npsResponses          NpsSurveyResponse[]    @relation("ContactNpsResponses")
  referralsMade         Referral[]             @relation("ReferrerContact")
  exitSurveys           ExitSurvey[]           @relation("ContactExitSurveys")
  sequenceEnrolments    SequenceEnrolment[]    @relation("ContactSequenceEnrolments")
  statements            Statement[]            @relation("ContactStatements")
  payments              Payment[]              @relation("ContactPayments")
  documents             ParentDocument[]       @relation("ContactDocuments")
  supportTickets        SupportTicket[]        @relation("ParentTickets")
  bookings              Booking[]              @relation("ContactBookings")
  conversations         Conversation[]
  enrolmentApplications EnrolmentApplication[] @relation("ContactEnrolmentApplications")
  authTokens            ParentAuthToken[]      @relation("ContactAuthTokens")
  pushSubscriptions     PushSubscription[]     @relation("ContactPushSubscriptions")
  onboardingProgress    Json? // { profile, medical, documents, pickups, installed }
  parentPostLikes       ParentPostLike[]       @relation("ParentPostLikes")
  parentPostComments    ParentPostComment[]    @relation("ParentPostComments")
  feedback              ParentFeedback[]       @relation("ContactFeedback")

  @@unique([email, serviceId])
  @@index([serviceId])
  @@index([serviceId, status])
}

// ============================================================
// Parent Experience — Quick Feedback + Exit Survey
// ============================================================

model QuickFeedback {
  id          String   @id @default(cuid())
  serviceId   String
  service     Service  @relation("ServiceQuickFeedback", fields: [serviceId], references: [id], onDelete: Cascade)
  weekStart   DateTime @db.Date
  score       Int // 1=very unhappy, 2=unhappy, 3=neutral, 4=happy, 5=very happy
  comment     String?  @db.Text
  parentName  String?
  parentEmail String?
  ipHash      String? // Hashed IP for rate limiting
  createdAt   DateTime @default(now())

  @@index([serviceId, weekStart])
  @@index([score])
  @@index([createdAt])
}

model ExitSurvey {
  id                String         @id @default(cuid())
  serviceId         String
  service           Service        @relation("ServiceExitSurveys", fields: [serviceId], references: [id], onDelete: Cascade)
  contactId         String?
  contact           CentreContact? @relation("ContactExitSurveys", fields: [contactId], references: [id], onDelete: SetNull)
  childName         String
  withdrawalDate    DateTime
  reason            String // moved_schools, no_longer_need_care, cost, unhappy_with_service, child_did_not_enjoy, schedule_change, other
  reasonDetail      String?        @db.Text
  satisfactionScore Int // 1-5
  enjoyedMost       String?        @db.Text
  couldImprove      String?        @db.Text
  wouldReturn       String // yes, maybe, no
  surveyToken       String         @unique
  tokenExpiresAt    DateTime
  completedAt       DateTime?
  createdAt         DateTime       @default(now())

  @@index([serviceId])
  @@index([reason])
  @@index([surveyToken])
}

model WhatsAppGroup {
  id               String   @id @default(cuid())
  groupType        String // announcements, centre_parents, lunchbox, ccs_help, ideas
  serviceCode      String? // null for broadcast groups
  whatsappGroupJid String   @unique // WhatsApp group JID from 360dialog — must be unique
  name             String
  memberCount      Int      @default(0)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())

  @@index([groupType])
  @@index([serviceCode])
}

model SocialAccount {
  id                 String    @id @default(cuid())
  serviceCode        String    @unique
  facebookPageId     String?
  instagramAccountId String?
  accessToken        String    @db.Text // encrypted via encryptToken()
  tokenExpiresAt     DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model DeliveryLog {
  id             String   @id @default(cuid())
  channel        String // email, whatsapp, social
  serviceCode    String?
  messageType    String? // week_ahead, newsletter, etc.
  externalId     String? // provider message/post ID
  recipientCount Int      @default(0)
  status         String // sent, scheduled, failed
  errorMessage   String?  @db.Text
  payload        Json? // original request body for debugging
  entityType     String?
  entityId       String?
  subject        String?
  templateId     String?
  renderedHtml   String?  @db.Text
  createdAt      DateTime @default(now())

  @@index([channel])
  @@index([serviceCode])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([serviceCode, createdAt])
  @@index([status])
  @@index([channel, status])
}

// ============================================================
// Parent Nurture Sequences
// ============================================================

model ParentNurtureStep {
  id           String         @id @default(cuid())
  serviceId    String
  service      Service        @relation("ServiceNurtureSteps", fields: [serviceId], references: [id], onDelete: Cascade)
  contactId    String
  contact      CentreContact  @relation("ContactNurtureSteps", fields: [contactId], references: [id], onDelete: Cascade)
  stepNumber   Int
  templateKey  String // welcome, how_to_enrol, what_to_bring, app_setup, first_week, ccs_assist, nudge_1, form_support, nudge_2, final_nudge, day1_checkin, day3_checkin, week2_feedback, month1_referral
  scheduledFor DateTime
  sentAt       DateTime?
  status       String         @default("pending") // pending, sent, failed, cancelled
  enquiryId    String?
  enquiry      ParentEnquiry? @relation(fields: [enquiryId], references: [id])
  createdAt    DateTime       @default(now())

  @@unique([contactId, templateKey])
  @@index([serviceId])
  @@index([scheduledFor])
  @@index([status])
  @@index([enquiryId])
}

// ============================================================
// Holiday Quest — Vacation Care Day Plans
// ============================================================

model HolidayQuestDay {
  id                String   @id @default(cuid())
  serviceId         String
  service           Service  @relation("ServiceHolidayQuest", fields: [serviceId], references: [id], onDelete: Cascade)
  date              DateTime @db.Date
  theme             String
  morningActivity   String   @db.Text
  afternoonActivity String   @db.Text
  isExcursion       Boolean  @default(false)
  excursionVenue    String?
  excursionCost     Float?
  materialsNeeded   String?  @db.Text
  dietaryNotes      String?  @db.Text
  maxCapacity       Int      @default(40)
  currentBookings   Int      @default(0)
  status            String   @default("draft") // draft, published, full
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([serviceId, date])
  @@index([serviceId])
  @@index([date])
}

// ============================================================
// OWNA Integration — Booking Forecasts & Roster
// ============================================================

model BookingForecast {
  id          String      @id @default(cuid())
  serviceId   String
  service     Service     @relation("ServiceBookings", fields: [serviceId], references: [id], onDelete: Cascade)
  date        DateTime    @db.Date
  sessionType SessionType
  regular     Int         @default(0)
  casual      Int         @default(0)
  total       Int         @default(0)
  capacity    Int         @default(0)
  syncedAt    DateTime    @default(now())

  @@unique([serviceId, date, sessionType])
  @@index([serviceId])
  @@index([date])
}

model RosterShift {
  id          String      @id @default(cuid())
  serviceId   String
  service     Service     @relation("ServiceRosterShifts", fields: [serviceId], references: [id], onDelete: Cascade)
  date        DateTime    @db.Date
  sessionType SessionType
  staffName   String
  shiftStart  String // "HH:mm"
  shiftEnd    String // "HH:mm"
  role        String? // "coordinator", "educator", "assistant"
  syncedAt    DateTime    @default(now())

  userId            String?
  user              User?              @relation("UserRosterShifts", fields: [userId], references: [id], onDelete: SetNull)
  status            String             @default("published")
  publishedAt       DateTime?
  createdById       String?
  createdBy         User?              @relation("CreatedRosterShifts", fields: [createdById], references: [id], onDelete: SetNull)
  shiftSwapRequests ShiftSwapRequest[] @relation("ShiftSwapRequests")
  // 2026-05-04 (timeclock v1): actual sign-in/out timestamps. Both null
  // until the user clocks in. `actualEnd` stays null while clocked-in
  // and gets set on clock-out. Variance against `shiftStart`/`shiftEnd`
  // is rendered in the per-service Weekly Shifts grid.
  actualStart       DateTime?
  actualEnd         DateTime?

  @@unique([serviceId, date, staffName, shiftStart])
  @@index([serviceId])
  @@index([date])
  @@index([serviceId, date])
  @@index([date, staffName])
  @@index([userId])
  @@index([userId, date])
  @@index([status])
}

/// Responsible-person register — under the NQF an approved provider must
/// designate one "responsible person working directly with children" per
/// session and keep a record of it. This is that record: exactly one entry
/// per (service, date, sessionType). Deliberately independent of
/// RosterShift so the register is immutable history (a later roster edit
/// must not rewrite the official record) and can be backfilled from paper
/// records without fabricating shifts.
///
/// `personName` / `personRole` are snapshots taken at record time so the
/// register stays accurate even if the staff member is later renamed,
/// reassigned, or offboarded. `userId` is an optional convenience link.
///
/// Complements the Reg 145/148 staff register in src/lib/nqf-registers.ts
/// (which lists all staff); this is the per-session responsible-person record.
///
/// 2026-06-11: introduced after an Assessment & Rating breach finding
/// (no RP rostered, no record kept). Spec:
/// docs/superpowers/specs/2026-06-11-responsible-person-register-design.md
model ResponsiblePersonEntry {
  id          String      @id @default(cuid())
  serviceId   String
  service     Service     @relation("ServiceResponsiblePersons", fields: [serviceId], references: [id], onDelete: Cascade)
  date        DateTime    @db.Date
  sessionType SessionType
  personName  String
  personRole  String?
  userId      String?
  user        User?       @relation("UserResponsiblePersonEntries", fields: [userId], references: [id], onDelete: SetNull)
  startTime   String // "HH:mm" — designated-RP period start
  endTime     String // "HH:mm" — designated-RP period end
  notes       String?
  createdById String?
  createdBy   User?       @relation("CreatedResponsiblePersonEntries", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([serviceId, date, sessionType])
  @@index([serviceId])
  @@index([date])
  @@index([serviceId, date])
  @@index([userId])
}

/// Staff-initiated request to swap or cover a shift.
/// 3-step flow: proposer → target accepts → admin/coordinator approves.
model ShiftSwapRequest {
  id             String      @id @default(cuid())
  shiftId        String
  shift          RosterShift @relation("ShiftSwapRequests", fields: [shiftId], references: [id], onDelete: Cascade)
  proposerId     String
  proposer       User        @relation("ProposedShiftSwaps", fields: [proposerId], references: [id])
  targetId       String
  target         User        @relation("TargetShiftSwaps", fields: [targetId], references: [id])
  reason         String?
  status         String      @default("proposed")
  acceptedAt     DateTime?
  approvedAt     DateTime?
  approvedById   String?
  approvedBy     User?       @relation("ApprovedShiftSwaps", fields: [approvedById], references: [id], onDelete: SetNull)
  rejectedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([proposerId])
  @@index([targetId])
  @@index([status])
  @@index([shiftId])
}

/// Kiosk — a paired tablet at a centre's front desk that staff use to
/// clock in/out. Auth is bearer-token (long random secret hashed at
/// rest, issued once during register flow) + the staff's own
/// `User.kioskPinHash`. Two layers so a stolen tablet alone can't
/// impersonate staff.
///
/// 2026-05-04: introduced as part of the timeclock v1 spec
/// (docs/superpowers/specs/2026-05-04-staff-timeclock-v1-design.md).
model Kiosk {
  id          String    @id @default(cuid())
  serviceId   String
  service     Service   @relation("ServiceKiosks", fields: [serviceId], references: [id], onDelete: Cascade)
  label       String // "Front desk iPad"
  /// bcrypt of the bearer token; the plaintext is shown to the admin
  /// once at register time and never re-readable.
  tokenHash   String
  createdById String?
  createdBy   User?     @relation("KioskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  /// Set when the admin revokes the kiosk; the auth helper rejects
  /// any request whose token matches a row with this non-null.
  revokedAt   DateTime?
  /// Bumped each time the kiosk hits the API — surfaces "this iPad
  /// hasn't talked to us in 3 days" to admins.
  lastSeenAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([serviceId])
  @@index([revokedAt])
}

/// ShiftTemplate — saved shift pattern an admin uses to create new
/// roster rows quickly. Connecteam-style: rather than re-typing
/// "ASC educator 15:00–18:00" twenty times a week, save it once and
/// pick it from a dropdown when adding a shift.
///
/// 2026-05-04: introduced as the smallest piece of the larger
/// drag-to-create + templates spec. Templates ship now; drag-from-
/// template-onto-grid is a follow-up.
model ShiftTemplate {
  id          String      @id @default(cuid())
  serviceId   String
  service     Service     @relation("ServiceShiftTemplates", fields: [serviceId], references: [id], onDelete: Cascade)
  /// Short admin-facing label, e.g. "ASC educator 3-6pm".
  label       String
  sessionType SessionType
  /// "HH:mm" — same shape as RosterShift.
  shiftStart  String
  shiftEnd    String
  /// Optional role hint that pre-fills RosterShift.role.
  role        String?
  createdById String?
  createdBy   User?       @relation("ShiftTemplateCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([serviceId, label])
  @@index([serviceId])
}

// ── Conversion Tracking ──────────────────────────────────

model ConversionOpportunity {
  id          String      @id @default(cuid())
  serviceId   String
  service     Service     @relation("ServiceConversions", fields: [serviceId], references: [id], onDelete: Cascade)
  familyRef   String // identifier from OWNA (family ID or child name)
  sessionType SessionType
  casualCount Int         @default(0) // casual bookings in analysis period
  periodStart DateTime
  periodEnd   DateTime
  status      String      @default("identified") // identified, contacted, converted, declined
  contactedAt DateTime?
  convertedAt DateTime?
  notes       String?     @db.Text
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([serviceId, familyRef, sessionType, periodStart])
  @@index([serviceId])
  @@index([status])
}

// ============================================================
// Compliance Audit System
// ============================================================

enum AuditFrequency {
  daily
  weekly
  monthly
  quarterly
  half_yearly
  yearly
}

enum AuditStatus {
  scheduled
  in_progress
  completed
  overdue
  skipped
}

enum AuditItemResult {
  yes
  no
  na
  not_answered
}

enum AuditResponseFormat {
  yes_no
  rating_1_5
  compliant
  reverse_yes_no
  review_date
  inventory
}

model AuditTemplate {
  id               String              @id @default(cuid())
  name             String              @unique
  description      String?             @db.Text
  qualityArea      Int
  nqsReference     String
  frequency        AuditFrequency
  scheduledMonths  Int[]
  responseFormat   AuditResponseFormat @default(yes_no)
  estimatedMinutes Int?
  sourceFileName   String?
  // 2026-06-19: Document-mode templates carry the DOCX itself (Blob
  // URL) and don't have structured items. Coordinators edit the doc
  // inline (TipTap) on each instance instead of answering yes/no.
  sourceFileUrl    String?
  // 2026-06-24: cached mammoth conversion of the source .docx so
  // the admin can preview + edit the master template inline. Lazy-
  // populated on first GET .../document when sourceFileUrl exists
  // but sourceHtml is null.
  sourceHtml       String?             @db.Text
  documentMode     Boolean             @default(false)
  isActive         Boolean             @default(true)
  sortOrder        Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  items     AuditTemplateItem[]
  instances AuditInstance[]

  @@index([qualityArea])
  @@index([frequency])
}

model AuditTemplateItem {
  id             String               @id @default(cuid())
  templateId     String
  template       AuditTemplate        @relation(fields: [templateId], references: [id], onDelete: Cascade)
  section        String?
  question       String               @db.Text
  guidance       String?              @db.Text
  responseFormat AuditResponseFormat?
  sortOrder      Int                  @default(0)
  isRequired     Boolean              @default(true)
  createdAt      DateTime             @default(now())

  responses AuditItemResponse[]

  @@index([templateId])
  @@index([templateId, sortOrder])
}

model AuditInstance {
  id                  String        @id @default(cuid())
  templateId          String
  template            AuditTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  serviceId           String
  service             Service       @relation("ServiceAudits", fields: [serviceId], references: [id], onDelete: Cascade)
  scheduledMonth      Int
  scheduledYear       Int
  dueDate             DateTime
  status              AuditStatus   @default(scheduled)
  startedAt           DateTime?
  completedAt         DateTime?
  auditorId           String?
  auditor             User?         @relation("AuditAuditor", fields: [auditorId], references: [id], onDelete: SetNull)
  auditorName         String?
  totalItems          Int           @default(0)
  yesCount            Int           @default(0)
  noCount             Int           @default(0)
  naCount             Int           @default(0)
  complianceScore     Float?
  strengths           String?       @db.Text
  areasForImprovement String?       @db.Text
  actionPlan          String?       @db.Text
  comments            String?       @db.Text
  reviewedAt          DateTime?
  reviewedById        String?
  reviewNotes         String?       @db.Text
  // 2026-06-19: For document-mode audits the completion artifact is
  // the edited DOCX (or its rendered preview). Null for structured
  // audits where responses[] is the source of truth.
  completedFileUrl    String?
  // Edited HTML for document-mode audits — what the coordinator
  // saved in the inline editor. Rendered back via the doc viewer.
  completedHtml       String?       @db.Text
  // 2026-06-24: AI flag scan results. When a doc-mode audit is
  // completed, the AI reads `completedHtml`, surfaces action items /
  // failed checks / hazards as `aiFlags` JSON and a one-paragraph
  // `aiSummary` for leadership review.
  aiFlags             Json?
  aiSummary           String?       @db.Text
  aiScannedAt         DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  responses AuditItemResponse[]
  reviews   AuditReview[]       @relation("AuditReviews")

  @@unique([templateId, serviceId, scheduledMonth, scheduledYear])
  @@index([serviceId])
  @@index([templateId])
  @@index([status])
  @@index([dueDate])
  @@index([serviceId, status])
}

model AuditItemResponse {
  id              String            @id @default(cuid())
  instanceId      String
  instance        AuditInstance     @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  templateItemId  String
  templateItem    AuditTemplateItem @relation(fields: [templateItemId], references: [id], onDelete: Cascade)
  result          AuditItemResult   @default(not_answered)
  ratingValue     Int?
  actionRequired  String?           @db.Text
  evidenceSighted String?           @db.Text
  notes           String?           @db.Text
  photoUrl        String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([instanceId, templateItemId])
  @@index([instanceId])
  @@index([result])
}

// ============================================================
// Parent Enquiry Pipeline (B2C)
// ============================================================

model ParentEnquiry {
  id                 String                        @id @default(cuid())
  serviceId          String
  service            Service                       @relation(fields: [serviceId], references: [id])
  parentName         String
  parentEmail        String?
  parentPhone        String?
  childName          String?
  childAge           Int?
  childrenDetails    Json? // Array of {name, age} for multiple children
  channel            String // phone, email, whatsapp, walkin, referral, website
  parentDriver       String? // homework, quran, enrichment, working_parent, traffic, sports
  /// QR-attribution: when an enquiry comes from a scanned activation QR
  /// (utm_campaign query param matching a known qrShortCode).
  sourceActivationId String?
  sourceActivation   CampaignActivationAssignment? @relation("EnquiryFromActivation", fields: [sourceActivationId], references: [id], onDelete: SetNull)
  stage              String                        @default("new_enquiry") // new_enquiry, info_sent, nurturing, form_started, enrolled, first_session, day3, week2, month1, retained, cold
  stageChangedAt     DateTime                      @default(now())
  nextActionDue      DateTime?
  ccsEducated        Boolean                       @default(false)
  formStarted        Boolean                       @default(false)
  formCompleted      Boolean                       @default(false)
  firstSessionDate   DateTime?
  referralId         String?
  referral           Referral?                     @relation(fields: [referralId], references: [id])
  assigneeId         String?
  assignee           User?                         @relation("EnquiryAssignee", fields: [assigneeId], references: [id])
  notes              String?                       @db.Text
  deleted            Boolean                       @default(false)
  ownaEnquiryId      String?                       @unique
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt
  lastEmailSentAt    DateTime?

  // Waitlist fields
  waitlistPosition  Int?
  waitlistJoinedAt  DateTime?
  waitlistOfferedAt DateTime?
  waitlistExpiresAt DateTime?
  waitlistServiceId String?

  touchpoints  ParentEnquiryTouchpoint[]
  nurtureSteps ParentNurtureStep[]
  sourceCall   VapiCall?                 @relation("EnquiryFromCall")

  @@index([serviceId])
  stageEvents ParentEnquiryStageEvent[]

  @@index([stage])
  @@index([assigneeId])
  @@index([nextActionDue])
  @@index([stageChangedAt])
  @@index([stage, createdAt])
  @@index([serviceId, stage])
  @@index([waitlistServiceId, waitlistPosition])
}

// ============================================================
// 2026-07-06: enquiry stage-transition events. The funnel forecast
// (lib/forecast.ts) currently uses fixed per-stage multipliers because
// only each enquiry's CURRENT stage is stored; this log makes true
// per-stage conversion rates computable, powers time-in-stage SLA
// nudges, and is the auditable pipeline history acquirers ask for in
// due diligence.
// ============================================================

model ParentEnquiryStageEvent {
  id        String        @id @default(cuid())
  enquiryId String
  enquiry   ParentEnquiry @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  /// Null for the creation event.
  fromStage String?
  toStage   String
  createdAt DateTime      @default(now())

  @@index([enquiryId, createdAt])
  @@index([toStage, createdAt])
}

model ParentEnquiryTouchpoint {
  id                String        @id @default(cuid())
  enquiryId         String
  enquiry           ParentEnquiry @relation(fields: [enquiryId], references: [id])
  type              String // first_response, nudge_1, form_support, nudge_2, final_nudge, welcome, day1_checkin, day3_checkin, week2_feedback, month1_referral, retention_alert, custom
  channel           String // email, whatsapp, phone, sms
  content           String?       @db.Text
  scheduledFor      DateTime?
  sentAt            DateTime?
  status            String        @default("draft") // draft, pending_review, approved, sent, failed
  generatedByCowork Boolean       @default(false)
  createdAt         DateTime      @default(now())

  @@index([enquiryId])
  @@index([status])
}

model Referral {
  id                String          @id @default(cuid())
  serviceId         String
  service           Service         @relation(fields: [serviceId], references: [id])
  referrerName      String
  referrerContactId String?
  referrerContact   CentreContact?  @relation("ReferrerContact", fields: [referrerContactId], references: [id])
  referredName      String
  referredEmail     String?
  referredPhone     String?
  status            String          @default("pending") // pending, enquired, enrolled, rewarded, expired
  rewardAmount      Float           @default(50)
  rewardIssuedAt    DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  enquiries         ParentEnquiry[]

  @@index([serviceId])
  @@index([status])
}

// ============================================================
// Recruitment Pipeline
// ============================================================

model RecruitmentVacancy {
  id                    String                 @id @default(cuid())
  serviceId             String
  service               Service                @relation("ServiceVacancies", fields: [serviceId], references: [id])
  role                  String // educator, senior_educator, coordinator, director
  employmentType        EmploymentType
  qualificationRequired String? // none, cert_iii, diploma
  status                String                 @default("open") // open, interviewing, offered, filled, cancelled

  // Optional link to the Position Description library — when set,
  // the vacancy detail surface shows the PD inline so interviewers
  // have the selection criteria at hand. Nullable so legacy
  // vacancies don't break.
  positionDescriptionId String?
  positionDescription   PositionDescription?   @relation("VacancyPositionDescription", fields: [positionDescriptionId], references: [id], onDelete: SetNull)
  postedChannels        String[]
  postedAt              DateTime?
  targetFillDate        DateTime?
  filledAt              DateTime?
  filledByUserId        String?
  filledByUser          User?                  @relation("VacancyFilledBy", fields: [filledByUserId], references: [id])
  assignedToId          String?
  assignedTo            User?                  @relation("VacancyAssignee", fields: [assignedToId], references: [id])
  notes                 String?                @db.Text
  deleted               Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  candidates            RecruitmentCandidate[]

  @@index([serviceId])
  @@index([status])
  @@index([assignedToId])
}

model RecruitmentCandidate {
  id               String             @id @default(cuid())
  vacancyId        String
  vacancy          RecruitmentVacancy @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  name             String
  email            String?
  phone            String?
  source           String // indeed, seek, referral, community, mosque, university, walkin
  stage            String             @default("applied") // applied, screened, interviewed, offered, accepted, rejected, withdrawn
  appliedAt        DateTime           @default(now())
  stageChangedAt   DateTime           @default(now())
  interviewNotes   String?            @db.Text
  referredByUserId String?
  referredByUser   User?              @relation("CandidateReferrer", fields: [referredByUserId], references: [id])
  notes            String?            @db.Text
  resumeText       String?            @db.Text
  resumeFileUrl    String?
  aiScreenScore    Int? // 0-100 fit score
  aiScreenSummary  String?            @db.Text
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  staffReferral    StaffReferral?

  @@index([vacancyId])
  @@index([stage])
}

model StaffReferral {
  id             String                @id @default(cuid())
  referrerUserId String
  referrerUser   User                  @relation("StaffReferrer", fields: [referrerUserId], references: [id])
  referredName   String
  referredEmail  String?
  candidateId    String?               @unique
  candidate      RecruitmentCandidate? @relation(fields: [candidateId], references: [id])
  status         String                @default("pending") // pending, hired, bonus_paid, expired
  bonusAmount    Float                 @default(200)
  bonusPaidAt    DateTime?
  lastReminderAt DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([referrerUserId])
  @@index([status])
}

model StaffPulseSurvey {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("UserPulseSurveys", fields: [userId], references: [id])
  serviceId   String
  service     Service   @relation("ServicePulseSurveys", fields: [serviceId], references: [id])
  periodMonth String // format: "2026-03"
  q1Happy     Int? // 1-5
  q2Supported Int? // 1-5
  q3Schedule  Int? // 1-5
  q4Recommend Int? // 1-5
  q5Feedback  String?   @db.Text
  submittedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([userId, periodMonth])
  @@index([serviceId])
  @@index([periodMonth])
}

// ═══════════════════════════════════════════════════════════
// OVERDUE FEES MANAGEMENT
// ═══════════════════════════════════════════════════════════

model OverdueFeeRecord {
  id                   String    @id @default(cuid())
  serviceId            String
  service              Service   @relation("ServiceOverdueFees", fields: [serviceId], references: [id])
  parentName           String
  parentEmail          String?
  parentPhone          String?
  childName            String?
  invoiceRef           String?
  invoiceDate          DateTime  @db.Date
  dueDate              DateTime  @db.Date
  amountDue            Float
