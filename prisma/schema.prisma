model CampaignActivationAssignment {
  id            String            @id @default(cuid())
  campaignId    String
  campaign      MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  serviceId     String
  service       Service           @relation("ServiceActivations", fields: [serviceId], references: [id], onDelete: Cascade)
  assigned      Boolean           @default(true)
  coordinatorId String?
  coordinator   User?             @relation("ActivationCoordinator", fields: [coordinatorId], references: [id])
  budget        Float?
  notes         String?           @db.Text

  /// Lifecycle stage. Sprint 7 replaces the loose Sprint-2 `status` string.
  lifecycleStage ActivationLifecycleStage @default(concept)

  /// What kind of activation. Drives recap template + expected attendance ranges.
  activationType ActivationType?

  /// Lifecycle timestamps. Each represents the moment the stage was entered.
  conceptApprovedAt     DateTime?
  logisticsStartedAt    DateTime?
  finalPushStartedAt    DateTime?
  activationDeliveredAt DateTime?
  recapPublishedAt      DateTime?

  /// When the activation is/was scheduled to happen (vs. activationDeliveredAt = when it actually did).
  scheduledFor DateTime?

  expectedAttendance Int?
  actualAttendance   Int?
  enquiriesGenerated Int?

  /// Term metadata — denormalised for fast term-grid queries.
  /// Derived from scheduledFor (or campaign.startDate fallback) at write time.
  termYear   Int?
  termNumber Int?

  cancelledAt        DateTime?
  cancellationReason String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recapPosts       MarketingPost[] @relation("MarketingPostRecapFor")
  /// QR codes Akram has created and (optionally) linked to this activation.
  /// One activation can have multiple QRs (e.g. one per flyer batch).
  qrCodes          QrCode[]        @relation("QrCodeForActivation")
  sourcedEnquiries ParentEnquiry[] @relation("EnquiryFromActivation")

  @@unique([campaignId, serviceId])
  @@index([campaignId])
  @@index([serviceId])
  @@index([activationDeliveredAt])
  @@index([lifecycleStage])
  @@index([termYear, termNumber])
  @@index([scheduledFor])
}

/// Standalone trackable QR code. Created from /marketing/qr-codes or from
/// the activation panel; can be linked to an activation/service for context
/// but doesn't have to be.
model QrCode {
  id             String  @id @default(cuid())
  /// 7-char URL slug. Public scan URL = `${NEXTAUTH_URL}/a/${shortCode}`.
  shortCode      String  @unique
  /// Akram's label for this QR — e.g. "Minarah College Term 2 flyer batch A".
  name           String
  description    String? @db.Text
  /// Where the scan redirects to. Required.
  destinationUrl String
  /// Soft-archive flag; archived codes still resolve scans (so old flyers
  /// don't suddenly 404) but are hidden from the default management view.
  active         Boolean @default(true)

  /// Optional context tags.
  activationId String?
  activation   CampaignActivationAssignment? @relation("QrCodeForActivation", fields: [activationId], references: [id], onDelete: SetNull)
  serviceId    String?
  service      Service?                      @relation("QrCodeForService", fields: [serviceId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation("QrCodeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scans QrScan[]

  @@index([active])
  @@index([activationId])
  @@index([serviceId])
  @@index([createdById])
}

model QrScan {
  id        String   @id @default(cuid())
  qrCodeId  String
  qrCode    QrCode   @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  scannedAt DateTime @default(now())

  /// SHA-256 of (ip|secret) — never stores raw IPs. Used to count uniques.
  ipHash    String?
  userAgent String?
  referrer  String?
  /// Vercel-provided geolocation (best-effort). All optional.
  country   String?
  region    String?
  city      String?

  @@index([qrCodeId, scannedAt])
}

enum ActivationType {
  free_breakfast
  parent_info_session
  expert_talk
  programme_taster
  holiday_quest_preview
  open_day
  community_event
  other
}

enum ActivationLifecycleStage {
  concept
  approved
  logistics
  final_push
  delivered
  recap_published
  cancelled
}

