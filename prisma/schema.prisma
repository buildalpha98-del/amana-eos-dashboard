// ============================================================
// VAPI Call Tracking — AI phone call logs and follow-ups
// ============================================================

model VapiCall {
  id                       String         @id @default(cuid())
  vapiCallId               String?        @unique
  callType                 String // "new_enquiry" | "booking_change" | "billing_issue" | "escalation" | "holiday_quest" | "general_message"
  urgency                  String         @default("routine") // "routine" | "urgent" | "critical"
  status                   String         @default("new") // "new" | "in_progress" | "actioned" | "closed"
  assignedTo               String?
  parentName               String?
  parentPhone              String?
  parentEmail              String?
  childName                String?
  centreName               String?
  callDetails              Json?
  transcript               String?        @db.Text
  summary                  String?        @db.Text // Vapi post-call AI summary
  successEvaluation        Boolean? // Vapi post-call success evaluation
  recordingUrl             String?
  callDurationSeconds      Int?
  repeatCaller             Boolean        @default(false) // Same phone called within past 7 days
  followUpEmailSent        Boolean        @default(false)
  internalNotificationSent Boolean        @default(false)
  slaAlertedAt             DateTime? // Set when an SLA escalation has been sent, to prevent duplicates
  linkedEnquiryId          String?        @unique // ParentEnquiry auto-created from this call
  linkedEnquiry            ParentEnquiry? @relation("EnquiryFromCall", fields: [linkedEnquiryId], references: [id], onDelete: SetNull)
  linkedTodoId             String?        @unique // Todo auto-created from a booking-change call
  linkedTodo               Todo?          @relation("TodoFromCall", fields: [linkedTodoId], references: [id], onDelete: SetNull)
  notes                    String?        @db.Text
  actionedAt               DateTime?
  actionedBy               String?
  calledAt                 DateTime       @default(now())
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  @@index([status, callType])
  @@index([centreName, calledAt])
  @@index([urgency, status])
}

model ContentTeamMember {
  id          String            @id @default(cuid())
  name        String
  role        ContentTeamRole
  status      ContentTeamStatus @default(prospect)
  phone       String?
  email       String?
  notes       String?           @db.Text
  startedAt   DateTime?
  pausedAt    DateTime?
  pauseReason String?           @db.VarChar(500)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([status])
  @@index([role])
}

model SocialCounter {
  id          String   @id @default(cuid())
  weekStart   DateTime @unique @db.Date
  feed        Int      @default(0)
  stories     Int      @default(0)
  reels       Int      @default(0)
  updatedById String?
  updatedBy   User?    @relation("SocialCounterUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// AmanaWayContent — owner/admin-editable overrides for the
// in-app Amana Way handbook (`/tools/the-amana-way`). Singleton
// row keyed by id "singleton". `data` is a Record<string,string>
// of content-key → override text. Reads merge the override on
// top of the panel's defaults; missing keys fall through.
model AmanaWayContent {
  id          String   @id @default("singleton")
  data        Json     @default("{}")
  updatedById String?
  updatedBy   User?    @relation("AmanaWayContentUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// AmanaHandbookContent — owner/admin-editable overrides for the
// Educators Induction Handbook (`/tools/handbook`). Same singleton
// shape as AmanaWayContent. Decoupled from AmanaWayContent so the
// two handbooks evolve independently and overrides don't collide
// on shared default keys.
model AmanaHandbookContent {
  id          String   @id @default("singleton")
  data        Json     @default("{}")
  updatedById String?
  updatedBy   User?    @relation("AmanaHandbookContentUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 2026-05-17: per-template subject + body override for the ~52 transactional
// email templates in src/lib/email-templates/. Each template function looks
// up its `key` in this table (cached) and uses the override when present;
// otherwise falls back to the hardcoded copy. Variables interpolate via
// `{{name}}` placeholders. Editable from /settings/email-templates by
// owner / admin.
model EmailTemplateOverride {
  key         String   @id
  subject     String
  body        String   @db.Text
  updatedById String?
  updatedBy   User?    @relation("EmailTemplateUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


// ─────────────────────────────────────────────────────────────────────
// HR — Performance & disciplinary cases (2026-06-01)
// ─────────────────────────────────────────────────────────────────────
//
// Tracks formal disciplinary, performance management, and grievance
// events tied to a staff member. The data point Fair Work Commission
// asks for in any unfair-dismissal proceeding: "show me the warnings
// you gave them, the dates, what was said, who signed."
//
// Visibility model: admin/owner/head_office only. Staff don't see
// their own case file via this surface — managers communicate
// outcomes through the existing 1:1 / email channels. `confidential`
// raises the bar further (owner only) for sensitive allegations.
//
// Retention: Fair Work Act record-keeping requires 7 years. Cases
// are SOFT-deleted (`deleted=true`) rather than physically removed
// so the audit chain survives.

model PerformanceCase {
  id          String                @id @default(cuid())

  // Subject of the case — the staff member it concerns.
  userId      String
  user        User                  @relation("CaseSubject", fields: [userId], references: [id], onDelete: Cascade)

  // Manager / admin who logged it.
  raisedById  String
  raisedBy    User                  @relation("CaseRaiser", fields: [raisedById], references: [id])

  // Manager who closed it out (null while open).
  closedById  String?
  closedBy    User?                 @relation("CaseCloser", fields: [closedById], references: [id])

  type        PerformanceCaseType
  status      PerformanceCaseStatus @default(open)

  title       String                @db.VarChar(200)
  summary     String                @db.Text

  // The date the incident/conversation/etc actually happened. Separate
  // from `createdAt` because cases are often logged days after the fact.
  occurredAt  DateTime              @db.Date
  // Optional follow-up review date (e.g. PIP review in 4 weeks).
  followUpAt  DateTime?             @db.Date

  // Free-text resolution — what was the outcome. Null until closed.
  outcome     String?               @db.Text
  closedAt    DateTime?

  // Optional attachment — typically the signed warning letter PDF,
  // PIP document, or supporting evidence. Stored as Vercel Blob URL.
  fileUrl     String?
  fileName    String?

  // Confidential flag — restricts visibility to owner role only.
  // Use for sensitive allegations where even other admins shouldn't
  // see the detail (e.g. allegations of harassment against a colleague).
  confidential Boolean              @default(false)

  // Soft delete — Fair Work retention is 7 years; physical deletion
  // is restricted to owner and stays a future concern.
  deleted     Boolean               @default(false)

  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  // Back-ref for SeparationRecord — when a dismissal record references
  // this case as the justifying disciplinary chain. Many separations
  // CAN cite the same case (rare but legal), so it's a list.
  separations SeparationRecord[]    @relation("SeparationCase")

  @@index([userId, status])
  @@index([type, occurredAt])
}

enum PerformanceCaseType {
  // Disciplinary chain (ascending severity).
  verbal_warning
  written_warning
  final_warning
  // Performance improvement plan — formal, time-bound, written.
  pip
  // Complaint raised BY this staff member (the user is the complainant).
  grievance
  // Complaint raised AGAINST this staff member.
  allegation
  // Positive — recognition / commendation. Tracking the good with the
  // bad gives a more honest staff file and helps with regrading reviews.
  commendation
  // Informal "I had a chat with X about Y" — useful but doesn't escalate.
  conversation
}

enum PerformanceCaseStatus {
  open
  in_progress
  resolved
  escalated
  closed
}

// HR — Visa expiry alert dedup (2026-06-01)
//
// Mirrors ComplianceCertificateAlert but keyed on User because visa
// fields live on User, not on a separate Certificate row. Prevents the
// daily cron from re-emailing staff the same threshold twice.
//
// Unique on (userId, threshold) — once we've sent the "30 days left"
// notification for a given staff member's current visa, that pair is
// locked. Renewing the visa (new expiry > old) is detected by the
// cron and surfaces re-alerting in a future enhancement; v1 just stays
// quiet until the row is manually cleared.

model VisaAlert {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserVisaAlerts", fields: [userId], references: [id], onDelete: Cascade)
  // Threshold the alert was sent for: 30 | 14 | 7 | 0 (already expired).
  threshold Int
  sentAt    DateTime @default(now())

  @@unique([userId, threshold])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────
// HR — Performance reviews (2026-06-01)
// ─────────────────────────────────────────────────────────────────────
//
// Formal performance review cycles — distinct from PerformanceCase
// (which is the disciplinary / grievance / commendation case file).
// A review is a scheduled assessment with self + manager input, an
// optional rating, and a goal set carried forward to the next cycle.
//
// Phase 1 scope (this model): admin can create reviews for any staff
// member, fill in the manager assessment, set goals, mark complete.
// Self-assessment + staff acknowledgement workflows ship in phase 2 —
// the columns are already here so the migration is one-and-done.
//
// Visibility:
//   - admin / owner / head_office: full read/write on every review
//   - the subject (`userId`): reads their OWN reviews (My Portal) and
//     can fill `selfAssessment` while status = self_assessment, and
//     acknowledge while status = awaiting_acknowledgement. They never
//     see `privateNotes` (admin-only HR commentary).
//   - everyone else: 403
//
// Retention: Reviews form part of the staff file — soft-deleted only,
// retained 7 years per Fair Work record-keeping.

model PerformanceReview {
  id              String              @id @default(cuid())

  // Subject of the review — the staff member being reviewed.
  userId          String
  user            User                @relation("ReviewSubject", fields: [userId], references: [id], onDelete: Cascade)

  // The manager assigned to complete the review. Selected by the admin
  // at creation time (the User model has no direct "manager" relation,
  // so we can't auto-default — typically the centre Director or the
  // service manager from `Service.managerId` where applicable).
  reviewerUserId  String?
  reviewer        User?               @relation("ReviewReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)

  // Whoever created the cycle (admin scheduling it).
  createdById     String
  createdBy       User                @relation("ReviewCreator", fields: [createdById], references: [id])

  type            ReviewType
  status          ReviewStatus        @default(scheduled)

  // The review period this assessment covers. e.g. probation review =
  // start date → 75 days later; annual = anniversary year.
  periodStart     DateTime            @db.Date
  periodEnd       DateTime            @db.Date
  // When the completed review is due.
  dueDate         DateTime            @db.Date

  // ── Self-assessment (phase 2 workflow, columns ready now) ──
  selfAssessment       String?        @db.Text
  selfStrengths        String?        @db.Text
  selfImprovements     String?        @db.Text
  selfSubmittedAt      DateTime?

  // ── Manager assessment ──
  managerAssessment    String?        @db.Text
  managerStrengths     String?        @db.Text
  managerImprovements  String?        @db.Text
  managerSubmittedAt   DateTime?

  // Optional overall rating. Nullable so a review can be completed
  // without a rating where the type doesn't call for one (e.g. a
  // check-in conversation).
  overallRating        ReviewRating?

  // Staff acknowledgement — they've seen and signed off (or noted
  // disagreement in `acknowledgementNotes`).
  acknowledgedAt       DateTime?
  acknowledgementNotes String?        @db.Text

  // Admin-only HR commentary. Never returned to the subject.
  privateNotes         String?        @db.Text

  // When the review was finalised end-to-end (status = completed).
  completedAt          DateTime?

  // Soft delete — 7-year Fair Work retention.
  deleted              Boolean         @default(false)

  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  // Per-review goals carried forward.
  goals                PerformanceReviewGoal[]

  @@index([userId, status])
  @@index([reviewerUserId, status])
  @@index([dueDate])
  @@index([type, periodEnd])
}

enum ReviewType {
  probation         // ~75 days after start; binary pass/extend/end
  mid_year          // Light-touch check-in mid annual cycle
  annual            // Yearly full review
  ad_hoc            // Manager-initiated outside the normal cadence
}

enum ReviewStatus {
  scheduled                  // Created, not yet open for self-assessment
  self_assessment            // Subject can fill self-assessment
  manager_review             // Subject submitted; manager writing assessment
  awaiting_acknowledgement   // Manager submitted; subject must sign off
  completed                  // Acknowledged + closed
  cancelled                  // Cycle abandoned (subject left, etc.)
}

enum ReviewRating {
  below_expectations
  partially_meeting
  meeting_expectations
  exceeding_expectations
  exceptional
}

// Per-review goal — at review close-out the manager sets goals to
// carry forward to the next cycle. Each goal has its own status so
// mid-year check-ins can mark progress without re-opening the review.

model PerformanceReviewGoal {
  id            String         @id @default(cuid())
  reviewId      String
  review        PerformanceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  title         String         @db.VarChar(200)
  description   String?        @db.Text

  // Optional target date. Nullable for open-ended development goals.
  dueDate       DateTime?      @db.Date

  status        ReviewGoalStatus @default(not_started)

  // Manager's running notes on this goal between reviews.
  progressNotes String?        @db.Text

  // Render order in the UI — managers like to put the most important
  // goal first.
  sortOrder     Int            @default(0)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([reviewId, sortOrder])
}

enum ReviewGoalStatus {
  not_started
  in_progress
  achieved
  not_achieved
  deferred       // Carried forward to a later cycle
}

// ─────────────────────────────────────────────────────────────────────
// HR — Position descriptions (2026-06-01)
// ─────────────────────────────────────────────────────────────────────
//
// The formal "this is what this job is" document. Distinct from:
//   - Contract (legal employment terms — pay, hours, type, end date)
//   - Role enum (auth bucket — owner / admin / member / staff)
//
// Position descriptions are reusable templates. A given PD can be
// linked to many users (e.g. "Educator Lead" PD attached to every
// lead educator across centres). Staff see their assigned PD on My
// Portal as a read-only reference for "what's expected of me here."
//
// Admin-only CRUD. Soft delete via `archived` status — historical
// references survive even after a PD is no longer in active use.

model PositionDescription {
  id                String   @id @default(cuid())

  // Short identifying title. Used as the link label everywhere.
  title             String   @db.VarChar(200)

  // Plain-text fields (markdown-friendly via the viewer). All are
  // long-form so the same component renders any PD consistently.
  summary           String   @db.Text
  responsibilities  String   @db.Text
  selectionCriteria String   @db.Text
  qualifications    String   @db.Text

  // Optional hint matching this PD to a Role. Used in the assignment
  // picker to surface PDs that "fit" the staff member's role, but not
  // enforced — a staff-role user can still hold a Lead PD.
  targetRole        Role?

  status            PDStatus @default(draft)

  publishedAt       DateTime?
  archivedAt        DateTime?

  createdById       String
  createdBy         User     @relation("PDCreator", fields: [createdById], references: [id])

  // Users currently assigned this PD. SetNull on PD delete so a
  // mistakenly deleted PD doesn't cascade-delete staff records.
  assignedUsers     User[]   @relation("UserPositionDescription")

  // Vacancies linked to this PD — interviewers see the PD inline on
  // the vacancy detail surface.
  vacancies         RecruitmentVacancy[] @relation("VacancyPositionDescription")

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status, targetRole])
  @@index([targetRole])
}

enum PDStatus {
  draft
  published
  archived
}

// ─────────────────────────────────────────────────────────────────────
// HR — Reference checks on hire (2026-06-01)
// ─────────────────────────────────────────────────────────────────────
//
// Structured record of reference checks performed during hiring.
// The Fair Work Act doesn't mandate references but doing them is a
// well-established defence against negligent hiring claims (esp. in
// childcare where the bar for vetting is high). Capturing what was
// asked, who said what, when, and what we concluded protects the
// organisation if questions ever come back.
//
// Visibility: admin / owner / head_office only. Staff don't see
// references taken about themselves through this surface. Notes can
// reference identifiable third parties — owner-only deletion.
//
// Retention: 7 years per Fair Work record-keeping. Soft delete only.

model ReferenceCheck {
  id                  String   @id @default(cuid())

  // Subject of the check — the (prospective) hire.
  userId              String
  user                User     @relation("RefCheckSubject", fields: [userId], references: [id], onDelete: Cascade)

  // Who performed the check.
  checkedById         String
  checkedBy           User     @relation("RefCheckChecker", fields: [checkedById], references: [id])

  // Referee identity
  refereeName         String   @db.VarChar(200)
  refereeRelationship String   @db.VarChar(200)
  refereeOrganisation String?  @db.VarChar(200)
  refereePhone        String?
  refereeEmail        String?

  method              RefCheckMethod
  contactedAt         DateTime?

  status              RefCheckStatus           @default(pending)
  recommendation      RefCheckRecommendation?

  // Free-form structured notes — capture what was discussed. v1
  // doesn't enforce a fixed Q&A list; admins write down what was said.
  notes               String   @db.Text
  redFlags            String?  @db.Text

  // Specific anti-fraud / quality flags
  employmentVerified  Boolean?
  wouldRehire         Boolean?

  // 7-year Fair Work retention via soft delete.
  deleted             Boolean  @default(false)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId, status])
  @@index([checkedById])
}

enum RefCheckMethod {
  phone
  video
  email
  written_response
  in_person
}

enum RefCheckStatus {
  pending           // Created but not yet contacted
  contacted         // Attempted; awaiting response
  completed         // Done, notes captured
  unable_to_reach   // Couldn't get hold of the referee
  declined          // Referee declined to provide a reference
}

enum RefCheckRecommendation {
  strong_positive
  positive
  neutral
  reservations
  do_not_recommend
}

// ─────────────────────────────────────────────────────────────────────
// HR — Diversity & inclusion register (2026-06-01)
// ─────────────────────────────────────────────────────────────────────
//
// Opt-in self-disclosed diversity profile. Feeds the WGEA workforce-
// composition report (Workplace Gender Equality Agency mandatory
// reporting for orgs ≥ 100 employees — we may not hit that threshold
// for years but the register itself is a low-cost positive-step now).
//
// Privacy:
//   - Staff own their data. They can read, edit, and DELETE it.
//   - Admin NEVER sees individual values via any dashboard surface —
//     only aggregate counts with a min-cell-size threshold (≥3) so
//     categories of one or two can't be reverse-identified.
//   - Hard delete on consent withdrawal (no soft-delete here, by
//     design — staff trust depends on "no" actually meaning no).
//   - The endpoint is wrapped in withApiAuth so admin attempts to
//     read another user's profile are 403'd.

model DiversityProfile {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Gender identity — modeled per ABS Standard for Sex and Gender
  // Variables 2020. `prefer_to_self_describe` opens a free-text field
  // (genderSelfDescribed). Null = not disclosed.
  genderIdentity         DiversityGender?
  genderSelfDescribed    String?  @db.VarChar(200)

  // Cultural background — free text. Culture is too varied for an enum.
  culturalIdentity       String?  @db.VarChar(200)
  bornInAustralia        Boolean?
  yearArrivedInAustralia Int?
  languageAtHome         String?  @db.VarChar(200)

  // Indigenous identity (ABS Standard).
  indigenousIdentity     DiversityIndigenous?

  // Disability — high-level disclosure + optional self-described detail.
  disabilityStatus       DiversityDisability?
  disabilityType         String?  @db.VarChar(200)

  // Carer responsibilities (relevant for flexible work + family-friendly
  // policy planning).
  carerStatus            DiversityCarer?

  // Australian Defence Force veteran status.
  veteranStatus          Boolean?

  // Explicit consent stamp — set when first saved, refreshed on update.
  // Used in the privacy notice ("you opted in on YYYY-MM-DD").
  consentGivenAt         DateTime

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

enum DiversityGender {
  woman
  man
  non_binary
  prefer_to_self_describe
  prefer_not_to_say
}

enum DiversityIndigenous {
  none
  aboriginal
  torres_strait_islander
  both
  prefer_not_to_say
}

enum DiversityDisability {
  none
  with_disability
  prefer_not_to_say
}

enum DiversityCarer {
  none
  parent_carer
  family_carer
  both
  prefer_not_to_say
}

// ─────────────────────────────────────────────────────────────────────
// Service purchase approvals (2026-06-02)
// ─────────────────────────────────────────────────────────────────────
//
// Staff working at a centre raise an approval request BEFORE buying
// something with their personal funds. Admin reviews + approves or
// rejects. On approval the staff member is told to make the purchase
// and submit an expense claim through My Portal (EH Payroll), so the
// org reimbursement runs through normal payroll plumbing.
//
// Lives in: Service → Finance → Approvals sub-tab.
//
// Notifications fire on status change so the requester doesn't need
// to poll — the bell-icon UserNotification surface picks them up.
//
// Money stored in CENTS (Int) to dodge float rounding. payRate /
// budget elsewhere uses Float; centring on Int here is the cleaner
// pattern for a new column and a 7-year audit footprint.

model PurchaseApproval {
  id           String  @id @default(cuid())

  serviceId    String
  service      Service @relation("ServicePurchaseApprovals", fields: [serviceId], references: [id], onDelete: Cascade)

  // Who's asking to buy the thing.
  requestedById String
  requestedBy   User   @relation("PurchaseApprovalRequester", fields: [requestedById], references: [id], onDelete: Cascade)

  vendor       String  @db.VarChar(200)   // e.g. "Officeworks"
  product      String  @db.VarChar(500)   // e.g. "Pack of coloring pens (50 ct)"
  costCents    Int                        // e.g. 2000 = $20.00
  reason       String? @db.Text           // optional rationale

  status       PurchaseApprovalStatus @default(pending)

  // Decision audit.
  decidedById  String?
  decidedBy    User?    @relation("PurchaseApprovalDecider", fields: [decidedById], references: [id], onDelete: SetNull)
  decidedAt    DateTime?
  decisionNote String?  @db.Text   // admin's note on approve/reject

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([serviceId, status])
  @@index([requestedById, status])
  @@index([status, createdAt])
}

enum PurchaseApprovalStatus {
  pending
  approved
  rejected
  cancelled  // requester withdrew before decision
}

// ─────────────────────────────────────────────────────────────────────
// EH Payroll webhook audit (2026-06-01)
// ─────────────────────────────────────────────────────────────────────
//
// Mirror of every webhook event Employment Hero Payroll fires at us.
// Use cases:
//   - HMAC-verified inbound goes here regardless of whether we
//     "understand" the event type — provides a complete forensic
//     audit if support need to reconstruct what happened
//   - `providerEventId` is unique → idempotent processing (EH retries
//     up to 3 times on non-200 responses, we DON'T want to double-act)
//   - `processedAt`/`error` track whether downstream handling worked
//
// Retention is rolled in with the existing audit-log cleanup cron at
// 7 years — these aren't security records but they're operationally
// useful enough that we don't want them pruning aggressively.

model EhWebhookEvent {
  id              String   @id @default(cuid())

  eventType       String   @db.VarChar(100)
  // EH provides an event ID we can dedup on. Optional because not
  // every event type carries one.
  providerEventId String?  @db.VarChar(200)
  payload         Json

  receivedAt      DateTime @default(now())
  processedAt     DateTime?
  // Free-text error from the handler when processing failed. Null
  // when processedAt is set successfully.
  error           String?  @db.Text

  @@unique([providerEventId])
  @@index([eventType, receivedAt])
  @@index([receivedAt])
}

// ─────────────────────────────────────────────────────────────────────
// HR — Anonymous safe-reporting channel (2026-06-01)
// ─────────────────────────────────────────────────────────────────────
//
// Closes the positive-duty obligation under the *Sex Discrimination
// and Fair Work (Respect at Work) Amendment Act 2022* (in force since
// Dec 2023). The Australian Human Rights Commission can investigate
// employers for failure to take reasonable steps to prevent sexual
// harassment — having a safe reporting channel is one of the named
// "reasonable steps."
//
// Design hard requirements:
//   - NO reporterId, NO ipAddress, NO userAgent. The intake API
//     deliberately ignores the session even when one is present
//     (uses `withApiHandler`, not `withApiAuth`).
//   - Only reviewedById is stored — that's the owner / designated
//     reviewer, NOT the reporter.
//   - Auto-delete is NOT implemented at the DB layer. Reports may
//     be needed as evidence years later (statute of limitations on
//     harassment claims is up to 6 years). The owner can soft-delete
//     once truly resolved.

model SafeReport {
  id          String              @id @default(cuid())

  // What the report is about — drives triage. `child_safety` is
  // separately flagged because it carries mandatory-reporting
  // implications and may need to be escalated to authorities.
  category    SafeReportCategory

  // Optional service context. Reports about the whole org leave this
  // null. Helps the reviewer route + scope follow-up.
  serviceId   String?
  service     Service?            @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  // The report itself. Up to ~20k chars (enforced at zod layer).
  content     String              @db.Text

  status      SafeReportStatus    @default(received)

  // Private to the reviewer — never displayed to anyone except the
  // owner/reviewer. Things like "called Mirna 12 May, agreed to mediate."
  reviewNotes String?             @db.Text

  reviewedById String?
  reviewedBy   User?               @relation("SafeReportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  resolvedAt   DateTime?

  // Soft delete for "received in error / resolved with no further
  // action needed and we'd like to declutter." Owner only.
  deleted      Boolean             @default(false)

  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([status, createdAt])
  @@index([category, createdAt])
}

enum SafeReportCategory {
  harassment           // Including sexual harassment (positive-duty)
  discrimination       // Sex, race, disability, age, religion, etc
  bullying
  safety               // WHS / hazard concerns
  conduct              // General staff conduct concerns
  retaliation          // Retaliation against another reporter — critical
  child_safety         // Child Safe Standards concerns — most urgent
  other
}

enum SafeReportStatus {
  received
  under_review
  resolved
  closed_no_action
}

// ─────────────────────────────────────────────────────────────────────
// HR — Separation record (2026-06-01)
// ─────────────────────────────────────────────────────────────────────
//
// The legal-fact record of an employee's departure. Closes the #6 HR
// audit finding. Complements the existing StaffOffboarding pack
// (operational checklist — return laptop, etc); SeparationRecord
// captures the things Fair Work / FWC will ask for:
//
//   - WHY did they leave (structured enum, not free text)?
//   - When was notice given, when was the last working day?
//   - Has final pay been processed?
//   - Was a reference letter issued, what does it say?
//   - Are they eligible for rehire (matters for casual pool)?
//   - For dismissals: link to the PerformanceCase chain that
//     justifies the dismissal — procedural fairness defence.
//
// Retention: 7 years (Fair Work record-keeping). Soft-delete only.

model SeparationRecord {
  id              String           @id @default(cuid())

  // ONE separation per user (re-hires get a new record under a new
  // User row or we soft-delete + recreate). Unique constraint enforces.
  userId          String           @unique
  user            User             @relation("SeparationSubject", fields: [userId], references: [id], onDelete: Cascade)

  reason          SeparationReason
  // Free-text expansion of reason. Required at the UI layer for any
  // dismissal type (capacity / misconduct) so the why is documented.
  reasonDetail    String?          @db.Text

  // Timeline.
  noticeStartDate DateTime?        @db.Date
  lastWorkingDay  DateTime         @db.Date
  noticePeriodWeeks Float?

  // Final-pay tracking — the most common dispute source after dismissal.
  finalPayProcessed   Boolean      @default(false)
  finalPayProcessedAt DateTime?
  finalPayNotes       String?      @db.Text

  // Reference letter.
  referenceLetterIssued Boolean    @default(false)
  referenceLetterUrl    String?
  referenceNotes        String?    @db.Text

  // Rehire eligibility — drives the casual pool / re-recruitment view.
  eligibleForRehire Boolean        @default(true)
  rehireNotes       String?        @db.Text

  // Employment Hero termination sync (2026-07-08).
  // When a Separation record is created / updated with a lastWorkingDay
  // and the user has employmentHeroEmployeeId, we push the termination
  // date to EH so payroll doesn't keep the person active. We stamp the
  // sync timestamp here on success and the error message on failure so
  // the SeparationTab can show a status badge + retry button.
  ehTerminationSyncedAt DateTime?
  ehTerminationError    String?    @db.Text

  // Exit interview — separate from the offboarding pack so it's an
  // explicit fact, not just one task in a list.
  exitInterviewCompleted Boolean   @default(false)
  exitInterviewNotes     String?   @db.Text
  exitInterviewAt        DateTime?

  // For dismissal cases — link to the disciplinary chain that justifies
  // the termination. Procedural fairness defence.
  performanceCaseId String?
  performanceCase   PerformanceCase? @relation("SeparationCase", fields: [performanceCaseId], references: [id], onDelete: SetNull)

  // Audit.
  recordedById  String
  recordedBy    User             @relation("SeparationRecorder", fields: [recordedById], references: [id])

  // ── Finalisation (2026-06-01) ─────────────────────────────
  // `finalisedAt` is the point of no return: when set, the system
  // executed the orchestration side-effects (deactivate user, clear
  // EH mapping, transfer owned Rocks/Issues/Todos to a successor).
  // Owner-only action via POST /api/separations/[id]/finalise.
  finalisedAt   DateTime?
  finalisedById String?
  finalisedBy   User?            @relation("SeparationFinaliser", fields: [finalisedById], references: [id], onDelete: SetNull)

  // If specified at finalisation, who took over the leaving staff
  // member's ownership of Rocks / open Todos / Issues. Null = no
  // transfer requested (owner consciously left orphans for triage).
  successorUserId String?

  // Soft delete — Fair Work retention is 7 years.
  deleted       Boolean          @default(false)

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([reason])
  @@index([lastWorkingDay])
  @@index([finalisedAt])
}

enum SeparationReason {
  resignation
  dismissal_capacity         // unable to perform the role
  dismissal_misconduct       // serious or sustained misconduct
  redundancy
  end_of_contract            // fixed-term contract completed
  mutual_separation
  retirement
  abandonment                // stopped showing up; no contact
  deceased
  other
}

// ─────────────────────────────────────────────────────────────────────
// HR — Casual conversion (Closing Loopholes No. 2 Act, Aug 2024)
// ─────────────────────────────────────────────────────────────────────
//
// Employee-choice model: a casual who has been employed for at least
// 6 months (12 months for small businesses with <15 employees) can
// elect in writing to convert to permanent. The employer must respond
// in writing within 21 days. Refusals are only valid on narrow
// grounds (Fair Work Act s66B).
//
// This model is the audit trail Fair Work asks for if a dispute is
// lodged. Manual entry by admin v1; later: a self-service surface
// where casuals can submit their own election.

model CasualConversionElection {
  id              String                    @id @default(cuid())

  userId          String
  user            User                      @relation("CasualConversionUser", fields: [userId], references: [id], onDelete: Cascade)

  // The Act gives the employee the choice — part-time vs full-time.
  requestedType   ConversionRequestType

  // When the election was lodged (employee → employer).
  electedAt       DateTime                  @default(now())
  // Optional context the employee provided in their written request.
  electionNotes   String?                   @db.Text

  // ─── Employer response ─────────────────────────────────────
  // Per s66B(2), employer must respond in writing within 21 days.
  // The dashboard surface shows a countdown ticker when this is null.
  respondedAt     DateTime?
  respondedById   String?
  respondedBy     User?                     @relation("CasualConversionResponder", fields: [respondedById], references: [id], onDelete: SetNull)
  response        ConversionResponse?
  // REQUIRED for declined responses. Per s66B(3) the only valid grounds
  // are limited (operational, position not existing in 12mo, etc).
  // Free text so admin can document the specific grounds cited.
  declineReasons  String?                   @db.Text

  // If accepted, link to the new EmploymentContract that was issued.
  // SetNull because deleting the contract shouldn't cascade-delete the
  // election record — the election history stands regardless.
  newContractId   String?                   @unique
  newContract     EmploymentContract?       @relation("ConversionResultContract", fields: [newContractId], references: [id], onDelete: SetNull)

  // Soft delete only — Fair Work retention is 7 years.
  deleted         Boolean                   @default(false)

  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([userId, electedAt])
  @@index([response])
}

enum ConversionRequestType {
  part_time
  full_time
}

enum ConversionResponse {
  accepted
  declined
}

// ─────────────────────────────────────────────────────────────────────
// HR — Workers Compensation claim record (2026-06-01)
// ─────────────────────────────────────────────────────────────────────
//
// Tracks a workers compensation claim from lodgement → decision →
// return-to-work → closure. Owned by HR, not the insurer (we don't
// pretend to be a claims-management system); the goal is internal
// audit trail + RTW plan tracking + a single place to see "what's
// the status of this claim" without digging through emails.
//
// Linked to IncidentRecord (optional — some claims arise from
// gradual-onset injuries with no single incident).
//
// Retention: indefinite for active claims; 7 years post-closure
// per Fair Work + workers comp scheme record-keeping.

model WorkersCompensationClaim {
  id              String                @id @default(cuid())

  // Claimant — the injured staff member.
  userId          String
  user            User                  @relation("WCClaimant", fields: [userId], references: [id], onDelete: Cascade)

  // Optional originating incident.
  incidentId      String?
  incident        IncidentRecord?       @relation("IncidentWCClaim", fields: [incidentId], references: [id], onDelete: SetNull)

  // Insurer / claim metadata.
  claimNumber     String?               // e.g. "WC-2026-001234"
  insurerName     String?               // e.g. "iCare", "Allianz Workers Comp"
  insurerContact  String?               @db.Text // claims manager name + email/phone

  status          WCClaimStatus         @default(lodged)

  // Timeline.
  dateOfInjury    DateTime              @db.Date
  dateLodged      DateTime              @db.Date
  dateOfDecision  DateTime?             @db.Date

  // Injury detail (free text for flexibility — body part can be
  // multi-site, mechanism is highly varied).
  injuryDescription String?             @db.Text
  bodyPart          String?
  mechanismOfInjury String?             @db.Text

  // Return to work tracking — the most operational piece.
  rtwPlanCreated      Boolean           @default(false)
  rtwPlanUrl          String?
  rtwStartDate        DateTime?         @db.Date
  rtwFullCapacityDate DateTime?         @db.Date
  currentRestrictions String?           @db.Text

  // Payment status (high-level — we don't replicate the insurer's
  // ledger, just flag whether weekly payments are active).
  weeklyPaymentActive Boolean           @default(false)
  weeklyPaymentRate   Float?
  medicalExpensesPaid Float?

  notes           String?               @db.Text

  closedAt        DateTime?
  closedById      String?
  closedBy        User?                 @relation("WCClaimCloser", fields: [closedById], references: [id], onDelete: SetNull)

  createdById     String
  createdBy       User                  @relation("WCClaimCreator", fields: [createdById], references: [id])

  deleted         Boolean               @default(false)

  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([userId, status])
  @@index([incidentId])
  @@index([status, dateLodged])
}

enum WCClaimStatus {
  lodged
  under_review
  accepted
  declined
  on_hold
  closed
  reopened
}

// ─────────────────────────────────────────────────────────────────────
// HR — Reasonable adjustment (2026-06-01)
// ─────────────────────────────────────────────────────────────────────
//
// Records of accommodation requests + decisions under the Disability
// Discrimination Act 1992 + Fair Work Act anti-discrimination
// provisions. The legal test for refusing an adjustment is
// "unjustifiable hardship" — and to defend that, you need a record
// showing you actually considered the request and what trade-offs
// you weighed. Most discrimination claims are won and lost on this
// evidence.
//
// Sensitive — admin-only visibility. Often touches medical /
// disability information.

model ReasonableAdjustment {
  id              String                       @id @default(cuid())

  userId          String
  user            User                         @relation("AdjustmentSubject", fields: [userId], references: [id], onDelete: Cascade)

  // The request
  requestedAt     DateTime                     @db.Date
  requestSummary  String                       @db.Text

  // Free-text context — disability or protected attribute the
  // adjustment relates to. Optional because the employee may not
  // wish to specify (and the employer can't insist).
  contextNotes    String?                      @db.Text

  // Assessment
  assessedAt      DateTime?                    @db.Date
  // What was considered: alternatives weighed, who was consulted
  // (OT, medical, HR advisor), trade-offs.
  assessmentNotes String?                      @db.Text

  // Decision
  status          ReasonableAdjustmentStatus   @default(under_assessment)
  decisionAt      DateTime?                    @db.Date
  decisionDetail  String?                      @db.Text
  // REQUIRED when status=declined per DDA. Free text so admin can
  // document the specific "unjustifiable hardship" basis.
  declineReasons  String?                      @db.Text

  // Review schedule — adjustments aren't set-and-forget.
  reviewAt        DateTime?                    @db.Date

  // Optional attachment — medical note, OT recommendation, etc.
  fileUrl         String?
  fileName        String?

  // Audit
  recordedById    String
  recordedBy      User                         @relation("AdjustmentRecorder", fields: [recordedById], references: [id])

  deleted         Boolean                      @default(false)
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  @@index([userId, status])
  @@index([reviewAt])
}

enum ReasonableAdjustmentStatus {
  under_assessment
  provided              // exactly as requested
  modified              // alternative provided, not exact match
  declined
  withdrawn             // employee withdrew the request
  no_longer_needed
}

// ============================================================
// 2026-07-05: AI morning briefing v1
// ============================================================

model DailyBriefing {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation("UserDailyBriefings", fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime  @db.Date
  /// AI-composed markdown brief (deterministic fallback when AI is down).
  content   String    @db.Text
  /// Raw signal payload the brief was composed from — powers the card chips.
  signals   Json?
  /// Which composer produced it: "ai" | "fallback".
  source    String    @default("ai")
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@unique([userId, date])
  @@index([userId, date])
  @@index([date])
}
