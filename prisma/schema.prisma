  serviceCode    String?
  // ── Inbound feedback channel (SMS reply, NPS form, manual entry) ──
  source         String? // sms_reply | nps_form | email_reply | manual
  channel        String? // sms | email | web
  fromNumber     String? // E.164 mobile if SMS reply
  contactId      String?
  contact        CentreContact? @relation("ContactFeedback", fields: [contactId], references: [id], onDelete: SetNull)
  childId        String?
  child          Child?         @relation("ChildFeedback", fields: [childId], references: [id], onDelete: SetNull)
  surveyType     String? // quarterly_survey, nps, complaint, compliment, suggestion, exit_survey, sms_reply
