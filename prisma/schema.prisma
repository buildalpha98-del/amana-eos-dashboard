  serviceId             String
  service               Service   @relation("ServiceIncidents", fields: [serviceId], references: [id])
  incidentDate          DateTime
  childName             String?
  incidentType          String // injury | illness | behaviour | missing_child | near_miss | medication_error | property_damage | complaint
  severity              String // minor | moderate | reportable | serious
  location              String? // indoor | outdoor | playground | transition | bathroom | kitchen
  timeOfDay             String? // arrival | programme | meal_time | packdown | departure
