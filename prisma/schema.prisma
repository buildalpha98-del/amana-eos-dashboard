model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  passwordHash   String
  role           Role      @default(member)
  avatar         String?
  active         Boolean   @default(true)
  serviceId      String?
  service        Service?  @relation("ServiceStaff", fields: [serviceId], references: [id], onDelete: SetNull)
  state          String? // Australian state for State Manager scoping (VIC, NSW, QLD, etc.)
  // 2026-05-12: free-form admin-managed tags for /team filtering and
  // org-specific grouping (e.g. "nsw", "lead-trainer", "weekend-only").
  // Always lowercased + trimmed at write time so "NSW" and "nsw" are
  // the same tag. Default empty array so existing rows don't need a
  // backfill. Max 20 per user enforced at the API layer.
  tags           String[]  @default([])
  tokenVersion   Int       @default(0) // Bump to invalidate all existing sessions
  mfaSecret      String? // Encrypted TOTP secret (null = MFA not enrolled)
  mfaBackupCodes String[] // Hashed one-time recovery codes
  mfaEnabledAt   DateTime? // Non-null = MFA is active
  lastLoginAt    DateTime? // Updated on each successful sign-in
  // 2026-05-04 (timeclock v1): 4-digit PIN used at the kiosk to clock
  // in/out. Staff sets it themselves in My Portal; admin can `reset`
  // (clear the hash, never read it). `kioskPinSetAt` lets us flag
  // "PIN required before you can use the kiosk" for first-time users.
  kioskPinHash   String?
  kioskPinSetAt  DateTime?
  // 2026-06-01: maps this User to their Employment Hero Payroll employee
  // record so My Portal can surface payslips/leave/expenses. Nullable —
  // not every dashboard user is in payroll (e.g. casuals during trial,
  // historical accounts). Populated by the daily sync cron based on email
  // match; admins can manually override for unmatched users.
  employmentHeroEmployeeId Int? @unique
  // 2026-06-01 (right to disconnect — Fair Work Act s333M, in force
  // Aug 2024). Staff-set preference: "don't message me between these
  // hours." Stored as HH:MM strings to avoid timezone/`@db.Time`
  // headaches. Both null = no preference set (the legal default is
  // still that the employee can refuse unreasonable contact, but
  // we'd lose evidence of an explicit refusal pattern).
  // When `quietHoursStart > quietHoursEnd` the window wraps midnight
  // (e.g. "20:00" → "07:00" = evening + overnight + early morning).
  quietHoursStart String?
  quietHoursEnd   String?
  // Free-form expansion — "no contact on weekends", "calls OK in
  // genuine emergencies only", etc. Helps managers calibrate.
  quietHoursNotes String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  ownedRocks                    Rock[]                         @relation("RockOwner")
  assignedTodos                 Todo[]                         @relation("TodoAssignee")
  createdTodos                  Todo[]                         @relation("TodoCreator")
  raisedIssues                  Issue[]                        @relation("IssueRaiser")
  ownedIssues                   Issue[]                        @relation("IssueOwner")
  ownedMeasurables              Measurable[]                   @relation("MeasurableOwner")
  ownedScorecards               Scorecard[]                    @relation("ScorecardOwner")
  scorecardMemberships          ScorecardMember[]              @relation("ScorecardMembership")
  measurableEntries             MeasurableEntry[]              @relation("EntryCreator")
  activityLogs                  ActivityLog[]
  vtoUpdates                    VisionTractionOrganiser[]      @relation("VTOUpdater")
  managedServices               Service[]                      @relation("ServiceManager")
  ownedProjects                 Project[]                      @relation("ProjectOwner")
  createdMeetings               Meeting[]                      @relation("MeetingCreator")
  uploadedDocuments             Document[]                     @relation("DocumentUploader")
  assignedDocuments             Document[]                     @relation("DocumentAssignee")
  uploadedAttachments           Attachment[]                   @relation("AttachmentUploader")
  assignedTickets               SupportTicket[]                @relation("TicketAssignee")
  sentMessages                  TicketMessage[]                @relation("MessageSender")
  dismissedNotifications        NotificationDismissal[]
  marketingPosts                MarketingPost[]                @relation("MarketingPostAssignee")
  approvedPosts                 MarketingPost[]                @relation("MarketingPostApprover")
  marketingComments             MarketingComment[]             @relation("MarketingCommentAuthor")
  marketingPostRevisions        MarketingPostRevision[]        @relation("MarketingPostRevisionAuthor")
  marketingTasks                MarketingTask[]                @relation("MarketingTaskAssignee")
  announcements                 Announcement[]                 @relation("AnnouncementAuthor")
  announcementReads             AnnouncementRead[]             @relation("AnnouncementReader")
  cascadeAcks                   CascadeAcknowledgment[]        @relation("CascadeAcknowledger")
  weeklyPulses                  WeeklyPulse[]                  @relation("PulseAuthor")
  passwordResetTokens           PasswordResetToken[]
  calendarIntegration           CalendarIntegration?
  onboardings                   StaffOnboarding[]              @relation("OnboardingUser")
  lmsEnrollments                LMSEnrollment[]                @relation("LMSStudent")
  certificates                  ComplianceCertificate[]        @relation("UserCertificates")
  practicalSignoffs             PracticalSignoff[]             @relation("SignoffSubject")
  practicalSignoffsGiven        PracticalSignoff[]             @relation("SignoffSigner")
  recordedAttendance            DailyAttendance[]              @relation("AttendanceRecorder")
  signedInRecords               AttendanceRecord[]             @relation("SignInRecorder")
  signedOutRecords              AttendanceRecord[]             @relation("SignOutRecorder")
  budgetItemsCreated            BudgetItem[]                   @relation("BudgetItemCreator")
  feedbackReviewed              ParentFeedback[]               @relation("FeedbackReviewer")
  programActivitiesCreated      ProgramActivity[]              @relation("ProgramCreator")
  menuWeeksCreated              MenuWeek[]                     @relation("MenuCreator")
  activityTemplatesCreated      ActivityTemplate[]             @relation("ActivityTemplateCreator")
  activityTemplateFilesUploaded ActivityTemplateFile[]         @relation("ActivityTemplateFileUploader")
  seatAssignments               AccountabilitySeatAssignment[]
  todoTemplatesAssigned         TodoTemplate[]                 @relation("TemplateAssignee")
  todoTemplatesCreated          TodoTemplate[]                 @relation("TemplateCreator")
  createdServiceEvents          ServiceEvent[]                 @relation("ServiceEventCreator")

  // ── Performance / disciplinary back-refs ───────────
  // Cases where THIS user is the subject (warnings against them, grievances
  // they raised, PIPs about their performance). Plus cases they raised as
  // a manager and cases they closed. All three relations are needed because
  // Prisma requires a back-reference field per named relation.
  performanceCases       PerformanceCase[] @relation("CaseSubject")
  raisedPerformanceCases PerformanceCase[] @relation("CaseRaiser")
  closedPerformanceCases PerformanceCase[] @relation("CaseCloser")

  // Performance review back-refs (separate from PerformanceCase —
  // reviews are scheduled assessments, cases are disciplinary records).
  performanceReviews     PerformanceReview[] @relation("ReviewSubject")
  reviewsReviewing       PerformanceReview[] @relation("ReviewReviewer")
  reviewsCreated         PerformanceReview[] @relation("ReviewCreator")

  // Position description assignment. The PD library is the formal
  // "this is what this job is" document — separate from contracts
  // (legal terms) and from the role enum (auth bucket).
  positionDescriptionId           String?
  positionDescription             PositionDescription? @relation("UserPositionDescription", fields: [positionDescriptionId], references: [id], onDelete: SetNull)
  positionDescriptionAssignedAt   DateTime?
  createdPositionDescriptions     PositionDescription[] @relation("PDCreator")

  // Reference checks — back-refs for both subject-side (checks ABOUT
  // this user during their hiring) and checker-side (checks this user
  // PERFORMED on others). Subject-side is the primary use case.
  referenceChecks                 ReferenceCheck[] @relation("RefCheckSubject")
  performedReferenceChecks        ReferenceCheck[] @relation("RefCheckChecker")

  // Diversity & inclusion self-disclosed profile (opt-in). Withdrawal
  // hard-deletes the row, so the relation cascades.
  diversityProfile                DiversityProfile?

  // Per-(userId, threshold) dedup marker for the visa-expiry alert
  // cron. Mirrors ComplianceCertificateAlert but keyed on User
  // because visa lives on the User row, not a separate cert record.
  visaAlerts             VisaAlert[]       @relation("UserVisaAlerts")

  // Back-ref for SafeReport.reviewedBy — SafeReport has NO reporterId
  // (anonymity is the whole point). This relation only tracks who
  // *reviewed* / *resolved* a report; never who filed it.
  reviewedSafeReports    SafeReport[]      @relation("SafeReportReviewer")

  // Per-User separation record (Fair Work termination evidence).
  // Complements StaffOffboarding (operational checklist) — Separation
  // is the legal-fact record of why and how they left.
  separationRecord       SeparationRecord? @relation("SeparationSubject")
  recordedSeparations    SeparationRecord[] @relation("SeparationRecorder")
  finalisedSeparations   SeparationRecord[] @relation("SeparationFinaliser")

  // Casual conversion elections — Closing Loopholes No. 2 Act 2024
  // (employee-choice model). Multiple records possible over a casual's
  // tenure; cooldown rules apply between elections.
  casualConversionElections CasualConversionElection[] @relation("CasualConversionUser")
  respondedConversions      CasualConversionElection[] @relation("CasualConversionResponder")

  // Workers Compensation claims (Health & WHS section).
  workersCompClaims         WorkersCompensationClaim[] @relation("WCClaimant")
  createdWCClaims           WorkersCompensationClaim[] @relation("WCClaimCreator")
  closedWCClaims            WorkersCompensationClaim[] @relation("WCClaimCloser")

  // Reasonable adjustment records (Disability Discrimination Act 1992
  // defence). Sensitive — admin-only.
  reasonableAdjustments     ReasonableAdjustment[]   @relation("AdjustmentSubject")
  recordedAdjustments       ReasonableAdjustment[]   @relation("AdjustmentRecorder")

  // Purchase-approval requests — staff submit these from the service
  // Finance tab when they need to buy something with personal funds.
  purchaseApprovalsRequested PurchaseApproval[] @relation("PurchaseApprovalRequester")
  purchaseApprovalsDecided   PurchaseApproval[] @relation("PurchaseApprovalDecider")

  // ── NQS back-refs ─────────────────────────────────
  staffReflections          StaffReflection[]          @relation("StaffReflections")
  learningObservations      LearningObservation[]      @relation("LearningObservations")
  medicationAdministrations MedicationAdministration[] @relation("MedicationAdministered")
  medicationWitnesses       MedicationAdministration[] @relation("MedicationWitnessed")
  staffRiskAssessments      RiskAssessment[]           @relation("RiskAssessments")
  riskAssessmentApprovals   RiskAssessment[]           @relation("RiskAssessmentApprovals")
  shiftHandovers            ShiftHandover[]            @relation("ShiftHandovers")

  // ── Staff Profile Expansion ──────────────────────────────────
  phone             String?
  dateOfBirth       DateTime?       @db.Date
  addressStreet     String?
  addressSuburb     String?
  addressState      String?
  addressPostcode   String?
  taxFileNumber     String?         @db.Text // AES-256-GCM encrypted
  superFundName     String?
  superMemberNumber String?
  superUSI          String?
  visaStatus        VisaStatus?
  visaExpiry        DateTime?       @db.Date
  employmentType    EmploymentType?
  startDate         DateTime?       @db.Date
  probationEndDate  DateTime?       @db.Date

  // ── Induction state machine (see src/lib/induction.ts) ──
  inductionStatus        InductionStatus @default(cleared)
  inductionDueDate       DateTime?
  inductionClearedAt     DateTime?
  inductionClearedById   String?
  inductionGraceUntil    DateTime?
  inductionOverrideUntil DateTime?
  bankDetailsNote   String?
  bankAccountName   String?
  bankBSB           String?
  bankAccountNumber String?
  xeroEmployeeId    String?

  // ── HR Relations ─────────────────────────────────────────────
  emergencyContacts        EmergencyContact[]
  qualifications           StaffQualification[]
  pdRecords                ProfessionalDevelopmentRecord[] @relation("UserPdRecords")
  contracts                EmploymentContract[]            @relation("ContractEmployee")
  // Back-ref for contracts where this user signed as the issuing
  // admin. 2026-06-02 — two-party contract signature feature.
  signedContractsAsAdmin   EmploymentContract[]            @relation("ContractAdminSigner")
  createdContractTemplates ContractTemplate[]              @relation("TemplateCreator")
  updatedContractTemplates ContractTemplate[]              @relation("TemplateUpdater")
  createdContractCustomTags ContractCustomTag[]            @relation("ContractCustomTagCreator")
  leaveRequests            LeaveRequest[]                  @relation("LeaveRequester")
  approvedLeaves           LeaveRequest[]                  @relation("LeaveApprover")
  leaveBalances            LeaveBalance[]
  timesheetEntries         TimesheetEntry[]                @relation("TimesheetStaff")
  policyDocVersionUploads  PolicyDocumentVersion[]         @relation("PolicyDocVersionUploader")
  policyDocAcks            PolicyDocumentAcknowledgement[] @relation("PolicyDocAcknowledger")
  offboardings             StaffOffboarding[]              @relation("OffboardingUser")
  apiKeys                  ApiKey[]                        @relation("ApiKeyCreator")

  // ── CRM Relations ───────────────────────────────────────────
  assignedLeads           Lead[]                         @relation("LeadAssignee")
  touchpointsSent         TouchpointLog[]                @relation("TouchpointSender")
  activationCoordinations CampaignActivationAssignment[] @relation("ActivationCoordinator")

  // ── Compliance Audit Relations
  conductedAudits AuditInstance[] @relation("AuditAuditor")

  // ── Scenario Modelling
  scenarios Scenario[] @relation("ScenarioCreator")

  // ── Marketing Operations ──────────────────────────────
  schoolCommsSent      SchoolComm[]         @relation("SchoolCommSender")
  photoComplianceConfs PhotoComplianceLog[] @relation("PhotoComplianceConfirmer")
  termCalendarAssigned TermCalendarEntry[]  @relation("TermCalendarAssignee")

  // ── Parent Enquiry Pipeline ──────────────────────────
  assignedEnquiries ParentEnquiry[] @relation("EnquiryAssignee")

  // ── Recruitment Pipeline ───────────────────────────
  filledVacancies    RecruitmentVacancy[]   @relation("VacancyFilledBy")
  assignedVacancies  RecruitmentVacancy[]   @relation("VacancyAssignee")
  candidateReferrals RecruitmentCandidate[] @relation("CandidateReferrer")
  staffReferrals     StaffReferral[]        @relation("StaffReferrer")
  pulseSurveys       StaffPulseSurvey[]     @relation("UserPulseSurveys")

