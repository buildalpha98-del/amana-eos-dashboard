  notes        String?
  enteredById  String?
  enteredBy    User?      @relation("EntryCreator", fields: [enteredById], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([measurableId, weekOf])
  @@index([weekOf])
  @@index([enteredById])
}

model ActivityLog {
